# Database - Use PostgreSQL connection string
# For connection pooling, add ?connection_limit=10 to your DATABASE_URL
DATABASE_URL="postgresql://user:password@localhost:5432/cicle?schema=public&connection_limit=10"

# Session - MUST be changed in production
SESSION_SECRET="your-super-secret-key-change-this-in-production"

# Port (EasyPanel will set this)
PORT=3000

# Redis (optional, for Socket.io scaling)
# REDIS_URL="redis://localhost:6379"

# App URL (for email links, push notifications)
# APP_URL="https://your-domain.com"

# Email (optional, for digest emails)
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=587
# SMTP_USER="your-email@gmail.com"
# SMTP_PASS="your-app-password"
# SMTP_FROM="noreply@your-domain.com"
