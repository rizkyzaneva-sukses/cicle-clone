<%- include('partials/header', { title: 'Profil Saya' }) %>

<%
  const initial = (user.name || user.email || 'U').charAt(0).toUpperCase();
  const roleLabel = user.platformRole === 'owner'
    ? 'Owner'
    : user.platformRole === 'partner'
      ? 'Partner'
      : userRole === 'admin'
        ? 'Admin'
        : 'Member';
  const roleClass = roleLabel === 'Owner'
    ? 'bg-yellow-100 text-yellow-700'
    : roleLabel === 'Partner'
      ? 'bg-purple-100 text-purple-700'
      : roleLabel === 'Admin'
        ? 'bg-blue-100 text-blue-700'
        : 'bg-gray-100 text-gray-600';
%>

<div class="max-w-5xl mx-auto space-y-6">
  <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3">
    <div>
      <h1 class="text-3xl font-bold text-gray-900">Profil Saya</h1>
      <p class="text-gray-500 mt-1">Kelola foto, identitas, keamanan, dan notifikasi akun kamu</p>
    </div>
    <a href="/" class="inline-flex items-center justify-center gap-2 px-4 py-2.5 bg-white border rounded-2xl text-sm font-semibold text-gray-700 hover:bg-gray-50 transition shadow-sm">
      <i class="fas fa-arrow-left text-gray-400"></i>
      Dashboard
    </a>
  </div>

  <section class="bg-white border rounded-3xl overflow-hidden shadow-sm">
    <div class="bg-gradient-to-r from-blue-600 via-indigo-600 to-sky-500 h-28"></div>
    <div class="p-5 sm:p-6">
      <div class="flex flex-col md:flex-row md:items-end gap-5 -mt-16">
        <div class="relative shrink-0">
          <div id="avatarPreview" class="w-28 h-28 sm:w-32 sm:h-32 rounded-[2rem] border-4 border-white bg-blue-600 shadow-lg overflow-hidden flex items-center justify-center text-white text-5xl font-bold">
            <% if (user.avatar) { %>
              <img src="<%= user.avatar %>" alt="Foto profil <%= user.name %>" class="w-full h-full object-cover">
            <% } else { %>
              <span><%= initial %></span>
            <% } %>
          </div>
          <button type="button" onclick="document.getElementById('avatarInput').click()"
            class="absolute -right-2 bottom-2 w-10 h-10 rounded-2xl bg-white border shadow-sm text-blue-600 hover:bg-blue-50 transition"
            title="Pilih foto profil">
            <i class="fas fa-camera"></i>
          </button>
        </div>

        <div class="min-w-0 flex-1 md:pb-2">
          <div class="flex flex-wrap items-center gap-2 mb-2">
            <h2 class="text-2xl font-bold text-gray-900 truncate"><%= user.name %></h2>
            <span class="text-xs px-2.5 py-1 rounded-full font-semibold <%= roleClass %>"><%= roleLabel %></span>
          </div>
          <p class="text-gray-500 truncate"><%= user.email %></p>
          <p class="text-xs text-gray-400 mt-1">
            Bergabung <%= new Date(user.createdAt).toLocaleDateString('id-ID', { day:'numeric', month:'long', year:'numeric' }) %>
          </p>
        </div>

        <div class="md:pb-2 flex flex-col sm:flex-row md:flex-col gap-2 md:w-52">
          <form action="/profile/avatar" method="POST" enctype="multipart/form-data" class="contents">
            <input id="avatarInput" type="file" name="avatar" accept="image/png,image/jpeg,image/webp,image/gif" class="hidden" onchange="previewAvatar(event)">
            <button type="submit" class="inline-flex items-center justify-center gap-2 px-4 py-3 bg-blue-600 hover:bg-blue-700 text-white rounded-2xl text-sm font-semibold transition">
              <i class="fas fa-upload"></i>
              Simpan Foto
            </button>
          </form>
          <% if (user.avatar) { %>
            <form action="/profile/avatar/delete" method="POST" onsubmit="return confirm('Hapus foto profil kamu?');">
              <button type="submit" class="w-full inline-flex items-center justify-center gap-2 px-4 py-3 bg-white border text-gray-700 rounded-2xl text-sm font-semibold hover:bg-gray-50 transition">
                <i class="fas fa-trash text-red-500"></i>
                Hapus Foto
              </button>
            </form>
          <% } %>
        </div>
      </div>

      <div class="mt-5 grid grid-cols-1 sm:grid-cols-3 gap-3">
        <div class="rounded-2xl border bg-gray-50 px-4 py-3">
          <div class="text-xs text-gray-400 font-semibold uppercase">Nama</div>
          <div class="text-sm font-semibold text-gray-800 truncate mt-0.5"><%= user.name %></div>
        </div>
        <div class="rounded-2xl border bg-gray-50 px-4 py-3">
          <div class="text-xs text-gray-400 font-semibold uppercase">Email</div>
          <div class="text-sm font-semibold text-gray-800 truncate mt-0.5"><%= user.email %></div>
        </div>
        <div class="rounded-2xl border bg-gray-50 px-4 py-3">
          <div class="text-xs text-gray-400 font-semibold uppercase">Telegram</div>
          <div class="text-sm font-semibold <%= user.telegramChatId ? 'text-emerald-600' : 'text-gray-500' %> truncate mt-0.5">
            <%= user.telegramChatId ? 'Aktif' : 'Belum terhubung' %>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <section class="bg-white border rounded-3xl p-5 sm:p-6 shadow-sm">
      <div class="mb-5">
        <h2 class="font-semibold text-lg flex items-center gap-2 text-gray-900">
          <i class="fas fa-user-edit text-blue-600"></i>
          Informasi Akun
        </h2>
        <p class="text-sm text-gray-500 mt-1">Nama dan email ini dipakai di workspace, task, chat, dan notifikasi.</p>
      </div>
      <form action="/profile/update" method="POST" class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Nama Lengkap</label>
          <input type="text" name="name" value="<%= user.name %>" required
            class="w-full border rounded-2xl px-5 py-3 focus:outline-none focus:border-blue-400 focus:ring-2 focus:ring-blue-100">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Email</label>
          <input type="email" name="email" value="<%= user.email %>" required
            class="w-full border rounded-2xl px-5 py-3 focus:outline-none focus:border-blue-400 focus:ring-2 focus:ring-blue-100">
        </div>
        <button type="submit" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white rounded-2xl font-semibold transition">
          <i class="fas fa-save"></i>
          Simpan Perubahan
        </button>
      </form>
    </section>

    <section class="bg-white border rounded-3xl p-5 sm:p-6 shadow-sm">
      <div class="mb-5">
        <h2 class="font-semibold text-lg flex items-center gap-2 text-gray-900">
          <i class="fas fa-lock text-blue-600"></i>
          Ganti Password
        </h2>
        <p class="text-sm text-gray-500 mt-1">Gunakan minimal 6 karakter untuk password baru.</p>
      </div>
      <form action="/profile/password" method="POST" class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Password Lama</label>
          <input type="password" name="currentPassword" required
            class="w-full border rounded-2xl px-5 py-3 focus:outline-none focus:border-blue-400 focus:ring-2 focus:ring-blue-100">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Password Baru</label>
          <input type="password" name="newPassword" required minlength="6"
            class="w-full border rounded-2xl px-5 py-3 focus:outline-none focus:border-blue-400 focus:ring-2 focus:ring-blue-100">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Konfirmasi Password Baru</label>
          <input type="password" name="confirmPassword" required minlength="6"
            class="w-full border rounded-2xl px-5 py-3 focus:outline-none focus:border-blue-400 focus:ring-2 focus:ring-blue-100">
        </div>
        <button type="submit" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-6 py-3 bg-gray-800 hover:bg-gray-900 text-white rounded-2xl font-semibold transition">
          <i class="fas fa-key"></i>
          Ganti Password
        </button>
      </form>
    </section>
  </div>

  <section class="bg-white border rounded-3xl p-5 sm:p-6 shadow-sm">
    <h2 class="font-semibold text-lg mb-2 flex items-center gap-2 text-gray-900">
      <i class="fab fa-telegram text-blue-500"></i>
      Reminder via Telegram
    </h2>

    <div id="telegram-connected-panel" class="<%= user.telegramChatId ? '' : 'hidden' %>">
      <!-- SUDAH TERHUBUNG -->
      <div class="flex items-center justify-between gap-4 mt-3 p-4 bg-emerald-50 border border-emerald-200 rounded-2xl">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 bg-emerald-100 rounded-full flex items-center justify-center">
            <i class="fas fa-check text-emerald-600"></i>
          </div>
          <div>
            <p class="text-sm font-semibold text-emerald-700">Terhubung ✅</p>
            <p class="text-xs text-emerald-600">Reminder deadline akan dikirim ke Telegram</p>
            <p class="text-[11px] text-emerald-500 mt-1 font-mono" id="telegram-chat-id-display"><%= user.telegramChatId ? 'Chat ID: ' + user.telegramChatId : '' %></p>
          </div>
        </div>
        <a href="/telegram/test" class="shrink-0 inline-flex items-center gap-1.5 px-4 py-2 bg-white border border-emerald-300 hover:bg-emerald-100 text-emerald-700 rounded-xl text-xs font-semibold transition">
          <i class="fas fa-paper-plane"></i> Test
        </a>
      </div>
    </div>

    <div id="telegram-disconnected-panel" class="<%= user.telegramChatId ? 'hidden' : '' %>">
    <% if (!user.telegramChatId) { %>
      <!-- BELUM TERHUBUNG -->
      <p class="text-sm text-gray-500 mb-4">
        Hubungkan Telegram biar reminder deadline otomatis masuk ke Telegram kamu.
      </p>
      <% if (telegramDeepLink) { %>
        <a href="<%= telegramDeepLink %>" target="_blank" onclick="startTelegramConnectCheck()"
          class="inline-flex items-center justify-center gap-2 px-5 py-3 bg-[#229ED9] hover:bg-[#1a8bc4] text-white rounded-2xl text-sm font-semibold transition">
          <i class="fab fa-telegram text-lg"></i>
          Hubungkan via Telegram
        </a>
        <button type="button" onclick="checkTelegramStatus(true)"
          class="ml-2 mt-2 sm:mt-0 inline-flex items-center justify-center gap-2 px-4 py-3 border rounded-2xl text-sm font-semibold text-gray-600 hover:bg-gray-50">
          <i class="fas fa-rotate"></i>
          Cek Status
        </button>
        <div id="telegram-waiting-panel" class="hidden mt-4 rounded-2xl border border-blue-100 bg-blue-50 px-4 py-3 text-sm text-blue-700">
          <div class="font-semibold">Menunggu Telegram...</div>
          <div class="text-xs mt-1" id="telegram-waiting-text">
            Setelah klik Start di Telegram, status di sini akan dicek otomatis.
          </div>
        </div>
        <p class="text-xs text-gray-400 mt-2">Klik → buka Telegram → klik Start → selesai.</p>
      <% } %>
    <% } %>
    </div>
  </section>

  <% if (user.platformRole === 'owner') { %>
    <section class="bg-red-50 border border-red-200 rounded-3xl p-5 sm:p-6">
      <h2 class="font-semibold text-lg mb-1 flex items-center gap-2 text-red-700">
        <i class="fas fa-exclamation-triangle text-red-600"></i>
        Reset Data Platform
      </h2>
      <p class="text-sm text-red-600 mb-5">Hapus semua brand, proyek, task, chat, notifikasi, dan user dummy. Akun yang dipertahankan akan tetap menjadi owner.</p>
      <form action="/admin/reset-data" method="POST" class="flex flex-col sm:flex-row gap-3"
        onsubmit="return confirm('Yakin reset semua data platform? Aksi ini tidak bisa dibatalkan.');">
        <input type="email" name="keepEmail" value="<%= user.email %>" required
          class="flex-1 border border-red-200 rounded-2xl px-5 py-3 text-sm focus:outline-none focus:border-red-400"
          aria-label="Email yang dipertahankan">
        <input type="text" name="confirmation" placeholder="Ketik RESET" required
          class="w-full sm:w-36 border border-red-200 rounded-2xl px-5 py-3 text-sm focus:outline-none focus:border-red-400"
          aria-label="Ketik RESET">
        <button type="submit" class="px-6 py-3 bg-red-600 text-white rounded-2xl text-sm font-semibold hover:bg-red-700 transition whitespace-nowrap">
          Reset Data
        </button>
      </form>
    </section>
  <% } %>
</div>

<script>
  function previewAvatar(event) {
    const file = event.target.files && event.target.files[0];
    if (!file) return;

    if (!file.type.startsWith('image/')) {
      alert('File harus berupa gambar.');
      event.target.value = '';
      return;
    }

    if (file.size > 3 * 1024 * 1024) {
      alert('Ukuran foto profil maksimal 3 MB.');
      event.target.value = '';
      return;
    }

    const preview = document.getElementById('avatarPreview');
    const reader = new FileReader();
    reader.onload = function(e) {
      preview.innerHTML = '<img src="' + e.target.result + '" alt="Preview foto profil" class="w-full h-full object-cover">';
    };
    reader.readAsDataURL(file);
  }

  let telegramPollTimer = null;
  let telegramPollAttempts = 0;

  function showTelegramWaiting(message) {
    const panel = document.getElementById('telegram-waiting-panel');
    const text = document.getElementById('telegram-waiting-text');
    if (panel) panel.classList.remove('hidden');
    if (text && message) text.textContent = message;
  }

  function showTelegramConnected(chatId) {
    document.getElementById('telegram-disconnected-panel')?.classList.add('hidden');
    document.getElementById('telegram-connected-panel')?.classList.remove('hidden');
    const display = document.getElementById('telegram-chat-id-display');
    if (display && chatId) display.textContent = 'Chat ID: ' + chatId;
  }

  async function checkTelegramStatus(reloadOnConnected = false) {
    try {
      const res = await fetch('/profile/telegram/status', {
        headers: { 'Accept': 'application/json' }
      });
      const data = await res.json();

      if (data.connected) {
        if (telegramPollTimer) clearInterval(telegramPollTimer);
        showTelegramConnected(data.telegramChatId);
        if (reloadOnConnected) window.location.reload();
        return true;
      }

      showTelegramWaiting('Belum terhubung. Pastikan klik Start dari tombol Hubungkan via Telegram, bukan mengetik /start manual.');
      return false;
    } catch (err) {
      showTelegramWaiting('Gagal cek status. Coba klik Cek Status lagi.');
      return false;
    }
  }

  function startTelegramConnectCheck() {
    showTelegramWaiting('Menunggu kamu klik Start di Telegram...');
    telegramPollAttempts = 0;
    if (telegramPollTimer) clearInterval(telegramPollTimer);

    telegramPollTimer = setInterval(async () => {
      telegramPollAttempts += 1;
      const connected = await checkTelegramStatus(false);
      if (connected || telegramPollAttempts >= 48) {
        clearInterval(telegramPollTimer);
        telegramPollTimer = null;
        if (!connected) {
          showTelegramWaiting('Belum terhubung. Kalau bot tidak membalas di Telegram, webhook bot kemungkinan belum aktif di server.');
        }
      }
    }, 2500);
  }
</script>

<%- include('partials/footer') %>
