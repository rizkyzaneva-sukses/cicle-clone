<%- include('partials/header', { title: 'Profil Saya' }) %>

<div class="max-w-2xl mx-auto">
  <div class="mb-8">
    <h1 class="text-3xl font-bold">Profil Saya</h1>
    <p class="text-gray-500 mt-1">Kelola informasi akun kamu</p>
  </div>

  <!-- Avatar + Info -->
  <div class="bg-white border rounded-3xl p-6 mb-5 shadow-sm flex items-center gap-5">
    <div class="w-20 h-20 bg-blue-600 rounded-3xl flex items-center justify-center text-white text-4xl font-bold shrink-0">
      <%= user.name.charAt(0).toUpperCase() %>
    </div>
    <div>
      <div class="text-xl font-bold"><%= user.name %></div>
      <div class="text-gray-500"><%= user.email %></div>
      <div class="mt-1">
        <% if (userRole === 'admin') { %>
          <span class="text-xs bg-blue-100 text-blue-700 px-2 py-0.5 rounded-full font-semibold">Admin</span>
        <% } else { %>
          <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded-full font-semibold">Member</span>
        <% } %>
      </div>
      <div class="text-xs text-gray-400 mt-1">Bergabung <%= new Date(user.createdAt).toLocaleDateString('id-ID', {day:'numeric',month:'long',year:'numeric'}) %></div>
    </div>
  </div>

  <!-- Edit Profile -->
  <div class="bg-white border rounded-3xl p-6 mb-5 shadow-sm">
    <h2 class="font-semibold text-lg mb-5 flex items-center gap-2">
      <i class="fas fa-user-edit text-blue-600"></i> Edit Profil
    </h2>
    <form action="/profile/update" method="POST" class="space-y-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1.5">Nama Lengkap</label>
        <input type="text" name="name" value="<%= user.name %>" required
          class="w-full border rounded-2xl px-5 py-3 focus:outline-none focus:border-blue-400 focus:ring-2 focus:ring-blue-100">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1.5">Email</label>
        <input type="email" name="email" value="<%= user.email %>" required
          class="w-full border rounded-2xl px-5 py-3 focus:outline-none focus:border-blue-400 focus:ring-2 focus:ring-blue-100">
      </div>
      <button type="submit"
        class="px-8 py-3 bg-blue-600 hover:bg-blue-700 text-white rounded-2xl font-medium transition">
        Simpan Perubahan
      </button>
    </form>
  </div>

  <!-- Change Password -->
  <div class="bg-white border rounded-3xl p-6 mb-5 shadow-sm">
    <h2 class="font-semibold text-lg mb-5 flex items-center gap-2">
      <i class="fas fa-lock text-blue-600"></i> Ganti Password
    </h2>
    <form action="/profile/password" method="POST" class="space-y-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1.5">Password Lama</label>
        <input type="password" name="currentPassword" required
          class="w-full border rounded-2xl px-5 py-3 focus:outline-none focus:border-blue-400 focus:ring-2 focus:ring-blue-100">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1.5">Password Baru</label>
        <input type="password" name="newPassword" required minlength="6"
          class="w-full border rounded-2xl px-5 py-3 focus:outline-none focus:border-blue-400 focus:ring-2 focus:ring-blue-100">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1.5">Konfirmasi Password Baru</label>
        <input type="password" name="confirmPassword" required minlength="6"
          class="w-full border rounded-2xl px-5 py-3 focus:outline-none focus:border-blue-400 focus:ring-2 focus:ring-blue-100">
      </div>
      <button type="submit"
        class="px-8 py-3 bg-gray-800 hover:bg-gray-900 text-white rounded-2xl font-medium transition">
        Ganti Password
      </button>
    </form>
  </div>

  <!-- Telegram Reminder -->
  <div class="bg-white border rounded-3xl p-6 mb-5 shadow-sm">
    <h2 class="font-semibold text-lg mb-2 flex items-center gap-2">
      <i class="fab fa-telegram text-blue-500"></i> Reminder via Telegram
    </h2>
    <p class="text-sm text-gray-500 mb-4">
      Isi Telegram Chat ID kamu biar reminder deadline (H-2, H-1, hari H, dan kalau lewat deadline) otomatis dikirim ke Telegram, bukan cuma notifikasi di app.
    </p>
    <ol class="text-xs text-gray-500 mb-4 space-y-1 list-decimal list-inside">
      <% if (telegramBotUsername) { %>
        <li>Buka <a href="https://t.me/<%= telegramBotUsername %>" target="_blank" class="text-blue-600 hover:underline">@<%= telegramBotUsername %></a> di Telegram, klik <b>Start</b>.</li>
      <% } else { %>
        <li>Buka bot Telegram yang dipakai tim ini, klik <b>Start</b> (tanya admin kalau belum tahu nama bot-nya).</li>
      <% } %>
      <li>Cari Chat ID kamu lewat bot seperti <a href="https://t.me/userinfobot" target="_blank" class="text-blue-600 hover:underline">@userinfobot</a> (kirim pesan apa saja, dia balas ID kamu).</li>
      <li>Tempel ID itu di kolom bawah ini.</li>
    </ol>
    
    <!-- Connect Telegram Button -->
    <% if (telegramDeepLink) { %>
      <div class="mb-4">
        <a href="<%= telegramDeepLink %>" target="_blank" 
          class="inline-flex items-center gap-2 px-4 py-2 bg-blue-500 hover:bg-blue-600 text-white rounded-xl text-sm font-medium transition">
          <i class="fab fa-telegram"></i> Hubungkan Telegram
        </a>
        <p class="text-xs text-gray-400 mt-1">Klik tombol di atas untuk langsung menghubungkan akun Telegram kamu</p>
      </div>
    <% } %>
    
    <form action="/profile/telegram" method="POST" class="flex flex-col sm:flex-row gap-3">
      <input type="text" name="telegramChatId" value="<%= user.telegramChatId || '' %>" placeholder="Contoh: 123456789"
        class="flex-1 border rounded-2xl px-5 py-3 focus:outline-none focus:border-blue-400 focus:ring-2 focus:ring-blue-100">
      <button type="submit"
        class="px-8 py-3 bg-blue-600 hover:bg-blue-700 text-white rounded-2xl font-medium transition whitespace-nowrap">
        Simpan
      </button>
    </form>
    <% if (user.telegramChatId) { %>
      <div class="flex items-center gap-3 mt-3">
        <p class="text-xs text-emerald-600"><i class="fas fa-check-circle mr-1"></i>Telegram Chat ID sudah aktif.</p>
        <a href="/telegram/test" class="text-xs text-blue-600 hover:underline">
          <i class="fas fa-paper-plane mr-1"></i>Kirim Pesan Test
        </a>
      </div>
    <% } %>
  </div>

  <% if (user.platformRole === 'owner') { %>
  <!-- Reset Data Platform (Owner Only) -->
  <div class="bg-red-50 border border-red-200 rounded-3xl p-6">
    <h2 class="font-semibold text-lg mb-1 flex items-center gap-2 text-red-700">
      <i class="fas fa-exclamation-triangle text-red-600"></i> Reset Data Platform
    </h2>
    <p class="text-sm text-red-600 mb-5">Hapus semua brand, proyek, task, chat, notifikasi, dan user dummy. Akun yang dipertahankan akan tetap menjadi owner.</p>
    <form action="/admin/reset-data" method="POST" class="flex flex-col sm:flex-row gap-3"
      onsubmit="return confirm('Yakin reset semua data platform? Aksi ini tidak bisa dibatalkan.');">
      <input type="email" name="keepEmail" value="<%= user.email %>" required
        class="flex-1 border border-red-200 rounded-2xl px-5 py-3 text-sm focus:outline-none focus:border-red-400"
        aria-label="Email yang dipertahankan">
      <input type="text" name="confirmation" placeholder="Ketik RESET" required
        class="w-full sm:w-36 border border-red-200 rounded-2xl px-5 py-3 text-sm focus:outline-none focus:border-red-400"
        aria-label="Ketik RESET">
      <button type="submit" class="px-6 py-3 bg-red-600 text-white rounded-2xl text-sm font-semibold hover:bg-red-700 transition whitespace-nowrap">
        Reset Data
      </button>
    </form>
  </div>
  <% } %>
</div>

<%- include('partials/footer') %>
