<%- include('partials/header', { title: 'Anggota Tim' }) %>

<div class="mb-8 flex items-center justify-between flex-wrap gap-4">
  <div>
    <h1 class="text-3xl font-bold text-gray-900">Anggota Tim</h1>
    <p class="text-gray-500 mt-1">Brand: <strong><%= company.name %></strong></p>
  </div>
  <div class="flex items-center gap-3">
    <div class="bg-blue-50 border border-blue-100 rounded-2xl px-5 py-3 text-center">
      <div class="text-2xl font-bold text-blue-600"><%= members.length %></div>
      <div class="text-xs text-blue-500">Anggota</div>
    </div>
    <% if (partners && partners.length > 0) { %>
    <div class="bg-purple-50 border border-purple-100 rounded-2xl px-5 py-3 text-center">
      <div class="text-2xl font-bold text-purple-600"><%= partners.length %></div>
      <div class="text-xs text-purple-500">Partner</div>
    </div>
    <% } %>
  </div>
</div>

<!-- Invite Form (admin/partner/owner) -->
<% if (canManage) { %>
<div class="bg-white border rounded-3xl p-6 mb-6 shadow-sm">
  <h2 class="font-semibold text-lg mb-4 flex items-center gap-2">
    <i class="fas fa-user-plus text-blue-600"></i> Undang Anggota Baru
  </h2>
  <form action="/members/invite" method="POST" class="flex gap-3 flex-wrap">
    <input type="hidden" name="companyId" value="<%= company.id %>">
    <div class="flex-1 min-w-48">
      <input type="email" name="email" required
        placeholder="Email anggota yang sudah terdaftar..."
        class="w-full border rounded-2xl px-5 py-3 focus:outline-none focus:border-blue-400 focus:ring-2 focus:ring-blue-100">
    </div>
    <button type="submit"
      class="px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white rounded-2xl font-medium transition flex items-center gap-2 shrink-0">
      <i class="fas fa-paper-plane"></i> Undang
    </button>
  </form>
  <p class="text-xs text-gray-400 mt-2">
    <i class="fas fa-info-circle"></i> Anggota harus sudah punya akun Cicle sebelum bisa diundang
  </p>
</div>
<% } %>

<!-- Partner List (jika ada) -->
<% if (partners && partners.length > 0) { %>
<div class="bg-white border rounded-3xl shadow-sm overflow-hidden mb-6">
  <div class="px-6 py-4 border-b bg-purple-50 flex items-center gap-2">
    <i class="fas fa-user-tie text-purple-600"></i>
    <span class="font-semibold text-gray-700">Partner Brand Ini</span>
  </div>
  <div class="divide-y">
    <% partners.forEach(pa => { %>
    <div class="px-6 py-4 flex items-center gap-4 hover:bg-gray-50 transition">
      <div class="w-11 h-11 rounded-full bg-purple-600 flex items-center justify-center text-white font-bold text-lg shrink-0">
        <%= pa.user.name.charAt(0).toUpperCase() %>
      </div>
      <div class="flex-1 min-w-0">
        <div class="font-semibold text-gray-900"><%= pa.user.name %></div>
        <div class="text-sm text-gray-500"><%= pa.user.email %></div>
      </div>
      <span class="px-3 py-1 bg-purple-100 text-purple-700 text-xs font-semibold rounded-full">
        <i class="fas fa-user-tie mr-1"></i>Partner
      </span>
      <div class="text-xs text-gray-400 shrink-0 text-right">
        <div>Assigned</div>
        <div><%= new Date(pa.assignedAt).toLocaleDateString('id-ID', {day:'numeric',month:'short',year:'numeric'}) %></div>
      </div>
      <% if (userRole === 'owner') { %>
      <form action="/members/partners/<%= pa.userId %>/remove" method="POST"
        onsubmit="return confirm('Cabut akses Partner <%= pa.user.name %> dari brand <%= company.name %>?')">
        <input type="hidden" name="companyId" value="<%= company.id %>">
        <button type="submit" class="px-3 py-1.5 border border-red-200 text-red-500 hover:bg-red-50 rounded-xl text-xs font-medium transition">
          <i class="fas fa-user-slash mr-1"></i> Cabut
        </button>
      </form>
      <% } %>
    </div>
    <% }) %>
  </div>
</div>
<% } %>

<!-- Members List -->
<div class="bg-white border rounded-3xl shadow-sm overflow-hidden">
  <div class="px-6 py-4 border-b bg-gray-50">
    <span class="font-semibold text-gray-700">Daftar Anggota</span>
  </div>

  <div class="divide-y">
    <% if (members.length === 0) { %>
      <div class="px-6 py-12 text-center text-gray-400">
        <i class="fas fa-users text-4xl mb-3 block"></i>
        Belum ada anggota di brand ini
      </div>
    <% } %>
    <% members.forEach(function(membership) { %>
    <div class="px-6 py-4 flex items-center gap-4 hover:bg-gray-50 transition flex-wrap">

      <div class="w-11 h-11 rounded-full bg-blue-600 flex items-center justify-center text-white font-bold text-lg shrink-0">
        <%= membership.user.name.charAt(0).toUpperCase() %>
      </div>

      <div class="flex-1 min-w-0">
        <div class="flex items-center gap-2 flex-wrap">
          <span class="font-semibold text-gray-900"><%= membership.user.name %></span>
          <% if (membership.user.id === currentUserId) { %>
            <span class="text-xs bg-gray-100 text-gray-500 px-2 py-0.5 rounded-full">Kamu</span>
          <% } %>
        </div>
        <div class="text-sm text-gray-500"><%= membership.user.email %></div>
      </div>

      <div class="shrink-0">
        <% if (membership.role === 'admin') { %>
          <span class="px-3 py-1 bg-blue-100 text-blue-700 text-xs font-semibold rounded-full">
            <i class="fas fa-shield-alt mr-1"></i>Admin
          </span>
        <% } else { %>
          <span class="px-3 py-1 bg-gray-100 text-gray-600 text-xs font-semibold rounded-full">
            <i class="fas fa-user mr-1"></i>Member
          </span>
        <% } %>
      </div>

      <div class="text-xs text-gray-400 shrink-0 text-right hidden sm:block">
        <div>Bergabung</div>
        <div><%= new Date(membership.joinedAt).toLocaleDateString('id-ID', {day:'numeric',month:'short',year:'numeric'}) %></div>
      </div>

      <% if (canManage && membership.user.id !== currentUserId) { %>
      <div class="flex items-center gap-2 shrink-0">
        <form action="/members/<%= membership.id %>/role" method="POST">
          <input type="hidden" name="companyId" value="<%= company.id %>">
          <input type="hidden" name="role" value="<%= membership.role === 'admin' ? 'member' : 'admin' %>">
          <button type="submit" class="text-xs px-3 py-1.5 border rounded-xl hover:bg-gray-50 transition text-gray-600">
            <i class="fas fa-exchange-alt mr-1"></i>
            <%= membership.role === 'admin' ? 'Jadikan Member' : 'Jadikan Admin' %>
          </button>
        </form>
        <form action="/members/<%= membership.id %>/remove" method="POST"
          onsubmit="return confirm('Hapus <%= membership.user.name %> dari brand ini?')">
          <input type="hidden" name="companyId" value="<%= company.id %>">
          <button type="submit" class="text-xs px-3 py-1.5 border border-red-200 text-red-500 hover:bg-red-50 rounded-xl transition">
            <i class="fas fa-trash"></i>
          </button>
        </form>
      </div>
      <% } %>
    </div>
    <% }) %>
  </div>
</div>

<%- include('partials/footer') %>
