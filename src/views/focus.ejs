<%- include('partials/header', { title: 'Focus Timer' }) %>

<div class="max-w-2xl mx-auto">
  <a href="/" class="text-blue-600 hover:underline text-sm flex items-center gap-1 mb-6">
    <i class="fas fa-arrow-left"></i> Kembali ke Dashboard
  </a>

  <div class="bg-white rounded-3xl border shadow-sm p-6 sm:p-8">
    <div class="text-center mb-8">
      <h1 class="text-3xl font-bold text-gray-900 mb-2">Focus Timer</h1>
      <p class="text-gray-500 text-sm">Pomodoro timer dengan mode 25/5 dan 50/10</p>
    </div>

    <!-- Stats Cards -->
    <div class="grid grid-cols-2 gap-4 mb-8">
      <div class="bg-blue-50 rounded-2xl p-4 text-center">
        <div class="text-3xl font-bold text-blue-600" id="today-sessions"><%= todaySessions %></div>
        <div class="text-xs text-blue-500 font-medium mt-1">Sesi Hari Ini</div>
      </div>
      <div class="bg-emerald-50 rounded-2xl p-4 text-center">
        <div class="text-3xl font-bold text-emerald-600" id="today-minutes"><%= totalFocusMinutes %></div>
        <div class="text-xs text-emerald-500 font-medium mt-1">Menit Fokus</div>
      </div>
    </div>

    <!-- Mode selector -->
    <div class="mb-6">
      <label class="block text-sm font-medium text-gray-700 mb-2">Mode Timer:</label>
      <div class="grid grid-cols-2 gap-3">
        <button type="button" onclick="setPresetMode('classic')" id="mode-classic"
          class="px-4 py-3 rounded-2xl text-sm font-semibold transition bg-blue-600 text-white">
          🍅 Pomodoro Klasik (25/5)
        </button>
        <button type="button" onclick="setPresetMode('extended')" id="mode-extended"
          class="px-4 py-3 rounded-2xl text-sm font-semibold transition bg-gray-100 text-gray-700 hover:bg-gray-200">
          🎯 Fokus Panjang (50/10)
        </button>
      </div>
    </div>

    <!-- Task selector -->
    <div class="mb-6">
      <label class="block text-sm font-medium text-gray-700 mb-2">Fokus pada tugas:</label>
      <select id="task-selector" class="w-full border rounded-2xl px-5 py-3 text-sm focus:outline-none focus:border-blue-400">
        <option value="">Tanpa tugas spesifik</option>
        <% tasks.forEach(task => { %>
          <option value="<%= task.id %>" data-title="<%= task.title %>">
            [<%= task.project.name %>] <%= task.title %>
          </option>
        <% }) %>
      </select>
    </div>

    <!-- Duration presets -->
    <div class="mb-6">
      <div class="flex items-center justify-between gap-3 mb-3">
        <label class="block text-sm font-medium text-gray-700">Durasi fokus:</label>
        <span id="cycle-status" class="text-xs text-gray-500 bg-gray-100 px-3 py-1.5 rounded-full">Pilih mode di atas</span>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-2">
        <button type="button" onclick="setWorkDuration(25)" id="preset-25"
          class="px-4 py-3 rounded-2xl text-sm font-semibold transition bg-blue-600 text-white">
          25 Menit
        </button>
        <button type="button" onclick="setWorkDuration(30)" id="preset-30"
          class="px-4 py-3 rounded-2xl text-sm font-semibold transition bg-gray-100 text-gray-700 hover:bg-gray-200">
          30 Menit
        </button>
        <button type="button" onclick="setWorkDuration(50)" id="preset-50"
          class="px-4 py-3 rounded-2xl text-sm font-semibold transition bg-gray-100 text-gray-700 hover:bg-gray-200">
          50 Menit
        </button>
        <button type="button" onclick="setWorkDuration(60)" id="preset-60"
          class="px-4 py-3 rounded-2xl text-sm font-semibold transition bg-gray-100 text-gray-700 hover:bg-gray-200">
          60 Menit
        </button>
      </div>
    </div>

    <!-- Timer type buttons -->
    <div class="flex justify-center gap-2 mb-8 flex-wrap">
      <button type="button" onclick="setTimerType('work')" id="type-work"
        class="px-4 py-2 rounded-xl text-sm font-medium transition bg-blue-600 text-white">
        Kerja (25m)
      </button>
      <button type="button" onclick="setTimerType('shortBreak')" id="type-shortBreak"
        class="px-4 py-2 rounded-xl text-sm font-medium transition bg-gray-100 text-gray-700 hover:bg-gray-200">
        Istirahat (5m)
      </button>
      <button type="button" onclick="setTimerType('longBreak')" id="type-longBreak"
        class="px-4 py-2 rounded-xl text-sm font-medium transition bg-gray-100 text-gray-400 cursor-not-allowed">
        Panjang (15m)
      </button>
    </div>

    <!-- Timer display -->
    <div class="flex justify-center mb-8">
      <div class="relative w-64 h-64">
        <svg class="w-full h-full transform -rotate-90" viewBox="0 0 100 100">
          <circle cx="50" cy="50" r="45" fill="none" stroke="#e5e7eb" stroke-width="6" />
          <circle cx="50" cy="50" r="45" fill="none" stroke="#3b82f6" stroke-width="6"
            stroke-dasharray="282.74" stroke-dashoffset="0" stroke-linecap="round"
            id="timer-progress" class="transition-all duration-1000" />
        </svg>
        <div class="absolute inset-0 flex flex-col items-center justify-center">
          <div class="text-5xl font-bold text-gray-900 font-mono" id="timer-display">25:00</div>
          <div class="text-sm text-gray-500 mt-1" id="timer-label">Fokus</div>
          <div class="text-xs text-gray-400 mt-2" id="timer-sub-label">Mode Pomodoro Klasik</div>
        </div>
      </div>
    </div>

    <!-- Controls -->
    <div class="flex justify-center gap-3 mb-6">
      <button onclick="startTimer()" id="btn-start"
        class="px-8 py-3 bg-blue-600 text-white rounded-2xl font-medium hover:bg-blue-700 transition flex items-center gap-2">
        <i class="fas fa-play"></i> Mulai
      </button>
      <button onclick="pauseTimer()" id="btn-pause"
        class="hidden px-8 py-3 bg-amber-500 text-white rounded-2xl font-medium hover:bg-amber-600 transition flex items-center gap-2">
        <i class="fas fa-pause"></i> Jeda
      </button>
      <button onclick="resetTimer()"
        class="px-8 py-3 border rounded-2xl font-medium text-gray-600 hover:bg-gray-50 transition flex items-center gap-2">
        <i class="fas fa-redo"></i> Reset
      </button>
    </div>

    <!-- Focus Mode toggle -->
    <div class="text-center">
      <label class="inline-flex items-center gap-2 text-sm text-gray-600 cursor-pointer">
        <input type="checkbox" id="focus-mode-toggle" onchange="toggleFocusMode()" class="accent-blue-600">
        <span>🔔 Focus Mode (sembunyikan notifikasi & chat)</span>
      </label>
    </div>
  </div>

  <!-- Weekly Stats -->
  <% if (typeof weeklyStats !== 'undefined') { %>
  <div class="bg-white rounded-3xl border shadow-sm p-6 sm:p-8 mt-6">
    <h2 class="font-bold text-lg text-gray-900 mb-4 flex items-center gap-2">
      <i class="fas fa-chart-bar text-blue-500"></i> Statistik Mingguan
    </h2>
    <div class="grid grid-cols-2 gap-4 mb-6">
      <div class="text-center">
        <div class="text-2xl font-bold text-blue-600"><%= weeklyStats.totalSessions %></div>
        <div class="text-xs text-gray-500">Total Sesi</div>
      </div>
      <div class="text-center">
        <div class="text-2xl font-bold text-emerald-600"><%= weeklyStats.totalMinutes %></div>
        <div class="text-xs text-gray-500">Total Menit</div>
      </div>
    </div>
    <!-- Simple bar chart -->
    <div class="flex items-end gap-2 h-32">
      <% const maxMinutes = Math.max(...Object.values(weeklyStats.byDay).map(d => d.minutes), 1); %>
      <% Object.entries(weeklyStats.byDay).forEach(([day, data]) => { %>
        <div class="flex-1 flex flex-col items-center gap-1">
          <div class="w-full bg-blue-500 rounded-t-lg transition-all" style="height: <%= Math.max(data.minutes / maxMinutes * 100, 4) %>%"></div>
          <span class="text-[10px] text-gray-400"><%= day %></span>
          <span class="text-[10px] text-gray-500 font-semibold"><%= data.minutes %>m</span>
        </div>
      <% }) %>
    </div>
  </div>
  <% } %>
</div>

<script>
  const TIMER_PRESETS = {
    classic: { work: 25, shortBreak: 5, longBreak: 15, label: 'Pomodoro Klasik' },
    extended: { work: 50, shortBreak: 10, longBreak: 20, label: 'Fokus Panjang' }
  };

  const STORAGE_KEY = 'focusTimerConfigV3';
  const TIMER_LABELS = { work: 'Fokus', shortBreak: 'Istirahat', longBreak: 'Istirahat Panjang' };
  const TIMER_COLORS = { work: '#3b82f6', shortBreak: '#10b981', longBreak: '#8b5cf6' };
  const circumference = 2 * Math.PI * 45;

  let state = loadState();
  let currentMode = state.mode || 'classic';
  let currentType = 'work';
  let totalSeconds = 0;
  let remainingSeconds = 0;
  let timerInterval = null;
  let isRunning = false;
  let focusModeActive = false;

  function loadState() {
    try {
      const saved = JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}');
      return {
        mode: ['classic', 'extended'].includes(saved.mode) ? saved.mode : 'classic',
        completedSinceLongBreak: Number.isInteger(saved.completedSinceLongBreak) ? saved.completedSinceLongBreak : 0
      };
    } catch (_) {
      return { mode: 'classic', completedSinceLongBreak: 0 };
    }
  }

  function saveState() {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
  }

  function getPreset() {
    return TIMER_PRESETS[currentMode];
  }

  function getShortBreakMinutes() {
    return getPreset().shortBreak;
  }

  function getDurationForType(type) {
    const preset = getPreset();
    if (type === 'work') return preset.work * 60;
    if (type === 'shortBreak') return preset.shortBreak * 60;
    return preset.longBreak * 60;
  }

  function canUseLongBreak() {
    return state.completedSinceLongBreak >= 3;
  }

  function setPresetMode(mode) {
    if (!TIMER_PRESETS[mode]) return;
    if (isRunning) {
      if (!confirm('Timer sedang berjalan. Yakin ingin mengganti mode?')) return;
      clearInterval(timerInterval);
      isRunning = false;
    }
    currentMode = mode;
    state.mode = mode;
    saveState();
    currentType = 'work';
    totalSeconds = getDurationForType('work');
    remainingSeconds = totalSeconds;
    updateDisplay();
    syncAllUi();
    resetButtons();
  }

  function updatePresetButtons() {
    ['classic', 'extended'].forEach(mode => {
      const btn = document.getElementById(`mode-${mode}`);
      if (!btn) return;
      btn.className = mode === currentMode
        ? 'px-4 py-3 rounded-2xl text-sm font-semibold transition bg-blue-600 text-white'
        : 'px-4 py-3 rounded-2xl text-sm font-semibold transition bg-gray-100 text-gray-700 hover:bg-gray-200';
    });

    // Update duration preset visibility
    const preset = getPreset();
    [25, 30, 50, 60].forEach(min => {
      const btn = document.getElementById(`preset-${min}`);
      if (!btn) return;
      btn.className = min === preset.work
        ? 'px-4 py-3 rounded-2xl text-sm font-semibold transition bg-blue-600 text-white'
        : 'px-4 py-3 rounded-2xl text-sm font-semibold transition bg-gray-100 text-gray-700 hover:bg-gray-200';
    });
  }

  function updateTypeButtons() {
    const preset = getPreset();
    const labels = {
      work: `Kerja (${preset.work}m)`,
      shortBreak: `Istirahat (${preset.shortBreak}m)`,
      longBreak: `Panjang (${preset.longBreak}m)`
    };

    document.getElementById('type-work').textContent = labels.work;
    document.getElementById('type-shortBreak').textContent = labels.shortBreak;
    document.getElementById('type-longBreak').textContent = labels.longBreak;

    ['work', 'shortBreak', 'longBreak'].forEach(type => {
      const btn = document.getElementById('type-' + type);
      if (!btn) return;
      if (type === 'longBreak' && !canUseLongBreak()) {
        btn.className = 'px-4 py-2 rounded-xl text-sm font-medium transition bg-gray-100 text-gray-400 cursor-not-allowed';
        btn.disabled = true;
        return;
      }
      btn.disabled = false;
      if (type === currentType) {
        btn.className = 'px-4 py-2 rounded-xl text-sm font-medium transition text-white';
        btn.style.backgroundColor = TIMER_COLORS[type];
      } else {
        btn.className = 'px-4 py-2 rounded-xl text-sm font-medium transition bg-gray-100 text-gray-700 hover:bg-gray-200';
        btn.style.backgroundColor = '';
      }
    });
  }

  function updateCycleStatus() {
    const el = document.getElementById('cycle-status');
    if (!el) return;
    if (canUseLongBreak()) {
      el.textContent = 'Istirahat panjang sudah terbuka';
    } else {
      el.textContent = `${state.completedSinceLongBreak}/3 sesi fokus menuju istirahat panjang`;
    }
  }

  function updateHelperText() {
    const sub = document.getElementById('timer-sub-label');
    if (!sub) return;
    sub.textContent = `Mode ${getPreset().label}`;
  }

  function syncAllUi() {
    updatePresetButtons();
    updateTypeButtons();
    updateCycleStatus();
    updateHelperText();
    document.getElementById('timer-progress').style.stroke = TIMER_COLORS[currentType];
  }

  function setWorkDuration(minutes) {
    const preset = getPreset();
    if (minutes !== preset.work) {
      // Switch to appropriate mode
      if (minutes <= 30 && currentMode !== 'classic') setPresetMode('classic');
      else if (minutes >= 50 && currentMode !== 'extended') setPresetMode('extended');
    }
    if (isRunning) {
      if (!confirm('Timer sedang berjalan. Yakin ingin mengganti durasi?')) return;
      clearInterval(timerInterval);
      isRunning = false;
    }
    currentType = 'work';
    totalSeconds = minutes * 60;
    remainingSeconds = totalSeconds;
    updateDisplay();
    syncAllUi();
    resetButtons();
  }

  function setTimerType(type) {
    if (type === 'longBreak' && !canUseLongBreak()) {
      alert('Istirahat panjang baru bisa dipakai setelah 3 sesi fokus selesai.');
      return;
    }
    if (isRunning) {
      if (!confirm('Timer sedang berjalan. Yakin ingin mengganti mode?')) return;
      clearInterval(timerInterval);
      isRunning = false;
    }
    currentType = type;
    totalSeconds = getDurationForType(type);
    remainingSeconds = totalSeconds;
    updateDisplay();
    syncAllUi();
    resetButtons();
  }

  function resetButtons() {
    document.getElementById('btn-start').classList.remove('hidden');
    document.getElementById('btn-start').classList.add('flex');
    document.getElementById('btn-pause').classList.add('hidden');
    document.getElementById('btn-pause').classList.remove('flex');
  }

  function updateDisplay() {
    const mins = Math.floor(remainingSeconds / 60);
    const secs = remainingSeconds % 60;
    document.getElementById('timer-display').textContent =
      String(mins).padStart(2, '0') + ':' + String(secs).padStart(2, '0');
    const progress = remainingSeconds / totalSeconds;
    const offset = circumference * (1 - progress);
    document.getElementById('timer-progress').style.strokeDashoffset = offset;
    document.getElementById('timer-label').textContent = TIMER_LABELS[currentType];
    document.title = `${String(mins).padStart(2, '0')}:${String(secs).padStart(2, '0')} - Focus Timer`;
  }

  function startTimer() {
    if (isRunning) return;
    isRunning = true;
    document.getElementById('btn-start').classList.add('hidden');
    document.getElementById('btn-pause').classList.remove('hidden');
    document.getElementById('btn-pause').classList.add('flex');

    timerInterval = setInterval(() => {
      remainingSeconds--;
      if (remainingSeconds <= 0) {
        clearInterval(timerInterval);
        isRunning = false;
        remainingSeconds = 0;
        updateDisplay();
        timerComplete();
        return;
      }
      updateDisplay();
    }, 1000);
  }

  function pauseTimer() {
    if (!isRunning) return;
    clearInterval(timerInterval);
    isRunning = false;
    document.getElementById('btn-pause').classList.add('hidden');
    document.getElementById('btn-start').classList.remove('hidden');
    document.getElementById('btn-start').classList.add('flex');
  }

  function resetTimer() {
    clearInterval(timerInterval);
    isRunning = false;
    remainingSeconds = totalSeconds;
    updateDisplay();
    resetButtons();
  }

  function timerComplete() {
    playNotificationSound();

    if (currentType === 'work') {
      const taskId = document.getElementById('task-selector').value;
      const minutes = Math.round(totalSeconds / 60);
      state.completedSinceLongBreak += 1;
      saveState();
      syncAllUi();

      fetch('/focus/log', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ taskId, minutes, type: currentType })
      }).then(() => {
        const sessionsEl = document.getElementById('today-sessions');
        const minutesEl = document.getElementById('today-minutes');
        sessionsEl.textContent = parseInt(sessionsEl.textContent, 10) + 1;
        minutesEl.textContent = parseInt(minutesEl.textContent, 10) + minutes;
      }).catch(console.error);
    } else if (currentType === 'longBreak') {
      state.completedSinceLongBreak = 0;
      saveState();
      syncAllUi();
    }

    if (Notification.permission === 'granted') {
      new Notification('Focus Timer Selesai!', {
        body: currentType === 'work' ? 'Waktu istirahat.' : 'Waktu fokus lagi.',
        icon: '/favicon.ico'
      });
    }

    alert(`${TIMER_LABELS[currentType]} selesai!`);

    if (currentType === 'work') {
      if (canUseLongBreak()) {
        setTimerType('longBreak');
      } else {
        setTimerType('shortBreak');
      }
    } else {
      setTimerType('work');
    }
  }

  function playNotificationSound() {
    try {
      const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
      [0, 0.2].forEach((delay) => {
        const oscillator = audioCtx.createOscillator();
        const gainNode = audioCtx.createGain();
        oscillator.connect(gainNode);
        gainNode.connect(audioCtx.destination);
        oscillator.type = 'sine';
        oscillator.frequency.value = delay === 0 ? 523.25 : 659.25;
        gainNode.gain.setValueAtTime(0.3, audioCtx.currentTime + delay);
        gainNode.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + delay + 0.5);
        oscillator.start(audioCtx.currentTime + delay);
        oscillator.stop(audioCtx.currentTime + delay + 0.5);
      });
    } catch (e) {
      console.log('Audio not available');
    }
  }

  function toggleFocusMode() {
    focusModeActive = document.getElementById('focus-mode-toggle').checked;
    // Hide notification bell and chat when in focus mode
    const notifWrapper = document.getElementById('notif-wrapper');
    if (notifWrapper) notifWrapper.style.display = focusModeActive ? 'none' : '';
    // Store preference
    localStorage.setItem('focusMode', focusModeActive ? '1' : '0');
  }

  if ('Notification' in window && Notification.permission === 'default') {
    Notification.requestPermission();
  }

  // Initialize
  totalSeconds = getDurationForType('work');
  remainingSeconds = totalSeconds;
  syncAllUi();
  updateDisplay();
</script>

<%- include('partials/footer') %>
