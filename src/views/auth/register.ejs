<%- include('../partials/header', { title: 'Daftar - Maulana Corp' }) %>

<div class="max-w-md mx-auto mt-12">
  <div class="text-center mb-8">
    <div class="inline-flex items-center justify-center w-16 h-16 bg-blue-600 rounded-3xl mb-4">
      <i class="fas fa-tasks text-white text-4xl"></i>
    </div>
    <h1 class="text-3xl font-bold">Buat Akun Maulana Corp</h1>
    <p class="text-gray-600 mt-2">
      <%= isFirstUser ? 'Buat akun Owner dan workspace pertama' : 'Buat akun, lalu minta Owner mengundang kamu ke workspace' %>
    </p>
  </div>

  <div class="bg-white border rounded-3xl p-8 shadow-sm">
    <% if (error) { %>
      <div class="mb-4 p-3 bg-red-100 text-red-700 rounded-2xl text-sm"><%= error %></div>
    <% } %>

    <form method="POST" action="/auth/register">
      <div class="space-y-5">
        <div>
          <label class="text-sm font-medium">Nama Lengkap</label>
          <input type="text" name="name" required class="mt-1.5 w-full border px-5 py-3.5 rounded-2xl">
        </div>
        <div>
          <label class="text-sm font-medium">Email</label>
          <input type="email" name="email" required class="mt-1.5 w-full border px-5 py-3.5 rounded-2xl">
        </div>
        <div>
          <label class="text-sm font-medium">Password</label>
          <input type="password" name="password" required class="mt-1.5 w-full border px-5 py-3.5 rounded-2xl">
        </div>
        <% if (isFirstUser) { %>
          <div>
            <label class="text-sm font-medium">Nama Workspace Pertama</label>
            <input type="text" name="companyName" required placeholder="PT. Contoh Indonesia" class="mt-1.5 w-full border px-5 py-3.5 rounded-2xl">
          </div>
        <% } else { %>
          <div class="bg-blue-50 border border-blue-100 text-blue-700 rounded-2xl px-4 py-3 text-sm">
            Workspace hanya bisa dibuat oleh Owner. Setelah daftar, minta Owner/Admin mengundang email kamu ke workspace.
          </div>
        <% } %>
      </div>

      <button type="submit" class="mt-8 w-full bg-blue-600 hover:bg-blue-700 text-white py-4 rounded-2xl font-semibold text-lg transition">
        <%= isFirstUser ? 'Daftar & Buat Workspace' : 'Daftar Akun' %>
      </button>
    </form>

    <p class="text-center mt-6 text-sm text-gray-600">
      Sudah punya akun? <a href="/auth/login" class="text-blue-600 font-medium">Masuk di sini</a>
    </p>
  </div>
</div>
<%- include('../partials/footer') %>
