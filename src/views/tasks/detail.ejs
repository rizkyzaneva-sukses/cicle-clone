<%- include('../partials/header', { title: task.title }) %>

<!-- Breadcrumb -->
<div class="flex items-center gap-1.5 sm:gap-2 text-xs sm:text-sm text-gray-500 mb-4 sm:mb-6 overflow-x-auto">
  <a href="/" class="hover:text-blue-600 whitespace-nowrap">Dashboard</a>
  <i class="fas fa-chevron-right text-xs"></i>
  <a href="/projects/<%= task.projectId %>" class="hover:text-blue-600"><%= task.project.name %></a>
  <i class="fas fa-chevron-right text-xs"></i>
  <span class="text-gray-800 font-medium truncate"><%= task.title %></span>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-4 sm:gap-6">

  <!-- LEFT: Task Info + Edit -->
  <div class="lg:col-span-2 space-y-5">

    <!-- Task Header -->
    <div class="bg-white border rounded-2xl sm:rounded-3xl p-4 sm:p-6 shadow-sm">
      <div class="flex items-start justify-between gap-4 mb-4">
        <div class="flex-1">
          <!-- Status + Priority badges -->
          <div class="flex items-center gap-2 mb-3 flex-wrap">
            <% const statusMap = { TODO: ['bg-gray-100 text-gray-700', 'To Do'], IN_PROGRESS: ['bg-amber-100 text-amber-700', 'In Progress'], DONE: ['bg-emerald-100 text-emerald-700', 'Done'] } %>
            <span class="px-3 py-1 text-xs font-semibold rounded-full <%= statusMap[task.status]?.[0] || 'bg-gray-100 text-gray-700' %>">
              <%= statusMap[task.status]?.[1] || task.status %>
            </span>
            <% const prioMap = { NONE: ['bg-gray-100 text-gray-500', 'Tanpa Prioritas'], LOW: ['bg-blue-100 text-blue-700', 'Low'], MEDIUM: ['bg-yellow-100 text-yellow-700', 'Medium'], HIGH: ['bg-orange-100 text-orange-700', 'High'], URGENT: ['bg-red-100 text-red-700', 'Urgent'] } %>
            <% if (task.priority && task.priority !== 'NONE') { %>
            <span class="px-3 py-1 text-xs font-semibold rounded-full <%= prioMap[task.priority]?.[0] %>">
              <i class="fas fa-flag mr-1"></i><%= prioMap[task.priority]?.[1] %>
            </span>
            <% } %>
            <% task.labels.forEach(tl => { %>
              <span class="px-3 py-1 text-xs font-semibold rounded-full text-white" style="background:<%= tl.label.color %>">
                <%= tl.label.name %>
              </span>
            <% }) %>
          </div>
          <h1 class="text-2xl font-bold text-gray-900"><%= task.title %></h1>
          <% if (task.description) { %>
            <p class="text-gray-600 mt-2"><%= task.description %></p>
          <% } %>
        </div>
        <button onclick="toggleEditForm()" class="shrink-0 px-4 py-2 border rounded-xl text-sm text-gray-600 hover:bg-gray-50 flex items-center gap-2">
          <i class="fas fa-edit"></i> Edit
        </button>
      </div>

      <!-- Meta info -->
      <div class="grid grid-cols-2 gap-4 text-sm pt-4 border-t">
        <div>
          <span class="text-gray-400">Assignee</span>
          <div class="font-medium mt-0.5">
            <% if (task.assignee) { %>
              <div class="flex items-center gap-2">
                <div class="w-6 h-6 bg-blue-600 rounded-full flex items-center justify-center text-white text-xs font-bold">
                  <%= task.assignee.name.charAt(0) %>
                </div>
                <%= task.assignee.name %>
              </div>
            <% } else { %>
              <span class="text-gray-400">Belum ditugaskan</span>
            <% } %>
          </div>
        </div>
        <div>
          <span class="text-gray-400">Deadline</span>
          <div class="font-medium mt-0.5">
            <% if (task.dueDate) { %>
              <% const isOverdue = new Date(task.dueDate) < new Date() && task.status !== 'DONE' %>
              <span class="<%= isOverdue ? 'text-red-600' : '' %>">
                <%= isOverdue ? '⚠️ ' : '' %><%= new Date(task.dueDate).toLocaleDateString('id-ID', {day:'numeric',month:'long',year:'numeric'}) %>
              </span>
            <% } else { %>
              <span class="text-gray-400">Tidak ada</span>
            <% } %>
          </div>
        </div>
        <div>
          <span class="text-gray-400">Proyek</span>
          <div class="font-medium mt-0.5">
            <a href="/projects/<%= task.projectId %>" class="text-blue-600 hover:underline"><%= task.project.name %></a>
          </div>
        </div>
        <div>
          <span class="text-gray-400">Dibuat</span>
          <div class="font-medium mt-0.5"><%= new Date(task.createdAt).toLocaleDateString('id-ID', {day:'numeric',month:'long',year:'numeric'}) %></div>
        </div>
      </div>
    </div>

    <!-- Edit Form (hidden by default) -->
    <div id="editForm" class="hidden bg-white border rounded-2xl sm:rounded-3xl p-4 sm:p-6 shadow-sm">
      <h3 class="font-semibold text-lg mb-4">Edit Task</h3>
      <form action="/tasks/<%= task.id %>/update" method="POST">
        <div class="space-y-4">
          <div>
            <label class="text-sm font-medium text-gray-700">Judul</label>
            <input type="text" name="title" value="<%= task.title %>" required
              class="mt-1 w-full border rounded-2xl px-4 py-2.5 focus:outline-none focus:border-blue-400">
          </div>
          <div>
            <label class="text-sm font-medium text-gray-700">Deskripsi</label>
            <textarea name="description" rows="3"
              class="mt-1 w-full border rounded-2xl px-4 py-2.5 focus:outline-none focus:border-blue-400"><%= task.description || '' %></textarea>
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="text-sm font-medium text-gray-700">Status</label>
              <select name="status" class="mt-1 w-full border rounded-2xl px-4 py-2.5">
                <option value="TODO" <%= task.status==='TODO'?'selected':'' %>>To Do</option>
                <option value="IN_PROGRESS" <%= task.status==='IN_PROGRESS'?'selected':'' %>>In Progress</option>
                <option value="DONE" <%= task.status==='DONE'?'selected':'' %>>Done</option>
              </select>
            </div>
            <div>
              <label class="text-sm font-medium text-gray-700">Prioritas</label>
              <select name="priority" class="mt-1 w-full border rounded-2xl px-4 py-2.5">
                <option value="NONE" <%= task.priority==='NONE'?'selected':'' %>>Tanpa Prioritas</option>
                <option value="LOW" <%= task.priority==='LOW'?'selected':'' %>>Low</option>
                <option value="MEDIUM" <%= task.priority==='MEDIUM'?'selected':'' %>>Medium</option>
                <option value="HIGH" <%= task.priority==='HIGH'?'selected':'' %>>High</option>
                <option value="URGENT" <%= task.priority==='URGENT'?'selected':'' %>>Urgent</option>
              </select>
            </div>
            <div>
              <label class="text-sm font-medium text-gray-700">Assignee</label>
              <select name="assigneeId" class="mt-1 w-full border rounded-2xl px-4 py-2.5">
                <option value="">Belum ditugaskan</option>
                <% members.forEach(m => { %>
                  <option value="<%= m.id %>" <%= task.assigneeId===m.id?'selected':'' %>><%= m.name %></option>
                <% }) %>
              </select>
            </div>
            <div>
              <label class="text-sm font-medium text-gray-700">Deadline</label>
              <input type="date" name="dueDate"
                value="<%= task.dueDate ? new Date(task.dueDate).toISOString().split('T')[0] : '' %>"
                class="mt-1 w-full border rounded-2xl px-4 py-2.5">
            </div>
          </div>
        </div>
        <div class="flex gap-3 mt-5">
          <button type="submit" class="flex-1 py-2.5 bg-blue-600 text-white rounded-2xl font-medium hover:bg-blue-700">Simpan</button>
          <button type="button" onclick="toggleEditForm()" class="flex-1 py-2.5 border rounded-2xl text-gray-600">Batal</button>
        </div>
      </form>
    </div>

    <!-- Checklist -->
    <div class="bg-white border rounded-2xl sm:rounded-3xl p-4 sm:p-6 shadow-sm">
      <div class="flex items-center justify-between mb-4">
        <h3 class="font-semibold text-lg flex items-center gap-2">
          <i class="fas fa-check-square text-blue-600"></i> Checklist
        </h3>
        <span class="text-sm text-gray-500" id="checklist-count">
          <%= task.checklists.filter(c=>c.isDone).length %> / <%= task.checklists.length %> selesai
        </span>
      </div>

      <!-- Progress bar -->
      <% if (task.checklists.length > 0) { %>
        <% const pct = Math.round(task.checklists.filter(c=>c.isDone).length / task.checklists.length * 100) %>
        <div class="h-1.5 bg-gray-100 rounded-full mb-4 overflow-hidden">
          <div class="h-full bg-blue-500 rounded-full transition-all" id="checklist-bar" style="width:<%= pct %>%"></div>
        </div>
      <% } %>

      <div id="checklist-list" class="space-y-2 mb-4">
        <p class="text-xs text-gray-400 mb-2"><i class="fas fa-info-circle mr-1"></i>Klik <i class="fas fa-plus text-blue-500"></i> di kanan item untuk tambah sub-checklist</p>
        <% task.checklists.forEach(item => { %>
          <div class="checklist-group" id="check-<%= item.id %>">
            <div class="flex items-center gap-3 p-2 rounded-xl hover:bg-gray-50 group cursor-pointer">
              <input type="checkbox" <%= item.isDone ? 'checked' : '' %>
                onchange="toggleCheck('<%= item.id %>', this)"
                class="w-4 h-4 accent-blue-600 cursor-pointer">
              <span class="flex-1 text-sm <%= item.isDone ? 'line-through text-gray-400' : 'text-gray-700' %>">
                <%= item.content %>
              </span>
              <button onclick="event.stopPropagation(); showSubCheckForm('<%= item.id %>')" class="text-blue-400 hover:text-blue-600 text-xs transition" title="Tambah sub-checklist">
                <i class="fas fa-plus"></i>
              </button>
              <button onclick="deleteCheck('<%= item.id %>')"
                class="opacity-0 group-hover:opacity-100 text-red-400 hover:text-red-600 text-xs transition">
                <i class="fas fa-times"></i>
              </button>
            </div>
            <% if (item.children && item.children.length > 0) { %>
              <div class="ml-8 space-y-1 mt-1">
                <% item.children.forEach(sub => { %>
                  <div class="flex items-center gap-3 p-1.5 rounded-lg hover:bg-gray-50 group" id="check-<%= sub.id %>">
                    <input type="checkbox" <%= sub.isDone ? 'checked' : '' %>
                      onchange="toggleCheck('<%= sub.id %>', this)"
                      class="w-3.5 h-3.5 accent-blue-600 cursor-pointer">
                    <span class="flex-1 text-xs <%= sub.isDone ? 'line-through text-gray-400' : 'text-gray-600' %>">
                      <%= sub.content %>
                    </span>
                    <button onclick="deleteCheck('<%= sub.id %>')"
                      class="text-red-400 hover:text-red-600 text-xs transition">
                      <i class="fas fa-times"></i>
                    </button>
                  </div>
                <% }) %>
              </div>
            <% } %>
            <div id="sub-form-<%= item.id %>" class="hidden ml-8 mt-1 flex gap-2">
              <input type="text" placeholder="Sub-checklist..."
                class="flex-1 border rounded-lg px-3 py-1.5 text-xs focus:outline-none focus:border-blue-400"
                onkeypress="if(event.key==='Enter') addSubCheck('<%= item.id %>', this)">
              <button onclick="addSubCheck('<%= item.id %>', this.previousElementSibling)" class="px-2 py-1 bg-blue-600 text-white rounded-lg text-xs hover:bg-blue-700"><i class="fas fa-plus"></i></button>
            </div>
          </div>
        <% }) %>
      </div>

      <!-- Add checklist item -->
      <div class="flex gap-2">
        <input type="text" id="new-checklist" placeholder="Tambah item checklist..."
          class="flex-1 border rounded-xl px-4 py-2 text-sm focus:outline-none focus:border-blue-400"
          onkeypress="if(event.key==='Enter') addCheck()">
        <button onclick="addCheck()" class="px-4 py-2 bg-blue-600 text-white rounded-xl text-sm hover:bg-blue-700">
          <i class="fas fa-plus"></i>
        </button>
      </div>
    </div>

    <!-- Dependencies -->
    <div class="bg-white border rounded-2xl sm:rounded-3xl p-4 sm:p-6 shadow-sm">
      <h3 class="font-semibold text-lg mb-4 flex items-center gap-2">
        <i class="fas fa-link text-orange-600"></i> Dependencies
        <span class="text-sm text-gray-400 font-normal" id="dep-count"></span>
      </h3>
      <div id="dep-list" class="space-y-2 mb-4"></div>
      <div class="flex gap-2">
        <select id="dep-select" class="flex-1 border rounded-xl px-3 py-2 text-sm focus:outline-none focus:border-blue-400">
          <option value="">Pilih task yang harus selesai duluan...</option>
        </select>
        <button onclick="addDependency()" class="px-4 py-2 bg-orange-600 text-white rounded-xl text-sm hover:bg-orange-700">
          <i class="fas fa-plus"></i>
        </button>
      </div>
    </div>

    <!-- Comments -->
    <div class="bg-white border rounded-2xl sm:rounded-3xl p-4 sm:p-6 shadow-sm">
      <h3 class="font-semibold text-lg mb-4 flex items-center gap-2">
        <i class="fas fa-comments text-blue-600"></i> Komentar
        <span class="text-sm text-gray-400 font-normal">(<%= task.comments.length %>)</span>
      </h3>

      <div id="comment-list" class="space-y-4 mb-5">
        <% task.comments.forEach(comment => { %>
          <div class="flex gap-3" id="comment-<%= comment.id %>">
            <div class="w-8 h-8 bg-blue-600 rounded-full flex items-center justify-center text-white text-xs font-bold shrink-0 mt-0.5">
              <%= comment.user.name.charAt(0) %>
            </div>
            <div class="flex-1 bg-gray-50 rounded-2xl px-4 py-3">
              <div class="flex items-center justify-between mb-1">
                <span class="text-sm font-semibold"><%= comment.user.name %></span>
                <div class="flex items-center gap-2">
                  <span class="text-xs text-gray-400">
                    <%= new Date(comment.createdAt).toLocaleDateString('id-ID', {day:'numeric',month:'short'}) %>
                  </span>
                  <% if (comment.userId === currentUserId) { %>
                    <button onclick="deleteComment('<%= comment.id %>')" class="text-xs text-red-400 hover:text-red-600">
                      <i class="fas fa-trash"></i>
                    </button>
                  <% } %>
                </div>
              </div>
              <p class="text-sm text-gray-700 comment-content"><%= comment.content %></p>
              <!-- Attached files -->
              <% if (comment.files && comment.files.length > 0) { %>
                <div class="flex flex-wrap gap-2 mt-2">
                  <% comment.files.forEach(file => { %>
                    <% if (file.mimeType && file.mimeType.startsWith('image/')) { %>
                      <a href="<%= file.url %>" target="_blank" class="block"><img src="<%= file.url %>" alt="<%= file.originalName %>" class="max-h-32 rounded-xl border object-contain"></a>
                    <% } else { %>
                      <a href="<%= file.url %>" target="_blank" class="inline-flex items-center gap-2 px-3 py-1.5 bg-white border rounded-xl text-xs text-gray-700 hover:bg-gray-50">
                        <i class="fas fa-file"></i><%= file.originalName %>
                      </a>
                    <% } %>
                  <% }) %>
                </div>
              <% } %>
              <!-- Cheers reactions + Reply -->
              <div class="flex items-center gap-1 mt-2 flex-wrap" id="reactions-<%= comment.id %>">
                <% const reactions = comment.reactions || {}; %>
                <% Object.entries(reactions).forEach(([emoji, users]) => { %>
                  <% if (users && users.length > 0) { %>
                    <button onclick="toggleReaction('<%= comment.id %>', '<%= emoji %>')"
                      class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs border transition <%= users.includes(currentUserId) ? 'bg-blue-100 border-blue-400 text-blue-700' : 'bg-white border-gray-200 hover:bg-gray-100' %>">
                      <span><%= emoji %></span><span class="font-medium"><%= users.length %></span>
                    </button>
                  <% } %>
                <% }) %>
                <div class="relative">
                  <button onclick="toggleCheerMenu('<%= comment.id %>')" class="w-6 h-6 rounded-full bg-white border border-gray-200 hover:bg-gray-100 flex items-center justify-center text-xs text-gray-400 transition">
                    <i class="fas fa-smile"></i>
                  </button>
                  <div id="cheer-menu-<%= comment.id %>" class="hidden absolute bottom-8 left-0 bg-white border rounded-xl shadow-lg p-2 flex gap-1 z-10">
                    <button onclick="toggleReaction('<%= comment.id %>', '👍')" class="hover:bg-gray-100 rounded-lg p-1 text-lg">👍</button>
                    <button onclick="toggleReaction('<%= comment.id %>', '🔥')" class="hover:bg-gray-100 rounded-lg p-1 text-lg">🔥</button>
                    <button onclick="toggleReaction('<%= comment.id %>', '❤️')" class="hover:bg-gray-100 rounded-lg p-1 text-lg">❤️</button>
                    <button onclick="toggleReaction('<%= comment.id %>', '😂')" class="hover:bg-gray-100 rounded-lg p-1 text-lg">😂</button>
                    <button onclick="toggleReaction('<%= comment.id %>', '🎉')" class="hover:bg-gray-100 rounded-lg p-1 text-lg">🎉</button>
                    <button onclick="toggleReaction('<%= comment.id %>', '👀')" class="hover:bg-gray-100 rounded-lg p-1 text-lg">👀</button>
                  </div>
                </div>
                <button onclick="showReplyForm('<%= comment.id %>')" class="text-xs text-gray-400 hover:text-blue-600 ml-1 transition">
                  <i class="fas fa-reply mr-0.5"></i>Reply
                </button>
              </div>
              <!-- Threaded replies -->
              <% if (comment.replies && comment.replies.length > 0) { %>
                <div class="mt-3 ml-4 pl-3 border-l-2 border-gray-200 space-y-3">
                  <% comment.replies.forEach(reply => { %>
                    <div class="flex gap-2" id="comment-<%= reply.id %>">
                      <div class="w-6 h-6 bg-gray-500 rounded-full flex items-center justify-center text-white text-[10px] font-bold shrink-0">
                        <%= reply.user.name.charAt(0) %>
                      </div>
                      <div class="flex-1">
                        <div class="flex items-center gap-2 mb-0.5">
                          <span class="text-xs font-semibold">${escapeHtml('<%= reply.user.name %>')}</span>
                          <span class="text-[10px] text-gray-400"><%= new Date(reply.createdAt).toLocaleDateString('id-ID', {day:'numeric',month:'short'}) %></span>
                        </div>
                        <p class="text-xs text-gray-700"><%= reply.content %></p>
                        <% if (reply.files && reply.files.length > 0) { %>
                          <div class="flex flex-wrap gap-1 mt-1">
                            <% reply.files.forEach(file => { %>
                              <a href="<%= file.url %>" target="_blank" class="inline-flex items-center gap-1 px-2 py-1 bg-white border rounded-lg text-[10px] text-gray-600 hover:bg-gray-50">
                                <i class="fas fa-file"></i><%= file.originalName %>
                              </a>
                            <% }) %>
                          </div>
                        <% } %>
                      </div>
                    </div>
                  <% }) %>
                </div>
              <% } %>
              <!-- Reply form -->
              <div id="reply-form-<%= comment.id %>" class="hidden mt-2 ml-4 pl-3 border-l-2 border-blue-300">
                <div class="flex gap-2">
                  <input type="text" id="reply-input-<%= comment.id %>" placeholder="Balas..."
                    class="flex-1 border rounded-xl px-3 py-1.5 text-xs focus:outline-none focus:border-blue-400"
                    onkeypress="if(event.key==='Enter') addReply('<%= comment.id %>')">
                  <button onclick="addReply('<%= comment.id %>')" class="px-3 py-1.5 bg-blue-600 text-white rounded-xl text-xs hover:bg-blue-700">Kirim</button>
                </div>
              </div>
            </div>
          </div>
        <% }) %>
        <% if (task.comments.length === 0) { %>
          <p class="text-gray-400 text-sm text-center py-4" id="no-comments">Belum ada komentar. Jadi yang pertama!</p>
        <% } %>
      </div>

      <!-- Add comment -->
      <div class="flex gap-3">
        <div class="w-8 h-8 bg-blue-600 rounded-full flex items-center justify-center text-white text-xs font-bold shrink-0 mt-1">
          <%= currentUser.name.charAt(0) %>
        </div>
        <div class="flex-1">
          <div class="flex gap-2">
            <input type="text" id="comment-input" placeholder="Tulis komentar..."
              class="flex-1 border rounded-2xl px-4 py-2.5 text-sm focus:outline-none focus:border-blue-400"
              onkeypress="if(event.key==='Enter') addComment()">
            <button onclick="addComment()" class="px-5 py-2.5 bg-blue-600 text-white rounded-2xl text-sm hover:bg-blue-700">
              Kirim
            </button>
          </div>
          <div class="flex items-center gap-3 mt-2">
            <label class="cursor-pointer text-xs text-gray-400 hover:text-blue-600 transition">
              <i class="fas fa-paperclip mr-1"></i>Lampirkan file
              <input type="file" id="comment-files" multiple class="hidden" onchange="showSelectedFiles()">
            </label>
            <div id="selected-files" class="text-xs text-gray-500"></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- RIGHT: Quick Actions Sidebar -->
  <div class="space-y-4">

    <!-- Back to Board -->
    <a href="/projects/<%= task.projectId %>"
      class="flex items-center gap-2 px-4 py-3 bg-white border rounded-2xl text-sm text-gray-700 hover:bg-gray-50 transition font-medium">
      <i class="fas fa-arrow-left text-blue-600"></i> Kembali ke Board
    </a>

    <!-- Change Status Quick -->
    <div class="bg-white border rounded-3xl p-5 shadow-sm">
      <div class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-3">Ubah Status</div>
      <div class="space-y-2">
        <% ['TODO','IN_PROGRESS','DONE'].forEach(s => { %>
          <form action="/tasks/<%= task.id %>/update" method="POST">
            <input type="hidden" name="title" value="<%= task.title %>">
            <input type="hidden" name="priority" value="<%= task.priority %>">
            <input type="hidden" name="status" value="<%= s %>">
            <% if (task.assigneeId) { %><input type="hidden" name="assigneeId" value="<%= task.assigneeId %>"><% } %>
            <button type="submit" class="w-full text-left px-3 py-2 rounded-xl text-sm transition
              <%= task.status === s ? 'bg-blue-600 text-white font-semibold' : 'hover:bg-gray-50 text-gray-700' %>">
              <% if (s==='TODO') { %><i class="fas fa-circle text-gray-400 mr-2 text-xs"></i>To Do
              <% } else if (s==='IN_PROGRESS') { %><i class="fas fa-circle text-amber-400 mr-2 text-xs"></i>In Progress
              <% } else { %><i class="fas fa-circle text-emerald-500 mr-2 text-xs"></i>Done<% } %>
            </button>
          </form>
        <% }) %>
      </div>
    </div>

    <!-- Labels -->
    <div class="bg-white border rounded-3xl p-5 shadow-sm">
      <div class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-3">Label</div>
      <div class="flex flex-wrap gap-2 mb-4">
        <% if (task.labels.length === 0) { %>
          <span class="text-sm text-gray-400">Belum ada label</span>
        <% } %>
        <% task.labels.forEach(tl => { %>
          <form action="/tasks/<%= task.id %>/labels/<%= tl.label.id %>/remove" method="POST">
            <button type="submit" class="text-xs font-semibold rounded-full px-3 py-1 text-white" style="background:<%= tl.label.color %>" title="Klik untuk hapus">
              <%= tl.label.name %> ×
            </button>
          </form>
        <% }) %>
      </div>
      <form action="/tasks/<%= task.id %>/labels" method="POST" class="space-y-2">
        <select name="labelId" class="w-full border rounded-xl px-3 py-2 text-sm">
          <option value="">Buat label baru...</option>
          <% labels.forEach(label => { %>
            <option value="<%= label.id %>"><%= label.name %></option>
          <% }) %>
        </select>
        <div class="grid grid-cols-[1fr_44px] gap-2">
          <input type="text" name="name" placeholder="Nama label baru" class="border rounded-xl px-3 py-2 text-sm">
          <input type="color" name="color" value="#3B82F6" class="h-10 w-full border rounded-xl p-1">
        </div>
        <button type="submit" class="w-full py-2 bg-blue-600 text-white rounded-xl text-sm hover:bg-blue-700">
          Tambah Label
        </button>
      </form>
    </div>

    <!-- Attachments -->
    <div class="bg-white border rounded-3xl p-5 shadow-sm">
      <div class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-3">Attachment</div>
      <div class="space-y-2 mb-4">
        <% if (task.attachments.length === 0) { %>
          <div class="text-sm text-gray-400">Belum ada file</div>
        <% } %>
        <% task.attachments.forEach(file => { %>
          <a href="<%= file.url %>" target="_blank" class="block border rounded-2xl overflow-hidden hover:bg-gray-50">
            <% if (file.mimeType.startsWith('image/')) { %>
              <img src="<%= file.url %>" alt="<%= file.originalName %>" class="w-full max-h-40 object-cover bg-gray-50">
            <% } %>
            <div class="px-3 py-2 text-xs">
              <div class="font-semibold text-gray-700 truncate"><%= file.originalName %></div>
              <div class="text-gray-400"><%= Math.ceil(file.size / 1024) %> KB • <%= file.uploadedBy.name %></div>
            </div>
          </a>
        <% }) %>
      </div>
      <form action="/tasks/<%= task.id %>/attachments" method="POST" enctype="multipart/form-data" class="space-y-2">
        <input type="file" name="files" multiple class="w-full text-sm border rounded-xl px-3 py-2">
        <button type="submit" class="w-full py-2 bg-gray-900 text-white rounded-xl text-sm hover:bg-black">
          Upload File
        </button>
      </form>
    </div>

    <!-- Activity Log -->
    <div class="bg-white border rounded-3xl p-5 shadow-sm">
      <div class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-3">Activity Log</div>
      <div class="space-y-3 max-h-72 overflow-y-auto">
        <% if (task.activityLogs.length === 0) { %>
          <div class="text-sm text-gray-400">Belum ada aktivitas</div>
        <% } %>
        <% task.activityLogs.forEach(log => { %>
          <div class="text-xs border-l-2 border-blue-200 pl-3">
            <div class="font-semibold text-gray-700"><%= log.action.replaceAll('_', ' ') %></div>
            <div class="text-gray-400"><%= log.user ? log.user.name : 'System' %> • <%= new Date(log.createdAt).toLocaleDateString('id-ID', {day:'numeric',month:'short',hour:'2-digit',minute:'2-digit'}) %></div>
          </div>
        <% }) %>
      </div>
    </div>

    <!-- Delete Task -->
    <form onsubmit="return confirmDelete(event, '<%= task.id %>', '<%= task.projectId %>')">
      <button type="submit"
        class="w-full px-4 py-3 border border-red-200 text-red-500 rounded-2xl text-sm hover:bg-red-50 transition font-medium">
        <i class="fas fa-trash mr-2"></i>Hapus Task
      </button>
    </form>
  </div>
</div>

<script>
const taskId = '<%= task.id %>';

function escapeHtml(value) {
  return String(value || '').replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#039;'}[c]));
}

function toggleEditForm() {
  document.getElementById('editForm').classList.toggle('hidden');
}

// Checklist
async function toggleCheck(id, el) {
  await fetch(`/checklist/${id}/toggle`, { method: 'PATCH' });
  const label = el.parentElement.querySelector('span');
  if (el.checked) label.classList.add('line-through','text-gray-400');
  else label.classList.remove('line-through','text-gray-400');
  updateChecklistMeta();
}

async function deleteCheck(id) {
  await fetch(`/checklist/${id}`, { method: 'DELETE' });
  document.getElementById(`check-${id}`)?.remove();
  updateChecklistMeta();
}

async function addCheck() {
  const input = document.getElementById('new-checklist');
  const content = input.value.trim();
  if (!content) return;

  const res = await fetch(`/checklist/task/${taskId}`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ content })
  });
  const data = await res.json();
  if (data.success) {
    const list = document.getElementById('checklist-list');
    const div = document.createElement('div');
    div.className = 'flex items-center gap-3 p-2 rounded-xl hover:bg-gray-50 group';
    div.id = `check-${data.item.id}`;
    div.innerHTML = `
      <input type="checkbox" onchange="toggleCheck('${data.item.id}', this)" class="w-4 h-4 accent-blue-600 cursor-pointer">
      <span class="flex-1 text-sm text-gray-700">${escapeHtml(data.item.content)}</span>
      <button onclick="deleteCheck('${data.item.id}')" class="opacity-0 group-hover:opacity-100 text-red-400 hover:text-red-600 text-xs transition">
        <i class="fas fa-times"></i>
      </button>
    `;
    list.appendChild(div);
    input.value = '';
    updateChecklistMeta();
  }
}

function updateChecklistMeta() {
  const all = document.querySelectorAll('#checklist-list input[type=checkbox]');
  const done = document.querySelectorAll('#checklist-list input[type=checkbox]:checked');
  document.getElementById('checklist-count').textContent = `${done.length} / ${all.length} selesai`;
  let bar = document.getElementById('checklist-bar');
  if (!bar && all.length > 0) {
    const wrapper = document.createElement('div');
    wrapper.className = 'h-1.5 bg-gray-100 rounded-full mb-4 overflow-hidden';
    bar = document.createElement('div');
    bar.id = 'checklist-bar';
    bar.className = 'h-full bg-blue-500 rounded-full transition-all';
    bar.style.width = '0%';
    wrapper.appendChild(bar);
    document.getElementById('checklist-list').before(wrapper);
  }
  if (bar && all.length > 0) bar.style.width = `${Math.round(done.length/all.length*100)}%`;
}

// Sub-checklist
function showSubCheckForm(parentId) {
  const form = document.getElementById(`sub-form-${parentId}`);
  form.classList.toggle('hidden');
  if (!form.classList.contains('hidden')) form.querySelector('input').focus();
}

async function addSubCheck(parentId, input) {
  const content = input.value.trim();
  if (!content) return;
  const res = await fetch(`/checklist/task/${taskId}`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ content, parentId })
  });
  const data = await res.json();
  if (data.success) {
    const group = document.getElementById(`check-${parentId}`);
    let subList = group.querySelector('.sub-checklist');
    if (!subList) {
      subList = document.createElement('div');
      subList.className = 'sub-checklist ml-8 space-y-1 mt-1';
      group.insertBefore(subList, group.lastElementChild);
    }
    const div = document.createElement('div');
    div.className = 'flex items-center gap-3 p-1.5 rounded-lg hover:bg-gray-50 group';
    div.id = `check-${data.item.id}`;
    div.innerHTML = `
      <input type="checkbox" onchange="toggleCheck('${data.item.id}', this)" class="w-3.5 h-3.5 accent-blue-600 cursor-pointer">
      <span class="flex-1 text-xs text-gray-600">${escapeHtml(data.item.content)}</span>
      <button onclick="deleteCheck('${data.item.id}')" class="opacity-0 group-hover:opacity-100 text-red-400 hover:text-red-600 text-xs transition"><i class="fas fa-times"></i></button>
    `;
    subList.appendChild(div);
    input.value = '';
    updateChecklistMeta();
  }
}

// Cheers reactions
function toggleCheerMenu(commentId) {
  document.querySelectorAll('[id^="cheer-menu-"]').forEach(el => el.classList.add('hidden'));
  const menu = document.getElementById(`cheer-menu-${commentId}`);
  menu.classList.toggle('hidden');
}

async function toggleReaction(commentId, emoji) {
  const res = await fetch(`/tasks/${taskId}/comments/${commentId}/reactions`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ emoji })
  });
  const data = await res.json();
  if (data.success) {
    const container = document.getElementById(`reactions-${commentId}`);
    container.innerHTML = data.reactions.map(([e, users]) => `
      <button onclick="toggleReaction('${commentId}', '${e}')"
        class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs border transition ${users.includes(currentUser.id) ? 'bg-blue-100 border-blue-400 text-blue-700' : 'bg-white border-gray-200 hover:bg-gray-100'}">
        <span>${e}</span><span class="font-medium">${users.length}</span>
      </button>
    `).join('') + `
      <div class="relative">
        <button onclick="toggleCheerMenu('${commentId}')" class="w-6 h-6 rounded-full bg-white border border-gray-200 hover:bg-gray-100 flex items-center justify-center text-xs text-gray-400 transition"><i class="fas fa-smile"></i></button>
        <div id="cheer-menu-${commentId}" class="hidden absolute bottom-8 left-0 bg-white border rounded-xl shadow-lg p-2 flex gap-1 z-10">
          <button onclick="toggleReaction('${commentId}', '👍')" class="hover:bg-gray-100 rounded-lg p-1 text-lg">👍</button>
          <button onclick="toggleReaction('${commentId}', '🔥')" class="hover:bg-gray-100 rounded-lg p-1 text-lg">🔥</button>
          <button onclick="toggleReaction('${commentId}', '❤️')" class="hover:bg-gray-100 rounded-lg p-1 text-lg">❤️</button>
          <button onclick="toggleReaction('${commentId}', '😂')" class="hover:bg-gray-100 rounded-lg p-1 text-lg">😂</button>
          <button onclick="toggleReaction('${commentId}', '🎉')" class="hover:bg-gray-100 rounded-lg p-1 text-lg">🎉</button>
          <button onclick="toggleReaction('${commentId}', '👀')" class="hover:bg-gray-100 rounded-lg p-1 text-lg">👀</button>
        </div>
      </div>
    `;
    toggleCheerMenu(commentId);
  }
}

document.addEventListener('click', (e) => {
  if (!e.target.closest('[id^="cheer-menu"]') && !e.target.closest('[onclick*="toggleCheerMenu"]')) {
    document.querySelectorAll('[id^="cheer-menu-"]').forEach(el => el.classList.add('hidden'));
  }
});

// @mention in comments
function setupMention(inputId) {
  const input = document.getElementById(inputId);
  if (!input) return;
  input.addEventListener('input', async (e) => {
    const val = input.value;
    const atPos = val.lastIndexOf('@');
    if (atPos === -1) { removeDropdown(); return; }
    const query = val.slice(atPos + 1);
    if (query.length < 1) { removeDropdown(); return; }
    const res = await fetch(`/tasks/${taskId}/members?q=${encodeURIComponent(query)}`);
    const members = await res.json();
    showDropdown(members, input, atPos);
  });
}

function showDropdown(members, input, atPos) {
  removeDropdown();
  if (!members.length) return;
  const dd = document.createElement('div');
  dd.id = 'mention-dropdown';
  dd.className = 'absolute z-50 bg-white border rounded-xl shadow-lg max-h-40 overflow-y-auto';
  dd.style.cssText = 'bottom:100%;left:0;margin-bottom:4px;width:220px;';
  members.forEach(m => {
    const opt = document.createElement('button');
    opt.className = 'w-full text-left px-3 py-2 hover:bg-blue-50 text-sm flex items-center gap-2';
    opt.innerHTML = `<span class="w-5 h-5 bg-blue-600 rounded-full flex items-center justify-center text-white text-[10px] font-bold">${m.name.charAt(0)}</span>${escapeHtml(m.name)}`;
    opt.onclick = () => {
      const val = input.value;
      input.value = val.slice(0, atPos) + '@' + m.name + ' ';
      removeDropdown();
      input.focus();
    };
    dd.appendChild(opt);
  });
  input.parentElement.style.position = 'relative';
  input.parentElement.appendChild(dd);
}

function removeDropdown() {
  document.getElementById('mention-dropdown')?.remove();
}

// File upload helpers
function showSelectedFiles() {
  const input = document.getElementById('comment-files');
  const display = document.getElementById('selected-files');
  if (input.files.length > 0) {
    display.textContent = Array.from(input.files).map(f => f.name).join(', ');
  } else {
    display.textContent = '';
  }
}

function showReplyForm(commentId) {
  const form = document.getElementById(`reply-form-${commentId}`);
  form.classList.toggle('hidden');
  if (!form.classList.contains('hidden')) form.querySelector('input').focus();
}

// Comments with file upload
async function addComment() {
  const input = document.getElementById('comment-input');
  const content = input.value.trim();
  const fileInput = document.getElementById('comment-files');
  if (!content && fileInput.files.length === 0) return;

  const formData = new FormData();
  if (content) formData.append('content', content);
  for (const file of fileInput.files) formData.append('files', file);

  const res = await fetch(`/tasks/${taskId}/comments`, { method: 'POST', body: formData });
  const data = await res.json();
  if (data.success) {
    const list = document.getElementById('comment-list');
    document.getElementById('no-comments')?.remove();
    const comment = data.comment;
    const filesHtml = (comment.files || []).map(f => {
      if (f.mimeType && f.mimeType.startsWith('image/')) {
        return `<a href="${f.url}" target="_blank" class="block mt-2"><img src="${f.url}" alt="${escapeHtml(f.originalName)}" class="max-h-32 rounded-xl border object-contain"></a>`;
      }
      return `<a href="${f.url}" target="_blank" class="inline-flex items-center gap-2 px-3 py-1.5 bg-white border rounded-xl text-xs text-gray-700 hover:bg-gray-50"><i class="fas fa-file"></i>${escapeHtml(f.originalName)}</a>`;
    }).join('');

    const div = document.createElement('div');
    div.className = 'flex gap-3';
    div.id = `comment-${comment.id}`;
    div.innerHTML = `
      <div class="w-8 h-8 bg-blue-600 rounded-full flex items-center justify-center text-white text-xs font-bold shrink-0 mt-0.5">${comment.user.name.charAt(0)}</div>
      <div class="flex-1 bg-gray-50 rounded-2xl px-4 py-3">
        <div class="flex items-center justify-between mb-1">
          <span class="text-sm font-semibold">${escapeHtml(comment.user.name)}</span>
          <div class="flex items-center gap-2">
            <span class="text-xs text-gray-400">Baru saja</span>
            <button onclick="deleteComment('${comment.id}')" class="text-xs text-red-400 hover:text-red-600"><i class="fas fa-trash"></i></button>
          </div>
        </div>
        <p class="text-sm text-gray-700 comment-content">${escapeHtml(comment.content)}</p>
        ${filesHtml}
        <div class="flex items-center gap-1 mt-2 flex-wrap" id="reactions-${comment.id}">
          <div class="relative">
            <button onclick="toggleCheerMenu('${comment.id}')" class="w-6 h-6 rounded-full bg-white border border-gray-200 hover:bg-gray-100 flex items-center justify-center text-xs text-gray-400"><i class="fas fa-smile"></i></button>
            <div id="cheer-menu-${comment.id}" class="hidden absolute bottom-8 left-0 bg-white border rounded-xl shadow-lg p-2 flex gap-1 z-10">
              ${['👍','🔥','❤️','😂','🎉','👀'].map(e => `<button onclick="toggleReaction('${comment.id}', '${e}')" class="hover:bg-gray-100 rounded-lg p-1 text-lg">${e}</button>`).join('')}
            </div>
          </div>
          <button onclick="showReplyForm('${comment.id}')" class="text-xs text-gray-400 hover:text-blue-600 ml-1"><i class="fas fa-reply mr-0.5"></i>Reply</button>
        </div>
        <div id="reply-form-${comment.id}" class="hidden mt-2 ml-4 pl-3 border-l-2 border-blue-300">
          <div class="flex gap-2">
            <input type="text" id="reply-input-${comment.id}" placeholder="Balas..." class="flex-1 border rounded-xl px-3 py-1.5 text-xs focus:outline-none focus:border-blue-400" onkeypress="if(event.key==='Enter') addReply('${comment.id}')">
            <button onclick="addReply('${comment.id}')" class="px-3 py-1.5 bg-blue-600 text-white rounded-xl text-xs hover:bg-blue-700">Kirim</button>
          </div>
        </div>
      </div>
    `;
    list.appendChild(div);
    input.value = '';
    fileInput.value = '';
    document.getElementById('selected-files').textContent = '';
  }
}

async function addReply(parentId) {
  const input = document.getElementById(`reply-input-${parentId}`);
  const content = input.value.trim();
  if (!content) return;
  const formData = new FormData();
  formData.append('content', content);
  formData.append('parentId', parentId);
  const res = await fetch(`/tasks/${taskId}/comments`, { method: 'POST', body: formData });
  const data = await res.json();
  if (data.success) {
    const parentEl = document.getElementById(`comment-${parentId}`);
    let replyContainer = parentEl.querySelector('.reply-thread');
    if (!replyContainer) {
      replyContainer = document.createElement('div');
      replyContainer.className = 'reply-thread mt-3 ml-4 pl-3 border-l-2 border-gray-200 space-y-3';
      parentEl.querySelector('.flex-1').appendChild(replyContainer);
    }
    const div = document.createElement('div');
    div.className = 'flex gap-2';
    div.id = `comment-${data.comment.id}`;
    div.innerHTML = `
      <div class="w-6 h-6 bg-gray-500 rounded-full flex items-center justify-center text-white text-[10px] font-bold shrink-0">${data.comment.user.name.charAt(0)}</div>
      <div class="flex-1"><div class="flex items-center gap-2 mb-0.5"><span class="text-xs font-semibold">${escapeHtml(data.comment.user.name)}</span><span class="text-[10px] text-gray-400">Baru saja</span></div><p class="text-xs text-gray-700">${escapeHtml(data.comment.content)}</p></div>
    `;
    replyContainer.appendChild(div);
    input.value = '';
  }
}

// Dependencies
async function loadDependencies() {
  try {
    const res = await fetch(`/dependencies/task/${taskId}`);
    const data = await res.json();
    const list = document.getElementById('dep-list');
    list.innerHTML = '';
    if (data.deps.length > 0) {
      data.deps.forEach(dep => {
        const statusIcon = dep.dependsOn.status === 'DONE' ? '✅' : '⏳';
        const div = document.createElement('div');
        div.className = 'flex items-center gap-2 p-2 bg-orange-50 rounded-xl text-sm';
        div.innerHTML = `<span>${statusIcon}</span><span class="flex-1 ${dep.dependsOn.status === 'DONE' ? 'line-through text-gray-400' : 'text-gray-700'}">${escapeHtml(dep.dependsOn.title)}</span><a href="/tasks/${dep.dependsOn.id}" class="text-xs text-blue-600 hover:underline">Lihat</a><button onclick="removeDep('${dep.id}')" class="text-red-400 hover:text-red-600 text-xs"><i class="fas fa-times"></i></button>`;
        list.appendChild(div);
      });
    }
    if (data.blockedBy.length > 0) {
      data.blockedBy.forEach(b => {
        const div = document.createElement('div');
        div.className = 'flex items-center gap-2 p-2 bg-gray-50 rounded-xl text-sm';
        div.innerHTML = `<span class="text-gray-400">🔒</span><span class="text-gray-500 text-xs">Blocked by: ${escapeHtml(b.task.title)}</span>`;
        list.appendChild(div);
      });
    }
    document.getElementById('dep-count').textContent = data.deps.length > 0 ? `(${data.deps.length})` : '';
  } catch (e) {}
}

async function addDependency() {
  const select = document.getElementById('dep-select');
  const dependsOnId = select.value;
  if (!dependsOnId) return;
  const res = await fetch(`/dependencies/task/${taskId}`, {
    method: 'POST', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ dependsOnId })
  });
  const data = await res.json();
  if (data.success) { loadDependencies(); select.value = ''; }
  else alert(data.error || 'Gagal');
}

async function removeDep(id) {
  await fetch(`/dependencies/${id}`, { method: 'DELETE' });
  loadDependencies();
}

async function deleteComment(id) {
  if (!confirm('Hapus komentar ini?')) return;
  await fetch(`/tasks/${taskId}/comments/${id}`, { method: 'DELETE' });
  document.getElementById(`comment-${id}`)?.remove();
}

async function confirmDelete(e, id, projectId) {
  e.preventDefault();
  if (!confirm('Hapus task ini permanen?')) return false;
  await fetch(`/tasks/${id}`, { method: 'DELETE' });
  window.location.href = `/projects/${projectId}`;
  return false;
}

// Init
document.addEventListener('DOMContentLoaded', () => {
  setupMention('comment-input');
  loadDependencies();
});
</script>

<%- include('../partials/footer') %>
