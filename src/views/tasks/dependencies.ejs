<%- include('../partials/header', { title: 'Task Dependencies' }) %>

<div class="mb-6">
  <a href="/projects/<%= projectId %>" class="text-blue-600 hover:underline text-sm flex items-center gap-1 mb-2">
    <i class="fas fa-arrow-left"></i> Kembali ke Proyek
  </a>
  <h1 class="text-2xl font-bold text-gray-900">Dependency Graph</h1>
  <p class="text-sm text-gray-500 mt-1">Visualisasi ketergantungan antar task</p>
</div>

<div class="bg-white border rounded-2xl p-6 shadow-sm">
  <div id="dep-graph" class="overflow-auto">
    <% if (typeof tasks !== 'undefined' && tasks.length > 0) { %>
      <svg id="dep-svg" width="100%" height="600" class="border rounded-xl bg-gray-50">
        <!-- Rendered by JS -->
      </svg>
    <% } else { %>
      <div class="text-center py-12">
        <i class="fas fa-diagram-project text-4xl text-gray-200 mb-3"></i>
        <p class="text-gray-400">Belum ada task dengan dependency</p>
      </div>
    <% } %>
  </div>

  <!-- Legend -->
  <div class="flex items-center gap-4 mt-4 text-xs text-gray-500 flex-wrap">
    <div class="flex items-center gap-1.5">
      <div class="w-3 h-3 rounded-full bg-emerald-500"></div> Done
    </div>
    <div class="flex items-center gap-1.5">
      <div class="w-3 h-3 rounded-full bg-amber-500"></div> In Progress
    </div>
    <div class="flex items-center gap-1.5">
      <div class="w-3 h-3 rounded-full bg-gray-400"></div> To Do
    </div>
    <div class="flex items-center gap-1.5">
      <div class="w-0.5 h-4 bg-red-400"></div> Critical Path
    </div>
  </div>

  <!-- Dependency list -->
  <% if (typeof deps !== 'undefined' && deps.length > 0) { %>
    <div class="mt-6 border-t pt-4">
      <h3 class="font-semibold text-sm text-gray-700 mb-3">Daftar Dependencies</h3>
      <div class="space-y-2">
        <% deps.forEach(dep => { %>
          <div class="flex items-center gap-3 text-sm bg-gray-50 rounded-xl px-4 py-2.5">
            <span class="font-medium text-gray-700"><%= dep.task?.title || '?' %></span>
            <i class="fas fa-arrow-right text-gray-400"></i>
            <span class="text-gray-600"><%= dep.dependsOn?.title || '?' %></span>
            <% if (dep.dependsOn?.status === 'DONE') { %>
              <span class="text-[10px] bg-emerald-100 text-emerald-700 px-2 py-0.5 rounded-full">Selesai</span>
            <% } else { %>
              <span class="text-[10px] bg-amber-100 text-amber-700 px-2 py-0.5 rounded-full">Belum selesai</span>
            <% } %>
          </div>
        <% }) %>
      </div>
    </div>
  <% } %>
</div>

<script>
(function() {
  const svg = document.getElementById('dep-svg');
  if (!svg) return;

  const tasks = <%- JSON.stringify(typeof tasks !== 'undefined' ? tasks : []) %>;
  const deps = <%- JSON.stringify(typeof deps !== 'undefined' ? deps : []) %>;

  if (tasks.length === 0) return;

  const statusColor = { DONE: '#10b981', IN_PROGRESS: '#f59e0b', TODO: '#9ca3af' };
  const nodeWidth = 180;
  const nodeHeight = 50;
  const gapX = 60;
  const gapY = 30;
  const padding = 40;

  // Simple layered layout
  const layers = new Map();
  const visited = new Set();

  function getLayer(taskId, depth = 0) {
    if (visited.has(taskId)) return layers.get(taskId) || 0;
    visited.add(taskId);
    const incoming = deps.filter(d => d.taskId === taskId);
    let maxPrev = depth;
    for (const dep of incoming) {
      maxPrev = Math.max(maxPrev, getLayer(dep.dependsOnId, depth) + 1);
    }
    layers.set(taskId, maxPrev);
    return maxPrev;
  }

  tasks.forEach(t => getLayer(t.id));

  // Position nodes
  const positions = new Map();
  const layerGroups = new Map();
  layers.forEach((layer, taskId) => {
    if (!layerGroups.has(layer)) layerGroups.set(layer, []);
    layerGroups.get(layer).push(taskId);
  });

  layerGroupS = [...layerGroups.entries()].sort((a, b) => a[0] - b[0]);
  layerGroups.forEach((taskIds, layer) => {
    taskIds.forEach((taskId, index) => {
      positions.set(taskId, {
        x: padding + layer * (nodeWidth + gapX),
        y: padding + index * (nodeHeight + gapY)
      });
    });
  });

  // Draw edges
  deps.forEach(dep => {
    const from = positions.get(dep.dependsOnId);
    const to = positions.get(dep.taskId);
    if (!from || !to) return;

    const isCritical = dep.dependsOn?.status !== 'DONE' && dep.task?.status !== 'DONE';
    const line = document.createElementNS('http://www.w3.org/2000/svg', 'line');
    line.setAttribute('x1', from.x + nodeWidth);
    line.setAttribute('y1', from.y + nodeHeight / 2);
    line.setAttribute('x2', to.x);
    line.setAttribute('y2', to.y + nodeHeight / 2);
    line.setAttribute('stroke', isCritical ? '#f87171' : '#d1d5db');
    line.setAttribute('stroke-width', isCritical ? '2.5' : '1.5');
    line.setAttribute('marker-end', 'url(#arrow)');
    svg.appendChild(line);
  });

  // Draw nodes
  tasks.forEach(task => {
    const pos = positions.get(task.id);
    if (!pos) return;

    const g = document.createElementNS('http://www.w3.org/2000/svg', 'g');
    g.setAttribute('transform', `translate(${pos.x}, ${pos.y})`);

    const rect = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
    rect.setAttribute('width', nodeWidth);
    rect.setAttribute('height', nodeHeight);
    rect.setAttribute('rx', '10');
    rect.setAttribute('fill', 'white');
    rect.setAttribute('stroke', statusColor[task.status] || '#9ca3af');
    rect.setAttribute('stroke-width', '2');
    g.appendChild(rect);

    const circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
    circle.setAttribute('cx', '15');
    circle.setAttribute('cy', nodeHeight / 2);
    circle.setAttribute('r', '6');
    circle.setAttribute('fill', statusColor[task.status] || '#9ca3af');
    g.appendChild(circle);

    const text = document.createElementNS('http://www.w3.org/2000/svg', 'text');
    text.setAttribute('x', '28');
    text.setAttribute('y', nodeHeight / 2 + 4);
    text.setAttribute('font-size', '11');
    text.setAttribute('fill', '#374151');
    text.textContent = task.title.length > 20 ? task.title.slice(0, 20) + '...' : task.title;
    g.appendChild(text);

    svg.appendChild(g);
  });

  // Arrow marker
  const defs = document.createElementNS('http://www.w3.org/2000/svg', 'defs');
  defs.innerHTML = '<marker id="arrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto"><path d="M 0 0 L 10 5 L 0 10 z" fill="#9ca3af"/></marker>';
  svg.prepend(defs);
})();
</script>

<%- include('../partials/footer') %>
