<%- include('partials/header', { title: 'Pengumuman' }) %>

<div class="max-w-3xl mx-auto">
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900">Pengumuman</h1>
    <p class="text-gray-500 mt-1">Broadcast yang bisa dibedakan untuk User Apps, Holding, atau Brand.</p>
  </div>

  <% if (currentUser.platformRole === 'owner') { %>
  <div class="bg-white border rounded-3xl p-6 mb-6 shadow-sm">
    <h2 class="font-semibold text-lg text-gray-900 mb-4 flex items-center gap-2"><i class="fas fa-bullhorn text-blue-600"></i> Buat Pengumuman Baru</h2>
    <form action="/announcements" method="POST" enctype="multipart/form-data" class="space-y-4" id="announcement-form">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <label class="block">
          <span class="text-sm font-medium text-gray-600">Tipe Pengumuman</span>
          <select name="scope" id="announcement-scope"
            class="mt-1.5 w-full border rounded-2xl px-4 py-3 focus:outline-none focus:border-blue-400 focus:ring-2 focus:ring-blue-100">
            <option value="<%= AnnouncementScope.APP %>">Pengumuman User Apps</option>
            <option value="<%= AnnouncementScope.HOLDING %>">Pengumuman Holding</option>
            <option value="<%= AnnouncementScope.BRAND %>">Pengumuman Brand</option>
          </select>
        </label>

        <label class="block hidden" id="announcement-workspace-wrap">
          <span class="text-sm font-medium text-gray-600">Pilih Holding</span>
          <select name="workspaceId" id="announcement-workspace"
            class="mt-1.5 w-full border rounded-2xl px-4 py-3 focus:outline-none focus:border-blue-400 focus:ring-2 focus:ring-blue-100">
            <option value="">Pilih holding...</option>
            <% workspaces.forEach(workspace => { %>
              <option value="<%= workspace.id %>"><%= workspace.name %></option>
            <% }) %>
          </select>
        </label>

        <label class="block hidden md:col-span-2" id="announcement-brand-wrap">
          <span class="text-sm font-medium text-gray-600">Pilih Brand</span>
          <select name="companyId" id="announcement-brand"
            class="mt-1.5 w-full border rounded-2xl px-4 py-3 focus:outline-none focus:border-blue-400 focus:ring-2 focus:ring-blue-100">
            <option value="">Pilih brand...</option>
            <% workspaces.forEach(workspace => { %>
              <% workspace.brands.forEach(brand => { %>
                <option value="<%= brand.id %>"><%= workspace.name %> • <%= brand.name %></option>
              <% }) %>
            <% }) %>
          </select>
        </label>
      </div>

      <textarea name="content" rows="4" required placeholder="Tulis pengumuman untuk target yang dipilih..."
        class="w-full border rounded-2xl px-5 py-3 focus:outline-none focus:border-blue-400 focus:ring-2 focus:ring-blue-100"></textarea>

      <label class="block">
        <span class="text-sm font-medium text-gray-600">Image opsional</span>
        <input type="file" name="image" accept="image/*"
          class="mt-1.5 w-full border rounded-2xl px-4 py-3 text-sm file:mr-4 file:border-0 file:bg-blue-50 file:text-blue-700 file:px-3 file:py-2 file:rounded-xl file:font-semibold">
      </label>

      <div class="flex flex-col sm:flex-row sm:items-center gap-3">
        <button type="submit" class="px-8 py-3 bg-blue-600 hover:bg-blue-700 text-white rounded-2xl font-medium transition">
          <i class="fas fa-paper-plane mr-1.5"></i>Kirim Pengumuman
        </button>
        <p class="text-xs text-gray-400">Notif app dan Telegram hanya dikirim ke target yang dipilih.</p>
      </div>
    </form>
  </div>
  <% } %>

  <div class="space-y-3">
    <% if (announcements.length === 0) { %>
      <div class="bg-white border rounded-3xl p-10 text-center">
        <i class="fas fa-bullhorn text-4xl text-gray-200 mb-3"></i>
        <p class="text-gray-500">Belum ada pengumuman yang relevan untuk kamu.</p>
      </div>
    <% } %>

    <% announcements.forEach(a => { %>
      <div class="bg-white border rounded-2xl p-5">
        <div class="flex flex-wrap items-start justify-between gap-3 mb-3">
          <div class="text-xs text-gray-400">
            <span><%= a.scopeLabel %></span>
            <span>•</span>
            <span><%= a.targetName %></span>
          </div>

          <% if (currentUser.platformRole === 'owner') { %>
            <form action="/announcements/<%= a.id %>/delete" method="POST" onsubmit="return confirm('Hapus pengumuman ini?')">
              <button type="submit" class="inline-flex items-center gap-2 rounded-xl border border-red-200 px-3 py-2 text-xs font-semibold text-red-600 hover:bg-red-50">
                <i class="fas fa-trash-alt"></i> Hapus
              </button>
            </form>
          <% } %>
        </div>

        <% if (a.imageUrl) { %>
          <a href="<%= a.imageUrl %>" target="_blank" rel="noopener noreferrer" class="block mb-4">
            <img src="<%= a.imageUrl %>" alt="<%= a.imageName || 'Image pengumuman' %>" class="w-full max-h-96 object-contain rounded-2xl border bg-gray-50">
          </a>
        <% } %>

        <div class="announcement-content text-gray-800 leading-7 break-words"><%- renderAnnouncementHtml(a.content) %></div>
        <div class="text-xs text-gray-400 mt-3">
          <%= a.createdBy ? a.createdBy.name : 'System' %> • <%= new Date(a.createdAt).toLocaleDateString('id-ID', {day:'numeric',month:'long',year:'numeric',hour:'2-digit',minute:'2-digit'}) %>
        </div>
      </div>
    <% }) %>
  </div>
</div>

<% if (currentUser.platformRole === 'owner') { %>
<script>
  (function() {
    const scopeEl = document.getElementById('announcement-scope');
    const workspaceWrap = document.getElementById('announcement-workspace-wrap');
    const workspaceEl = document.getElementById('announcement-workspace');
    const brandWrap = document.getElementById('announcement-brand-wrap');
    const brandEl = document.getElementById('announcement-brand');

    function syncAnnouncementTarget() {
      const scope = scopeEl.value;
      const isHolding = scope === '<%= AnnouncementScope.HOLDING %>';
      const isBrand = scope === '<%= AnnouncementScope.BRAND %>';

      workspaceWrap.classList.toggle('hidden', !isHolding);
      brandWrap.classList.toggle('hidden', !isBrand);

      workspaceEl.required = isHolding;
      brandEl.required = isBrand;

      if (!isHolding) workspaceEl.value = '';
      if (!isBrand) brandEl.value = '';
    }

    scopeEl.addEventListener('change', syncAnnouncementTarget);
    syncAnnouncementTarget();
  })();
</script>
<% } %>

<%- include('partials/footer') %>
