<%- include('partials/header', { title: 'Tugas Saya' }) %>

<style>
  /* Filter scroll container */
  .filter-scroll {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding-bottom: 4px;
  }

  .filter-scroll::-webkit-scrollbar {
    display: none;
  }

  .filter-scroll > button {
    scroll-snap-align: start;
    flex-shrink: 0;
  }

  /* Active filter pill */
  .filter-pill {
    transition: all 0.2s ease;
  }

  .filter-pill.active {
    background: linear-gradient(135deg, #3b82f6, #1d4ed8);
    color: white;
    border-color: transparent;
    box-shadow: 0 2px 10px rgba(59, 130, 246, 0.3);
  }

  /* Swipe hint arrow */
  .scroll-indicator {
    animation: scrollHint 1.5s ease-in-out infinite;
  }

  @keyframes scrollHint {
    0%, 100% { transform: translateX(0); opacity: 0.5; }
    50% { transform: translateX(5px); opacity: 1; }
  }

  /* Task card styles */
  .task-card-mobile {
    transition: all 0.3s ease;
    touch-action: pan-y;
    position: relative;
    overflow: hidden;
  }

  .task-card-mobile.swiping {
    transition: none;
  }

  /* Swipe action background */
  .swipe-action-bg {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    display: flex;
    align-items: center;
    padding: 0 20px;
    color: white;
    font-weight: 600;
    font-size: 0.875rem;
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .swipe-action-bg.visible {
    opacity: 1;
  }

  /* Haptic feedback simulation */
  .tap-feedback {
    transition: background-color 0.1s ease, transform 0.1s ease;
  }

  .tap-feedback:active {
    background-color: rgba(0, 0, 0, 0.05) !important;
    transform: scale(0.98);
  }

  /* Quick action buttons - larger touch targets */
  .quick-action-btn {
    min-width: 44px;
    min-height: 32px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
  }

  @media (max-width: 767px) {
    .quick-action-btn {
      min-width: 48px;
      min-height: 44px;
      padding: 0.5rem 1rem;
      font-size: 0.8rem;
    }
  }

  .quick-action-btn:active {
    transform: scale(0.95);
  }

  /* Empty state illustration */
  .empty-state {
    position: relative;
    padding: 2rem 1rem;
  }

  .empty-state-icon {
    font-size: 4rem;
    color: #d1d5db;
    animation: float 3s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }

  /* Loading skeleton */
  .skeleton {
    background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
    background-size: 200% 100%;
    animation: shimmer 1.5s infinite;
    border-radius: 8px;
  }

  @keyframes shimmer {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  html.dark .skeleton {
    background: linear-gradient(90deg, #1f2937 25%, #374151 50%, #1f2937 75%);
    background-size: 200% 100%;
  }

  /* Focus states for accessibility */
  button:focus-visible,
  a:focus-visible {
    outline: none;
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.5);
  }

  /* Mobile optimizations */
  @media (max-width: 767px) {
    .stat-card {
      padding: 0.75rem !important;
    }
    .stat-value {
      font-size: 1.25rem !important;
    }
    .stat-label {
      font-size: 0.65rem !important;
    }
    .task-card-content {
      padding: 0.875rem !important;
    }
  }

  /* Progress bar animation */
  .progress-fill {
    transition: width 0.5s ease-out;
  }
</style>

<div class="mb-4 sm:mb-6">
  <h1 class="text-xl sm:text-2xl font-bold text-gray-900">Tugas Saya</h1>
  <p class="text-xs sm:text-sm text-gray-500 mt-1">Semua task yang assigned ke kamu, lintas project</p>
</div>

<!-- Stats -->
<div class="grid grid-cols-2 lg:grid-cols-4 gap-2 sm:gap-4 mb-4 sm:mb-6">
  <div class="bg-white border rounded-xl sm:rounded-2xl p-3 sm:p-4 text-center shadow-sm stat-card tap-feedback">
    <div class="text-xl sm:text-2xl font-bold text-blue-600 stat-value"><%= tasks.filter(t => t.status === 'TODO').length %></div>
    <div class="text-[10px] sm:text-xs text-gray-500 mt-1 stat-label">To Do</div>
  </div>
  <div class="bg-white border rounded-xl sm:rounded-2xl p-3 sm:p-4 text-center shadow-sm stat-card tap-feedback">
    <div class="text-xl sm:text-2xl font-bold text-amber-600 stat-value"><%= tasks.filter(t => t.status === 'IN_PROGRESS').length %></div>
    <div class="text-[10px] sm:text-xs text-gray-500 mt-1 stat-label">Doing</div>
  </div>
  <div class="bg-white border rounded-xl sm:rounded-2xl p-3 sm:p-4 text-center shadow-sm stat-card tap-feedback">
    <div class="text-xl sm:text-2xl font-bold text-emerald-600 stat-value"><%= tasks.filter(t => t.status === 'DONE').length %></div>
    <div class="text-[10px] sm:text-xs text-gray-500 mt-1 stat-label">Done</div>
  </div>
  <div class="bg-white border rounded-xl sm:rounded-2xl p-3 sm:p-4 text-center shadow-sm stat-card tap-feedback">
    <div class="text-xl sm:text-2xl font-bold text-red-600 stat-value"><%= tasks.filter(t => t.dueDate && new Date(t.dueDate) < new Date() && t.status !== 'DONE').length %></div>
    <div class="text-[10px] sm:text-xs text-gray-500 mt-1 stat-label">Overdue</div>
  </div>
</div>

<!-- Filter tabs with horizontal scroll -->
<div class="relative mb-4 sm:mb-5">
  <div class="filter-scroll flex gap-2 md:flex-wrap">
    <button onclick="setMyFilter('ALL')" id="myfilter-ALL" class="filter-pill active px-4 py-2 text-sm rounded-xl border font-medium touch-target">
      Semua
    </button>
    <button onclick="setMyFilter('TODAY')" id="myfilter-TODAY" class="filter-pill px-4 py-2 text-sm rounded-xl border bg-white text-emerald-700 font-medium touch-target">
      📅 Hari Ini
    </button>
    <button onclick="setMyFilter('TODO')" id="myfilter-TODO" class="filter-pill px-4 py-2 text-sm rounded-xl border bg-white touch-target">
      📋 To Do
    </button>
    <button onclick="setMyFilter('IN_PROGRESS')" id="myfilter-IN_PROGRESS" class="filter-pill px-4 py-2 text-sm rounded-xl border bg-white touch-target">
      🔄 Doing
    </button>
    <button onclick="setMyFilter('DONE')" id="myfilter-DONE" class="filter-pill px-4 py-2 text-sm rounded-xl border bg-white touch-target">
      ✅ Done
    </button>
    <button onclick="setMyFilter('OVERDUE')" id="myfilter-OVERDUE" class="filter-pill px-4 py-2 text-sm rounded-xl border bg-white text-red-600 font-medium touch-target">
      ⚠️ Overdue
    </button>
  </div>
  <!-- Scroll indicator for mobile -->
  <div class="scroll-indicator absolute right-0 top-1/2 -translate-y-1/2 bg-gradient-to-l from-gray-50 to-transparent pl-6 pr-2 md:hidden">
    <i class="fas fa-chevron-right text-gray-400 text-sm"></i>
  </div>
</div>

<!-- Task list -->
<div id="my-tasks-list" class="space-y-2 sm:space-y-3">
  <% if (tasks.length === 0) { %>
    <div class="bg-white border rounded-2xl p-8 sm:p-10 text-center empty-state">
      <div class="empty-state-icon mb-4">
        <i class="fas fa-clipboard-check"></i>
      </div>
      <p class="text-gray-600 font-medium mb-2">Belum ada task yang di-assign ke kamu</p>
      <p class="text-gray-400 text-sm">Task baru akan muncul di sini ketika ada yang menugaskanmu</p>
    </div>
  <% } %>
</div>

<script>
const allTasks = <%- JSON.stringify(tasks) %>;
let myFilter = 'ALL';

function setMyFilter(f) {
  myFilter = f;
  document.querySelectorAll('.filter-pill').forEach(btn => {
    btn.classList.remove('active', 'bg-blue-600', 'text-white', 'border-blue-600');
    btn.classList.add('bg-white');
  });
  const active = document.getElementById(`myfilter-${f}`);
  if (active) {
    active.classList.add('active');
    active.classList.remove('bg-white');
    // Scroll active filter into view on mobile
    if (window.innerWidth < 768) {
      active.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
    }
  }
  renderMyTasks();
}

function renderMyTasks() {
  const list = document.getElementById('my-tasks-list');
  let filtered = allTasks;

  if (myFilter === 'OVERDUE') {
    filtered = allTasks.filter(t => t.dueDate && new Date(t.dueDate) < new Date() && t.status !== 'DONE');
  } else if (myFilter === 'TODAY') {
    const todayStr = new Date().toDateString();
    filtered = allTasks.filter(t => t.status !== 'DONE' && t.dueDate && (new Date(t.dueDate).toDateString() === todayStr || new Date(t.dueDate) < new Date()));
  } else if (myFilter !== 'ALL') {
    filtered = allTasks.filter(t => t.status === myFilter);
  }

  if (filtered.length === 0) {
    list.innerHTML = `
      <div class="bg-white border rounded-2xl p-8 sm:p-10 text-center empty-state">
        <div class="empty-state-icon mb-4">
          <i class="fas fa-search"></i>
        </div>
        <p class="text-gray-500 font-medium">Tidak ada task</p>
        <p class="text-gray-400 text-sm mt-1">Tidak ada task yang cocok dengan filter ini</p>
      </div>
    `;
    return;
  }

  const PRIO = { 
    URGENT: { label: '🔴 Urgent', cls: 'bg-red-100 text-red-700' }, 
    HIGH: { label: '🟠 High', cls: 'bg-orange-100 text-orange-700' }, 
    MEDIUM: { label: '🟡 Medium', cls: 'bg-yellow-100 text-yellow-700' }, 
    LOW: { label: '🟢 Low', cls: 'bg-green-100 text-green-700' }, 
    NONE: { label: '', cls: '' } 
  };
  const STATUS = { TODO: '📋 To Do', IN_PROGRESS: '🔄 Doing', DONE: '✅ Done' };

  list.innerHTML = filtered.map(task => {
    const prio = PRIO[task.priority] || PRIO.NONE;
    const isOverdue = task.dueDate && new Date(task.dueDate) < new Date() && task.status !== 'DONE';
    const checklists = task.checklists || [];
    const doneCount = checklists.filter(c => c.isDone).length;
    const pct = checklists.length > 0 ? Math.round(doneCount / checklists.length * 100) : 0;

    // Swipe action color
    const swipeColor = task.status === 'TODO' ? 'bg-amber-500' : task.status === 'IN_PROGRESS' ? 'bg-emerald-500' : '';
    const swipeIcon = task.status === 'TODO' ? 'fa-play' : task.status === 'IN_PROGRESS' ? 'fa-check' : '';

    return `
      <div class="task-card-mobile relative bg-white border rounded-xl sm:rounded-2xl overflow-hidden" data-task-id="${task.id}" data-status="${task.status}">
        <div class="swipe-action-bg ${swipeColor}">
          <i class="fas ${swipeIcon} text-lg"></i>
          <span class="ml-2">${task.status === 'TODO' ? 'Mulai' : 'Selesai'}</span>
        </div>
        <a href="/tasks/${task.id}" class="block task-card-content p-3 sm:p-4 tap-feedback">
          <div class="flex items-start justify-between gap-2 sm:gap-3 mb-2">
            <div class="flex-1 min-w-0">
              <div class="font-semibold text-sm text-gray-900 truncate">${escapeHtml(task.title)}</div>
              <div class="text-xs text-gray-400 mt-0.5 truncate">${escapeHtml(task.project?.name || '')}</div>
            </div>
            <span class="text-[10px] sm:text-xs px-2 py-0.5 rounded-full whitespace-nowrap flex-shrink-0 ${task.status === 'DONE' ? 'bg-emerald-100 text-emerald-700' : task.status === 'IN_PROGRESS' ? 'bg-amber-100 text-amber-700' : 'bg-gray-100 text-gray-600'}">${STATUS[task.status]}</span>
          </div>
          ${checklists.length > 0 ? `
            <div class="flex items-center gap-2 mb-2">
              <div class="flex-1 h-1.5 bg-gray-100 rounded-full overflow-hidden">
                <div class="h-full rounded-full progress-fill ${pct === 100 ? 'bg-emerald-500' : 'bg-blue-500'}" style="width:${pct}%"></div>
              </div>
              <span class="text-[10px] text-gray-400 flex-shrink-0">${doneCount}/${checklists.length}</span>
            </div>
          ` : ''}
          <div class="flex items-center gap-1.5 sm:gap-2 text-xs flex-wrap">
            ${prio.label ? `<span class="px-2 py-0.5 rounded-full font-semibold ${prio.cls}">${prio.label}</span>` : ''}
            ${task.dueDate ? `<span class="${isOverdue ? 'text-red-500 font-semibold' : 'text-gray-400'}"><i class="fas fa-clock mr-0.5"></i>${new Date(task.dueDate).toLocaleDateString('id-ID',{month:'short',day:'numeric'})}</span>` : ''}
            ${task.status !== 'DONE' ? `
              <div class="ml-auto flex gap-1.5">
                ${task.status === 'TODO' ? `<button onclick="event.preventDefault(); event.stopPropagation(); quickMove('${task.id}','IN_PROGRESS')" class="quick-action-btn px-3 py-1.5 bg-amber-100 text-amber-700 rounded-lg text-xs font-semibold hover:bg-amber-200">Mulai</button>` : ''}
                ${task.status === 'IN_PROGRESS' ? `<button onclick="event.preventDefault(); event.stopPropagation(); quickMove('${task.id}','DONE')" class="quick-action-btn px-3 py-1.5 bg-emerald-100 text-emerald-700 rounded-lg text-xs font-semibold hover:bg-emerald-200">Selesai</button>` : ''}
              </div>
            ` : ''}
          </div>
        </a>
      </div>
    `;
  }).join('');

  // Initialize swipe gestures on mobile
  initSwipeGestures();
}

// Swipe gesture handling
function initSwipeGestures() {
  document.querySelectorAll('.task-card-mobile').forEach(card => {
    let startX = 0;
    let currentX = 0;
    let swiping = false;
    const threshold = 80;

    card.addEventListener('touchstart', (e) => {
      startX = e.touches[0].clientX;
      swiping = true;
      card.classList.add('swiping');
    }, { passive: true });

    card.addEventListener('touchmove', (e) => {
      if (!swiping) return;
      currentX = e.touches[0].clientX;
      const diff = startX - currentX;
      
      // Only allow left swipe
      if (diff > 0) {
        const translateX = Math.min(diff, 150);
        card.style.transform = `translateX(-${translateX}px)`;
        
        // Show swipe action background
        const actionBg = card.querySelector('.swipe-action-bg');
        if (actionBg) {
          actionBg.classList.toggle('visible', diff > 40);
        }
      }
    }, { passive: true });

    card.addEventListener('touchend', () => {
      if (!swiping) return;
      swiping = false;
      card.classList.remove('swiping');
      
      const diff = startX - currentX;
      const taskId = card.dataset.taskId;
      const status = card.dataset.status;

      if (diff > threshold && taskId) {
        // Trigger quick move
        if (status === 'TODO') {
          quickMove(taskId, 'IN_PROGRESS');
        } else if (status === 'IN_PROGRESS') {
          quickMove(taskId, 'DONE');
        }
      }

      // Reset position
      card.style.transform = '';
      const actionBg = card.querySelector('.swipe-action-bg');
      if (actionBg) {
        actionBg.classList.remove('visible');
      }
    });

    card.addEventListener('touchcancel', () => {
      swiping = false;
      card.classList.remove('swiping');
      card.style.transform = '';
      const actionBg = card.querySelector('.swipe-action-bg');
      if (actionBg) {
        actionBg.classList.remove('visible');
      }
    });
  });
}

async function quickMove(taskId, newStatus) {
  const task = allTasks.find(t => t.id === taskId);
  if (!task) return;
  const old = task.status;
  task.status = newStatus;
  renderMyTasks();
  try {
    const res = await fetch(`/tasks/${taskId}/status`, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ status: newStatus })
    });
    if (!res.ok) throw new Error('fail');
  } catch (e) {
    task.status = old;
    renderMyTasks();
  }
}

function escapeHtml(v) {
  return String(v || '').replace(/[&<>\"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','\"':'&quot;',"'":'&#039;'}[c]));
}

document.addEventListener('DOMContentLoaded', renderMyTasks);
</script>

<%- include('partials/footer') %>
