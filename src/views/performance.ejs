<%- include('partials/header', { title: 'Dashboard Kinerja' }) %>

<style>
  /* Print-friendly styles */
  @media print {
    .no-print { display: none !important; }
    .print-break { page-break-before: always; }
    body { font-size: 12px; }
    .bg-white { border: 1px solid #e5e7eb; }
  }
  
  /* Chart styles */
  .chart-container {
    display: flex;
    align-items: flex-end;
    gap: 2px;
    height: 200px;
    padding: 10px 0;
  }
  
  .chart-bar {
    flex: 1;
    background: linear-gradient(to top, #3b82f6, #60a5fa);
    border-radius: 4px 4px 0 0;
    min-width: 8px;
    transition: all 0.3s ease;
    position: relative;
  }
  
  .chart-bar:hover {
    opacity: 0.8;
  }
  
  .chart-bar .tooltip {
    display: none;
    position: absolute;
    bottom: 100%;
    left: 50%;
    transform: translateX(-50%);
    background: #1f2937;
    color: white;
    padding: 4px 8px;
    border-radius: 4px;
    font-size: 11px;
    white-space: nowrap;
    z-index: 10;
  }
  
  .chart-bar:hover .tooltip {
    display: block;
  }
  
  .velocity-bar {
    background: linear-gradient(to top, #10b981, #34d399);
  }
  
  .chart-label {
    font-size: 10px;
    color: #6b7280;
    text-align: center;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  
  /* Dark mode support */
  html.dark .chart-bar {
    background: linear-gradient(to top, #2563eb, #3b82f6);
  }
  
  html.dark .velocity-bar {
    background: linear-gradient(to top, #059669, #10b981);
  }
</style>

<div class="mb-6">
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Dashboard Kinerja</h1>
      <p class="text-sm text-gray-500 mt-1">Monitoring performa tim per brand</p>
    </div>
    <div class="flex gap-2 no-print">
      <select id="daysSelect" onchange="changeDays(this.value)" 
        class="px-3 py-2 text-sm border rounded-xl bg-white">
        <option value="7" <%= daysBack === 7 ? 'selected' : '' %>>7 Hari</option>
        <option value="14" <%= daysBack === 14 ? 'selected' : '' %>>14 Hari</option>
        <option value="30" <%= daysBack === 30 ? 'selected' : '' %>>30 Hari</option>
      </select>
      <button onclick="window.print()" class="px-4 py-2 text-sm bg-gray-100 hover:bg-gray-200 rounded-xl">
        <i class="fas fa-print mr-1"></i>Cetak
      </button>
    </div>
  </div>
</div>

<!-- Brand selector -->
<div class="flex gap-2 mb-6 flex-wrap no-print">
  <button onclick="setBrand('ALL')" id="brand-ALL" class="px-4 py-2 text-sm rounded-xl border bg-blue-600 text-white border-blue-600">Semua Brand</button>
  <% brands.forEach(brand => { %>
    <button onclick="setBrand('<%= brand.id %>')" id="brand-<%= brand.id %>" class="px-4 py-2 text-sm rounded-xl border bg-white"><%= brand.name %></button>
  <% }) %>
</div>

<!-- Overall stats -->
<div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
  <div class="bg-white border rounded-2xl p-5 text-center shadow-sm">
    <div class="text-3xl font-bold text-blue-600" id="stat-total"><%= stats.total %></div>
    <div class="text-sm text-gray-500 mt-1">Total Task</div>
  </div>
  <div class="bg-white border rounded-2xl p-5 text-center shadow-sm">
    <div class="text-3xl font-bold text-emerald-600" id="stat-done"><%= stats.done %></div>
    <div class="text-sm text-gray-500 mt-1">Selesai</div>
  </div>
  <div class="bg-white border rounded-2xl p-5 text-center shadow-sm">
    <div class="text-3xl font-bold text-amber-600" id="stat-active"><%= stats.active %></div>
    <div class="text-sm text-gray-500 mt-1">Aktif</div>
  </div>
  <div class="bg-white border rounded-2xl p-5 text-center shadow-sm">
    <div class="text-3xl font-bold text-red-600" id="stat-overdue"><%= stats.overdue %></div>
    <div class="text-sm text-gray-500 mt-1">Overdue</div>
  </div>
</div>

<!-- Charts Section -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
  <!-- Burndown Chart -->
  <div class="bg-white border rounded-2xl p-5 shadow-sm">
    <h3 class="font-semibold text-lg mb-4 flex items-center gap-2">
      <i class="fas fa-fire text-orange-500"></i> Burndown Chart
      <span class="text-xs text-gray-400 font-normal">(Sisa task per hari)</span>
    </h3>
    <div class="chart-container">
      <% const maxBurndown = Math.max(...burndownData.map(d => d.remaining), 1); %>
      <% burndownData.forEach((d, i) => { %>
        <% if (i % Math.ceil(burndownData.length / 7) === 0 || i === burndownData.length - 1) { %>
          <div class="flex flex-col items-center" style="flex: 1;">
            <div class="chart-bar w-full" style="height: <%= (d.remaining / maxBurndown) * 100 %>%">
              <span class="tooltip"><%= d.date %>: <%= d.remaining %> task</span>
            </div>
            <span class="chart-label mt-1"><%= d.date.slice(5) %></span>
          </div>
        <% } else { %>
          <div class="chart-bar" style="height: <%= (d.remaining / maxBurndown) * 100 %>%">
            <span class="tooltip"><%= d.date %>: <%= d.remaining %> task</span>
          </div>
        <% } %>
      <% }) %>
    </div>
  </div>

  <!-- Velocity Chart -->
  <div class="bg-white border rounded-2xl p-5 shadow-sm">
    <h3 class="font-semibold text-lg mb-4 flex items-center gap-2">
      <i class="fas fa-tachometer-alt text-emerald-500"></i> Velocity Chart
      <span class="text-xs text-gray-400 font-normal">(Task selesai per minggu)</span>
    </h3>
    <div class="chart-container">
      <% const maxVelocity = Math.max(...velocityData.map(d => d.count), 1); %>
      <% velocityData.forEach(d => { %>
        <div class="flex flex-col items-center" style="flex: 1;">
          <div class="chart-bar velocity-bar w-full" style="height: <%= (d.count / maxVelocity) * 100 %>%">
            <span class="tooltip"><%= d.week %>: <%= d.count %> task</span>
          </div>
          <span class="chart-label mt-1"><%= d.week.replace('Minggu ', 'M') %></span>
        </div>
      <% }) %>
    </div>
  </div>
</div>

<!-- Per member stats -->
<h2 class="text-lg font-bold mb-4">Performa Per Member</h2>
<div class="space-y-4" id="member-stats">
  <% members.forEach(member => { %>
    <div class="bg-white border rounded-2xl p-5 shadow-sm member-card" data-brand="<%= member.brandId %>">
      <div class="flex items-center gap-4 mb-4">
        <div class="w-10 h-10 bg-blue-600 rounded-full flex items-center justify-center text-white font-bold">
          <%= member.name.charAt(0) %>
        </div>
        <div>
          <div class="font-semibold"><%= member.name %></div>
          <div class="text-xs text-gray-400"><%= member.email %> · <%= member.brandName %></div>
        </div>
        <div class="ml-auto text-right">
          <div class="text-xs text-gray-400">Completion Rate</div>
          <div class="text-lg font-bold <%= member.completionRate >= 80 ? 'text-emerald-600' : member.completionRate >= 50 ? 'text-amber-600' : 'text-red-600' %>">
            <%= member.completionRate %>%
          </div>
        </div>
      </div>

      <!-- Progress bar -->
      <div class="h-2 bg-gray-100 rounded-full overflow-hidden mb-3">
        <div class="h-full rounded-full transition-all <%= member.completionRate >= 80 ? 'bg-emerald-500' : member.completionRate >= 50 ? 'bg-amber-500' : 'bg-red-500' %>" style="width:<%= member.completionRate %>%"></div>
      </div>

      <div class="grid grid-cols-5 gap-3 text-center text-xs">
        <div class="bg-gray-50 rounded-xl p-2">
          <div class="font-bold text-gray-800"><%= member.totalTasks %></div>
          <div class="text-gray-500">Total</div>
        </div>
        <div class="bg-emerald-50 rounded-xl p-2">
          <div class="font-bold text-emerald-700"><%= member.doneTasks %></div>
          <div class="text-emerald-600">Selesai</div>
        </div>
        <div class="bg-amber-50 rounded-xl p-2">
          <div class="font-bold text-amber-700"><%= member.activeTasks %></div>
          <div class="text-amber-600">Aktif</div>
        </div>
        <div class="bg-red-50 rounded-xl p-2">
          <div class="font-bold text-red-700"><%= member.overdueTasks %></div>
          <div class="text-red-600">Overdue</div>
        </div>
        <div class="bg-purple-50 rounded-xl p-2">
          <div class="font-bold text-purple-700"><%= member.overdueRate %>%</div>
          <div class="text-purple-600">Rate</div>
        </div>
      </div>
    </div>
  <% }) %>

  <% if (members.length === 0) { %>
    <div class="bg-white border rounded-2xl p-10 text-center">
      <i class="fas fa-users text-4xl text-gray-200 mb-3"></i>
      <p class="text-gray-500">Belum ada data kinerja</p>
    </div>
  <% } %>
</div>

<!-- Workload per orang -->
<h2 class="text-lg font-bold mb-1 mt-10">Beban Kerja Tim</h2>
<p class="text-sm text-gray-500 mb-4">Jumlah task aktif (belum selesai) saat ini — bukan completion rate. Berguna untuk lihat siapa kebanyakan/kekurangan kerjaan.</p>
<div class="bg-white border rounded-2xl shadow-sm divide-y" id="workload-list">
  <% if (workloadMembers.length === 0) { %>
    <div class="p-10 text-center">
      <i class="fas fa-briefcase text-4xl text-gray-200 mb-3"></i>
      <p class="text-gray-500">Belum ada data</p>
    </div>
  <% } %>
  <% workloadMembers.forEach(member => { %>
    <% const level = member.activeTasks > 6 ? 'red' : member.activeTasks > 3 ? 'amber' : 'emerald'; %>
    <% const levelLabel = { red: 'Berat', amber: 'Sedang', emerald: 'Santai' }[level]; %>
    <div class="flex items-center gap-4 px-5 py-3.5 member-card" data-brand="<%= member.brandId %>">
      <div class="w-9 h-9 bg-blue-600 rounded-full flex items-center justify-center text-white text-sm font-bold shrink-0">
        <%= member.name.charAt(0) %>
      </div>
      <div class="flex-1 min-w-0">
        <div class="text-sm font-semibold truncate"><%= member.name %></div>
        <div class="text-xs text-gray-400 truncate"><%= member.brandName %></div>
      </div>
      <div class="flex-1 max-w-[160px] h-2 bg-gray-100 rounded-full overflow-hidden hidden sm:block">
        <div class="h-full rounded-full bg-<%= level %>-500" style="width:<%= Math.min(100, member.activeTasks * 12) %>%"></div>
      </div>
      <span class="text-xs font-semibold px-2.5 py-1 rounded-full bg-<%= level %>-50 text-<%= level %>-700 whitespace-nowrap">
        <%= member.activeTasks %> task aktif • <%= levelLabel %>
      </span>
    </div>
  <% }) %>
</div>

<!-- Team Activity Log -->
<h2 class="text-lg font-bold mb-4 mt-10">Aktivitas Tim Terbaru</h2>
<div class="bg-white border rounded-2xl shadow-sm overflow-hidden">
  <% if (activityLogs.length === 0) { %>
    <div class="p-10 text-center">
      <i class="fas fa-clock-rotate-left text-4xl text-gray-200 mb-3"></i>
      <p class="text-gray-500">Belum ada aktivitas tercatat</p>
    </div>
  <% } else { %>
    <div class="divide-y max-h-[480px] overflow-y-auto">
      <% activityLogs.forEach(log => { %>
        <div class="flex items-start gap-3 px-5 py-3.5">
          <div class="w-8 h-8 bg-blue-600 rounded-full flex items-center justify-center text-white text-xs font-bold shrink-0 mt-0.5">
            <%= log.actor.charAt(0).toUpperCase() %>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-sm text-gray-700">
              <span class="font-semibold"><%= log.actor %></span>
              <%= log.actionLabel %>
              <%= log.entityLabel %> <span class="font-medium">"<%= log.target %>"</span>
            </p>
            <p class="text-xs text-gray-400 mt-0.5">
              <%= new Date(log.createdAt).toLocaleDateString('id-ID', {day:'numeric',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'}) %>
            </p>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>

<script>
function setBrand(brandId) {
  document.querySelectorAll('[id^="brand-"]').forEach(btn => {
    btn.classList.remove('bg-blue-600','text-white','border-blue-600');
    btn.classList.add('bg-white');
  });
  const active = document.getElementById(`brand-${brandId}`);
  if (active) { active.classList.add('bg-blue-600','text-white','border-blue-600'); active.classList.remove('bg-white'); }

  document.querySelectorAll('.member-card').forEach(card => {
    if (brandId === 'ALL' || card.dataset.brand === brandId) {
      card.style.display = '';
    } else {
      card.style.display = 'none';
    }
  });
}

function changeDays(days) {
  window.location.href = `/performance?days=${days}`;
}
</script>

<%- include('partials/footer') %>
