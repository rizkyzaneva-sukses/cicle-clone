<%- include('partials/header', { title: 'Dashboard Owner' }) %>

<div class="mb-8">
  <h1 class="text-3xl font-bold text-gray-900">Dashboard Owner</h1>
  <p class="text-gray-500 mt-1">Visibilitas penuh semua brand & aktivitas platform</p>
</div>

<!-- Stats Global -->
<div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
  <div class="bg-white border rounded-2xl p-5 text-center shadow-sm">
    <div class="text-3xl font-bold text-blue-600"><%= brands.length %></div>
    <div class="text-sm text-gray-500 mt-1">Total Brand</div>
  </div>
  <div class="bg-white border rounded-2xl p-5 text-center shadow-sm">
    <div class="text-3xl font-bold text-purple-600"><%= totalMembers %></div>
    <div class="text-sm text-gray-500 mt-1">Total Anggota</div>
  </div>
  <div class="bg-white border rounded-2xl p-5 text-center shadow-sm">
    <div class="text-3xl font-bold text-emerald-600"><%= tasksDone %></div>
    <div class="text-sm text-gray-500 mt-1">Task Selesai</div>
  </div>
  <div class="bg-white border rounded-2xl p-5 text-center shadow-sm">
    <div class="text-3xl font-bold text-amber-600"><%= tasksPending %></div>
    <div class="text-sm text-gray-500 mt-1">Task Aktif</div>
  </div>
</div>

<!-- Reset Data -->
<div class="bg-red-50 border border-red-200 rounded-2xl p-5 mb-8">
  <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
    <div>
      <h2 class="text-lg font-bold text-red-700">Reset Data Platform</h2>
      <p class="text-sm text-red-600 mt-1">Hapus semua brand, proyek, task, chat, notifikasi, dan user dummy. Akun yang dipertahankan akan tetap menjadi owner.</p>
    </div>
    <form action="/admin/reset-data" method="POST" class="grid grid-cols-1 sm:grid-cols-[minmax(220px,1fr)_120px_auto] gap-2 w-full lg:w-auto"
      onsubmit="return confirm('Yakin reset semua data platform? Aksi ini tidak bisa dibatalkan.');">
      <input type="email" name="keepEmail" value="<%= currentUser.email %>" required
        class="border border-red-200 rounded-xl px-3 py-2 text-sm focus:outline-none focus:border-red-400"
        aria-label="Email yang dipertahankan">
      <input type="text" name="confirmation" placeholder="RESET" required
        class="border border-red-200 rounded-xl px-3 py-2 text-sm focus:outline-none focus:border-red-400"
        aria-label="Ketik RESET">
      <button type="submit" class="px-4 py-2 bg-red-600 text-white rounded-xl text-sm font-medium hover:bg-red-700 transition">
        Reset Data
      </button>
    </form>
  </div>
</div>

<!-- Semua Brand -->
<div class="flex items-center justify-between mb-4">
  <h2 class="text-xl font-bold">Semua Brand</h2>
  <a href="/brands" class="flex items-center gap-2 px-4 py-2 bg-blue-600 text-white rounded-xl text-sm font-medium hover:bg-blue-700 transition">
    <i class="fas fa-cog"></i> Kelola Brand
  </a>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
  <% if (brands.length === 0) { %>
    <div class="col-span-full bg-white border rounded-3xl p-12 text-center">
      <i class="fas fa-store text-5xl text-gray-200 mb-4"></i>
      <p class="text-gray-500 mb-4">Belum ada brand. Buat brand pertama sekarang.</p>
      <a href="/brands" class="inline-block px-6 py-2.5 bg-blue-600 text-white rounded-xl text-sm font-medium">Buat Brand</a>
    </div>
  <% } %>
  <% brands.forEach(brand => { %>
    <div class="bg-white border rounded-3xl p-6 shadow-sm hover:shadow-md transition">
      <div class="flex items-start justify-between mb-4">
        <div>
          <div class="w-10 h-10 bg-blue-600 rounded-2xl flex items-center justify-center text-white font-bold text-lg mb-3">
            <%= brand.name.charAt(0).toUpperCase() %>
          </div>
          <h3 class="font-bold text-lg"><%= brand.name %></h3>
          <p class="text-xs text-gray-400 mt-0.5">Dibuat <%= new Date(brand.createdAt).toLocaleDateString('id-ID', {day:'numeric',month:'short',year:'numeric'}) %></p>
        </div>
      </div>

      <!-- Stats brand -->
      <div class="grid grid-cols-3 gap-2 mb-4 text-center text-xs">
        <div class="bg-gray-50 rounded-xl p-2">
          <div class="font-bold text-gray-800"><%= brand.projects.length %></div>
          <div class="text-gray-500">Proyek</div>
        </div>
        <div class="bg-gray-50 rounded-xl p-2">
          <div class="font-bold text-gray-800"><%= brand.memberships.length %></div>
          <div class="text-gray-500">Anggota</div>
        </div>
        <div class="bg-gray-50 rounded-xl p-2">
          <div class="font-bold text-gray-800"><%= brand.partnerAccess.length %></div>
          <div class="text-gray-500">Partner</div>
        </div>
      </div>

      <!-- Partner di brand ini -->
      <% if (brand.partnerAccess.length > 0) { %>
        <div class="mb-4">
          <div class="text-xs text-gray-400 font-medium mb-1.5">Partner</div>
          <div class="flex flex-wrap gap-1.5">
            <% brand.partnerAccess.forEach(pa => { %>
              <span class="flex items-center gap-1 bg-purple-50 text-purple-700 text-xs px-2 py-1 rounded-full">
                <div class="w-3.5 h-3.5 bg-purple-600 rounded-full flex items-center justify-center text-white" style="font-size:8px">
                  <%= pa.user.name.charAt(0) %>
                </div>
                <%= pa.user.name.split(' ')[0] %>
              </span>
            <% }) %>
          </div>
        </div>
      <% } %>

      <div class="flex gap-2 pt-3 border-t">
        <a href="/projects?companyId=<%= brand.id %>" class="flex-1 text-center py-2 bg-blue-50 text-blue-700 rounded-xl text-xs font-medium hover:bg-blue-100 transition">
          <i class="fas fa-folder mr-1"></i>Proyek
        </a>
        <a href="/members?companyId=<%= brand.id %>" class="flex-1 text-center py-2 bg-gray-50 text-gray-700 rounded-xl text-xs font-medium hover:bg-gray-100 transition">
          <i class="fas fa-users mr-1"></i>Anggota
        </a>
      </div>
    </div>
  <% }) %>
</div>

<%- include('partials/footer') %>
