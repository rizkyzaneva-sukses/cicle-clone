<%- include('partials/header', { title: 'Dashboard Owner' }) %>
<% const dashboardWorkspaces = typeof workspaces !== 'undefined' ? workspaces : []; %>

<div class="mb-8">
  <h1 class="text-3xl font-bold text-gray-900">Dashboard Owner</h1>
  <p class="text-gray-500 mt-1">Visibilitas penuh semua workspace/holding, brand, dan aktivitas platform</p>
</div>

<!-- Stats Global -->
<div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
  <div class="bg-white border rounded-2xl p-5 text-center shadow-sm">
    <div class="text-3xl font-bold text-blue-600"><%= dashboardWorkspaces.length %></div>
    <div class="text-sm text-gray-500 mt-1">Workspace</div>
  </div>
  <div class="bg-white border rounded-2xl p-5 text-center shadow-sm">
    <div class="text-3xl font-bold text-purple-600"><%= totalMembers %></div>
    <div class="text-sm text-gray-500 mt-1">Total Anggota</div>
  </div>
  <div class="bg-white border rounded-2xl p-5 text-center shadow-sm">
    <div class="text-3xl font-bold text-emerald-600"><%= tasksDone %></div>
    <div class="text-sm text-gray-500 mt-1">Task Selesai</div>
  </div>
  <div class="bg-white border rounded-2xl p-5 text-center shadow-sm">
    <div class="text-3xl font-bold text-amber-600"><%= tasksPending %></div>
    <div class="text-sm text-gray-500 mt-1">Task Aktif</div>
  </div>
</div>

<!-- Semua Workspace -->
<div class="flex items-center justify-between mb-4">
  <h2 class="text-xl font-bold">Workspace / Holding</h2>
  <div class="flex items-center gap-2">
    <a href="/members/holding" class="flex items-center gap-2 px-4 py-2 border rounded-xl text-sm font-medium text-gray-600 hover:bg-gray-50 transition">
      <i class="fas fa-users"></i> Anggota Holding
    </a>
    <a href="/brands" class="flex items-center gap-2 px-4 py-2 bg-blue-600 text-white rounded-xl text-sm font-medium hover:bg-blue-700 transition">
      <i class="fas fa-cog"></i> Kelola Workspace & Brand
    </a>
  </div>
</div>

<div class="space-y-6">
  <% if (dashboardWorkspaces.length === 0) { %>
    <div class="col-span-full bg-white border rounded-3xl p-12 text-center">
      <i class="fas fa-building text-5xl text-gray-200 mb-4"></i>
      <p class="text-gray-500 mb-4">Belum ada workspace. Buat workspace pertama sekarang.</p>
      <a href="/brands" class="inline-block px-6 py-2.5 bg-blue-600 text-white rounded-xl text-sm font-medium">Buat Workspace</a>
    </div>
  <% } %>
  <% dashboardWorkspaces.forEach(workspace => { %>
    <div class="bg-white border rounded-3xl p-6 shadow-sm">
      <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-4 mb-5">
        <div>
          <div class="w-10 h-10 bg-gray-900 rounded-2xl flex items-center justify-center text-white font-bold text-lg mb-3">
            <%= workspace.name.charAt(0).toUpperCase() %>
          </div>
          <h3 class="font-bold text-xl"><%= workspace.name %></h3>
          <p class="text-xs text-gray-400 mt-0.5"><%= workspace.brands.length %> brand • Dibuat <%= new Date(workspace.createdAt).toLocaleDateString('id-ID', {day:'numeric',month:'short',year:'numeric'}) %></p>
        </div>
        <div class="flex flex-wrap gap-1.5">
          <% workspace.partners.forEach(partner => { %>
            <span class="flex items-center gap-1 bg-purple-50 text-purple-700 text-xs px-2 py-1 rounded-full">
              <%= partner.role %>: <%= partner.user.name.split(' ')[0] %>
            </span>
          <% }) %>
        </div>
      </div>

      <% if (workspace.brands.length === 0) { %>
        <div class="bg-gray-50 rounded-2xl p-6 text-center text-sm text-gray-500">Belum ada brand di workspace ini</div>
      <% } else { %>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          <% workspace.brands.forEach(brand => { %>
            <div class="border rounded-2xl p-4">
              <h4 class="font-bold"><%= brand.name %></h4>
              <p class="text-xs text-gray-400 mt-1"><%= brand.projects.length %> proyek • <%= brand.memberships.length %> anggota</p>
              <div class="flex gap-2 pt-3 mt-3 border-t">
                <a href="/projects?companyId=<%= brand.id %>" class="flex-1 text-center py-2 bg-blue-50 text-blue-700 rounded-xl text-xs font-medium hover:bg-blue-100 transition">
                  <i class="fas fa-folder mr-1"></i>Proyek
                </a>
                <a href="/members?companyId=<%= brand.id %>" class="flex-1 text-center py-2 bg-gray-50 text-gray-700 rounded-xl text-xs font-medium hover:bg-gray-100 transition">
                  <i class="fas fa-users mr-1"></i>Anggota
                </a>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  <% }) %>
</div>

<%- include('partials/footer') %>
