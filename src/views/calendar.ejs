<%- include('partials/header', { title: 'Kalender' }) %>

<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-6 gap-4">
  <div>
    <h1 class="text-2xl sm:text-3xl font-bold">Kalender</h1>
    <p class="text-gray-500 mt-1 text-sm">Semua deadline task lintas proyek yang bisa kamu akses.</p>
  </div>
  <div class="flex items-center gap-2">
    <a href="/calendar?month=<%= prevMonthKey %>" class="p-2.5 rounded-xl border hover:bg-gray-50 text-gray-600"><i class="fas fa-chevron-left"></i></a>
    <div class="px-4 py-2.5 rounded-xl border bg-white font-semibold text-sm min-w-[140px] text-center"><%= monthLabel %></div>
    <a href="/calendar?month=<%= nextMonthKey %>" class="p-2.5 rounded-xl border hover:bg-gray-50 text-gray-600"><i class="fas fa-chevron-right"></i></a>
  </div>
</div>

<div class="bg-white border rounded-2xl sm:rounded-3xl overflow-hidden">
  <div class="grid grid-cols-7 bg-gray-50 border-b text-xs sm:text-sm font-semibold text-gray-600">
    <% ['Min','Sen','Sel','Rab','Kam','Jum','Sab'].forEach(d => { %>
      <div class="p-2 sm:p-3 text-center"><%= d %></div>
    <% }) %>
  </div>
  <div class="grid grid-cols-7">
    <% for (let i = 0; i < firstDayOfWeek; i++) { %>
      <div class="border-b border-r min-h-[80px] sm:min-h-[110px] bg-gray-50/50"></div>
    <% } %>
    <% for (let day = 1; day <= daysInMonth; day++) { %>
      <% const dayTasks = tasksByDay[day] || []; %>
      <div class="border-b border-r min-h-[80px] sm:min-h-[110px] p-1.5 sm:p-2 <%= day === todayDate ? 'bg-blue-50' : '' %>">
        <div class="text-xs sm:text-sm font-semibold mb-1 <%= day === todayDate ? 'text-blue-600' : 'text-gray-700' %>"><%= day %></div>
        <div class="space-y-1">
          <% dayTasks.slice(0, 3).forEach(task => { %>
            <a href="/tasks/<%= task.id %>"
               class="block text-[10px] sm:text-xs px-1.5 py-0.5 rounded-md truncate <%= task.status === 'DONE' ? 'bg-emerald-100 text-emerald-700 line-through' : (new Date(task.dueDate) < new Date() ? 'bg-red-100 text-red-700' : 'bg-blue-100 text-blue-700') %>"
               title="<%= task.title %> • <%= task.project.name %>">
              <%= task.title %>
            </a>
          <% }) %>
          <% if (dayTasks.length > 3) { %>
            <div class="text-[10px] text-gray-400 px-1.5">+<%= dayTasks.length - 3 %> lagi</div>
          <% } %>
        </div>
      </div>
    <% } %>
  </div>
</div>

<div class="flex items-center gap-4 mt-4 text-xs text-gray-500 flex-wrap">
  <div class="flex items-center gap-1.5"><span class="w-3 h-3 rounded bg-blue-100 border border-blue-200"></span>Akan datang</div>
  <div class="flex items-center gap-1.5"><span class="w-3 h-3 rounded bg-red-100 border border-red-200"></span>Lewat deadline</div>
  <div class="flex items-center gap-1.5"><span class="w-3 h-3 rounded bg-emerald-100 border border-emerald-200"></span>Selesai</div>
</div>

<%- include('partials/footer') %>
