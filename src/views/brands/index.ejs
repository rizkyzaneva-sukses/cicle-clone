<%- include('../partials/header', { title: 'Kelola Workspace & Brand' }) %>

<div class="mb-8 flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
  <div>
    <h1 class="text-3xl font-bold">Workspace & Brand</h1>
    <p class="text-gray-500 mt-1">Atur holding/workspace, CEO/COO, brand, dan akses tim</p>
  </div>
  <div class="flex flex-col sm:flex-row gap-2">
    <a href="/members/holding"
      class="flex items-center justify-center gap-2 px-5 py-2.5 border rounded-2xl text-sm font-medium text-gray-600 hover:bg-gray-50 transition">
      <i class="fas fa-users"></i> Anggota Holding
    </a>
    <button onclick="document.getElementById('createWorkspaceModal').classList.remove('hidden')"
      class="flex items-center justify-center gap-2 px-5 py-2.5 bg-gray-900 text-white rounded-2xl text-sm font-medium hover:bg-gray-800 transition">
      <i class="fas fa-building"></i> Buat Workspace
    </button>
    <button onclick="document.getElementById('createBrandModal').classList.remove('hidden')"
      class="flex items-center justify-center gap-2 px-5 py-2.5 bg-blue-600 text-white rounded-2xl text-sm font-medium hover:bg-blue-700 transition">
      <i class="fas fa-plus"></i> Buat Brand
    </button>
  </div>
</div>

<% if (!workspaces || workspaces.length === 0) { %>
  <div class="bg-white border rounded-3xl p-16 text-center">
    <i class="fas fa-building text-6xl text-gray-200 mb-4"></i>
    <p class="text-gray-500 text-lg mb-4">Belum ada workspace/holding</p>
    <button onclick="document.getElementById('createWorkspaceModal').classList.remove('hidden')"
      class="px-6 py-2.5 bg-gray-900 text-white rounded-xl text-sm font-medium">Buat Workspace Pertama</button>
  </div>
<% } %>

<div class="space-y-8">
  <% workspaces.forEach(workspace => { %>
    <section class="bg-white border rounded-3xl p-6 shadow-sm">
      <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-5 mb-6">
        <div>
          <div class="flex items-center gap-3">
            <div class="w-12 h-12 bg-gray-900 rounded-2xl flex items-center justify-center text-white font-bold text-xl">
              <%= workspace.name.charAt(0).toUpperCase() %>
            </div>
            <div>
              <h2 class="font-bold text-2xl"><%= workspace.name %></h2>
              <p class="text-xs text-gray-400">Holding / Workspace • <%= workspace.brands.length %> brand</p>
            </div>
          </div>
        </div>

        <form action="/workspaces/<%= workspace.id %>/partners" method="POST" class="grid grid-cols-1 sm:grid-cols-[1fr_90px_auto] gap-2 w-full lg:max-w-xl">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <input type="email" name="email" required placeholder="Email CEO/COO..."
            class="border rounded-xl px-4 py-2 text-sm focus:outline-none focus:border-blue-400">
          <select name="role" class="border rounded-xl px-3 py-2 text-sm focus:outline-none focus:border-blue-400">
            <option value="CEO">CEO</option>
            <option value="COO">COO</option>
          </select>
          <button type="submit" class="px-4 py-2 bg-purple-600 text-white rounded-xl text-sm hover:bg-purple-700 transition">
            Assign
          </button>
        </form>
      </div>

      <div class="mb-5">
        <div class="text-sm font-semibold text-gray-700 mb-2">CEO / COO Workspace</div>
        <% if (workspace.partners.length === 0) { %>
          <p class="text-sm text-gray-400 italic">Belum ada CEO/COO di workspace ini</p>
        <% } else { %>
          <div class="flex flex-wrap gap-2">
            <% workspace.partners.forEach(partner => { %>
              <div class="flex items-center gap-2 bg-purple-50 border border-purple-100 rounded-2xl px-3 py-2">
                <div class="w-7 h-7 bg-purple-600 rounded-full flex items-center justify-center text-white text-xs font-bold">
                  <%= partner.user.name.charAt(0).toUpperCase() %>
                </div>
                <div>
                  <div class="text-sm font-medium text-gray-800"><%= partner.user.name %></div>
                  <div class="text-xs text-gray-400"><%= partner.role %> • <%= partner.user.email %></div>
                </div>
                <form action="/workspaces/<%= workspace.id %>/partners/<%= partner.userId %>/remove" method="POST"
                  onsubmit="return confirm('Cabut akses <%= partner.user.name %> dari workspace ini?')">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button type="submit" class="ml-1 text-red-400 hover:text-red-600 transition p-1" title="Cabut akses">
                    <i class="fas fa-times-circle"></i>
                  </button>
                </form>
              </div>
            <% }) %>
          </div>
        <% } %>
      </div>

      <div class="border-t pt-5">
        <div class="flex items-center justify-between mb-3">
          <h3 class="text-sm font-semibold text-gray-700">Brand di Workspace Ini</h3>
          <button onclick="openBrandModal('<%= workspace.id %>')"
            class="text-xs text-blue-600 hover:underline flex items-center gap-1">
            <i class="fas fa-plus"></i> Tambah Brand
          </button>
        </div>

        <% if (workspace.brands.length === 0) { %>
          <div class="p-8 text-center bg-gray-50 border rounded-2xl">
            <p class="text-gray-500 text-sm">Belum ada brand di workspace ini</p>
          </div>
        <% } else { %>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            <% workspace.brands.forEach(brand => { %>
              <div class="border rounded-2xl p-5 hover:shadow-sm transition">
                <div class="flex items-start justify-between mb-4">
                  <div>
                    <div class="w-12 h-12 bg-blue-600 rounded-2xl flex items-center justify-center text-white font-bold text-lg mb-3 overflow-hidden">
                      <% if (brand.avatar) { %>
                        <img src="<%= brand.avatar %>" alt="Profil <%= brand.name %>" class="w-full h-full object-cover">
                      <% } else { %>
                        <%= brand.name.charAt(0).toUpperCase() %>
                      <% } %>
                    </div>
                    <h4 class="font-bold text-lg"><%= brand.name %></h4>
                    <p class="text-xs text-gray-500 mt-1 min-h-[2.5rem]"><%= brand.description || 'Belum ada deskripsi brand.' %></p>
                    <p class="text-xs text-gray-400"><%= brand.projects.length %> proyek • <%= brand.memberships.length %> anggota</p>
                  </div>
                  <div class="flex items-center gap-2">
                    <button type="button"
                      data-brand="<%- encodeURIComponent(JSON.stringify({ id: brand.id, name: brand.name, description: brand.description || '', avatar: brand.avatar || '' })) %>"
                      onclick="openBrandEditModalFromElement(this)"
                      class="px-3 py-1.5 text-xs border border-blue-200 text-blue-600 rounded-xl hover:bg-blue-50 transition">
                      <i class="fas fa-pen"></i>
                    </button>
                    <form action="/brands/<%= brand.id %>/delete" method="POST"
                      onsubmit="return confirm('Hapus brand <%= brand.name %>? Semua data di dalamnya akan ikut terhapus!')">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                      <button type="submit" class="px-3 py-1.5 text-xs border border-red-200 text-red-500 rounded-xl hover:bg-red-50 transition">
                        <i class="fas fa-trash"></i>
                      </button>
                    </form>
                  </div>
                </div>

                <div class="flex gap-2 pt-3 border-t">
                  <a href="/projects?companyId=<%= brand.id %>" class="flex-1 text-center py-2 bg-blue-50 text-blue-700 rounded-xl text-xs font-medium hover:bg-blue-100 transition">
                    <i class="fas fa-folder mr-1"></i>Proyek
                  </a>
                  <a href="/members?companyId=<%= brand.id %>" class="flex-1 text-center py-2 bg-gray-50 text-gray-700 rounded-xl text-xs font-medium hover:bg-gray-100 transition">
                    <i class="fas fa-users mr-1"></i>Anggota
                  </a>
                  <button onclick="generateInvite('<%= brand.id %>', this)" class="flex-1 text-center py-2 bg-emerald-50 text-emerald-700 rounded-xl text-xs font-medium hover:bg-emerald-100 transition" title="Salin link invite">
                    <i class="fas fa-link mr-1"></i>Invite
                  </button>
                </div>
              </div>
            <% }) %>
          </div>
        <% } %>
      </div>
    </section>
  <% }) %>
</div>

<div id="createWorkspaceModal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50">
  <div class="bg-white rounded-3xl p-8 w-full max-w-md mx-4 shadow-2xl">
    <h3 class="text-2xl font-bold mb-6">Buat Workspace / Holding</h3>
    <form action="/workspaces/create" method="POST">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="mb-5">
        <label class="block text-sm font-medium mb-1.5">Nama Workspace</label>
        <input type="text" name="name" required autofocus placeholder="Contoh: Zaneva Group"
          class="w-full border rounded-2xl px-5 py-3 focus:outline-none focus:border-blue-400">
      </div>
      <div class="flex gap-3">
        <button type="button" onclick="document.getElementById('createWorkspaceModal').classList.add('hidden')"
          class="flex-1 py-3 border rounded-2xl text-gray-600">Batal</button>
        <button type="submit" class="flex-1 py-3 bg-gray-900 text-white rounded-2xl font-medium hover:bg-gray-800">
          Buat
        </button>
      </div>
    </form>
  </div>
</div>

<div id="createBrandModal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50">
  <div class="bg-white rounded-3xl p-8 w-full max-w-md mx-4 shadow-2xl">
    <h3 class="text-2xl font-bold mb-6">Buat Brand Baru</h3>
    <form action="/brands/create" method="POST">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="space-y-5">
        <div>
          <label class="block text-sm font-medium mb-1.5">Workspace / Holding</label>
          <select id="brandWorkspaceSelect" name="workspaceId" required class="w-full border rounded-2xl px-5 py-3 focus:outline-none focus:border-blue-400">
            <% workspaces.forEach(workspace => { %>
              <option value="<%= workspace.id %>"><%= workspace.name %></option>
            <% }) %>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium mb-1.5">Nama Brand</label>
          <input type="text" name="name" required placeholder="Contoh: Zaneva"
            class="w-full border rounded-2xl px-5 py-3 focus:outline-none focus:border-blue-400">
        </div>
        <div>
          <label class="block text-sm font-medium mb-1.5">Deskripsi Brand</label>
          <textarea name="description" rows="3" placeholder="Contoh: Brand untuk tim konten dan campaign marketplace"
            class="w-full border rounded-2xl px-5 py-3 focus:outline-none focus:border-blue-400"></textarea>
        </div>
      </div>
      <div class="flex gap-3 mt-8">
        <button type="button" onclick="document.getElementById('createBrandModal').classList.add('hidden')"
          class="flex-1 py-3 border rounded-2xl text-gray-600">Batal</button>
        <button type="submit" class="flex-1 py-3 bg-blue-600 text-white rounded-2xl font-medium hover:bg-blue-700">
          Buat Brand
        </button>
      </div>
    </form>
  </div>
</div>

<div id="editBrandModal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50" onclick="if(event.target===this) closeBrandEditModal()">
  <div class="bg-white rounded-3xl p-8 w-full max-w-lg mx-4 shadow-2xl">
    <div class="flex items-start justify-between gap-4 mb-6">
      <div>
        <h3 class="text-2xl font-bold">Edit Brand</h3>
        <p class="text-sm text-gray-500 mt-1">Atur nama, deskripsi, dan foto profil brand.</p>
      </div>
      <button type="button" onclick="closeBrandEditModal()" class="p-2 rounded-xl hover:bg-gray-100 text-gray-500">
        <i class="fas fa-times"></i>
      </button>
    </div>

    <div class="flex items-center gap-4 mb-6">
      <div id="brandAvatarPreview" class="w-20 h-20 rounded-[1.5rem] bg-blue-600 text-white flex items-center justify-center text-2xl font-bold overflow-hidden shrink-0">
        B
      </div>
      <div class="flex-1">
        <form id="brandAvatarForm" action="" method="POST" enctype="multipart/form-data" class="flex flex-wrap gap-2 items-center">
          <input id="brandAvatarInput" type="file" name="avatar" accept="image/png,image/jpeg,image/webp,image/gif" class="hidden" onchange="submitBrandAvatarForm()">
          <button type="button" onclick="document.getElementById('brandAvatarInput').click()" class="px-4 py-2 bg-blue-600 text-white rounded-xl text-sm font-medium hover:bg-blue-700 transition">
            Ganti Profil
          </button>
          <button id="brandAvatarDeleteBtn" type="submit" formaction="" formmethod="POST" class="hidden px-4 py-2 border border-red-200 text-red-500 rounded-xl text-sm font-medium hover:bg-red-50 transition"
            onclick="return confirm('Hapus foto profil brand ini?')">
            Hapus Foto
          </button>
        </form>
        <p class="text-xs text-gray-400 mt-2">Maksimal 3 MB. Format PNG, JPG, WebP, atau GIF.</p>
      </div>
    </div>

    <form id="editBrandForm" action="" method="POST">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="space-y-5">
        <div>
          <label class="block text-sm font-medium mb-1.5">Nama Brand</label>
          <input id="editBrandName" type="text" name="name" required class="w-full border rounded-2xl px-5 py-3 focus:outline-none focus:border-blue-400">
        </div>
        <div>
          <label class="block text-sm font-medium mb-1.5">Deskripsi Brand</label>
          <textarea id="editBrandDescription" name="description" rows="4"
            class="w-full border rounded-2xl px-5 py-3 focus:outline-none focus:border-blue-400"
            placeholder="Jelaskan brand ini dipakai untuk apa, tim apa, atau fokus kerjanya."></textarea>
        </div>
      </div>
      <div class="flex gap-3 mt-8">
        <button type="button" onclick="closeBrandEditModal()" class="flex-1 py-3 border rounded-2xl text-gray-600">Batal</button>
        <button type="submit" class="flex-1 py-3 bg-blue-600 text-white rounded-2xl font-medium hover:bg-blue-700">
          Simpan Perubahan
        </button>
      </div>
    </form>
  </div>
</div>

<script>
function openBrandModal(workspaceId) {
  document.getElementById('brandWorkspaceSelect').value = workspaceId;
  document.getElementById('createBrandModal').classList.remove('hidden');
}

function closeBrandEditModal() {
  document.getElementById('editBrandModal').classList.add('hidden');
  document.getElementById('brandAvatarInput').value = '';
}

function renderBrandAvatarPreview(brand) {
  const preview = document.getElementById('brandAvatarPreview');
  if (brand.avatar) {
    preview.innerHTML = `<img src="${brand.avatar}" alt="Profil ${brand.name}" class="w-full h-full object-cover">`;
  } else {
    preview.textContent = (brand.name || 'B').charAt(0).toUpperCase();
  }
}

function openBrandEditModal(brand) {
  document.getElementById('editBrandForm').action = `/brands/${brand.id}/update`;
  document.getElementById('brandAvatarForm').action = `/brands/${brand.id}/avatar`;
  document.getElementById('brandAvatarDeleteBtn').setAttribute('formaction', `/brands/${brand.id}/avatar/delete`);
  document.getElementById('brandAvatarDeleteBtn').classList.toggle('hidden', !brand.avatar);
  document.getElementById('editBrandName').value = brand.name || '';
  document.getElementById('editBrandDescription').value = brand.description || '';
  renderBrandAvatarPreview(brand);
  document.getElementById('editBrandModal').classList.remove('hidden');
}

function openBrandEditModalFromElement(button) {
  openBrandEditModal(JSON.parse(decodeURIComponent(button.dataset.brand)));
}

function submitBrandAvatarForm() {
  const input = document.getElementById('brandAvatarInput');
  if (!input.files || input.files.length === 0) return;
  document.getElementById('brandAvatarForm').submit();
}

async function generateInvite(brandId, btn) {
  const original = btn.innerHTML;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-1"></i>...';
  btn.disabled = true;
  try {
    const res = await fetch(`/invite/brand/${brandId}/generate-token`, { method: 'POST' });
    const data = await res.json();
    if (data.link) {
      await navigator.clipboard.writeText(data.link);
      btn.innerHTML = '<i class="fas fa-check mr-1"></i>Disalin!';
      btn.classList.replace('bg-emerald-50', 'bg-green-100');
      btn.classList.replace('text-emerald-700', 'text-green-700');
      setTimeout(() => {
        btn.innerHTML = original;
        btn.disabled = false;
        btn.classList.replace('bg-green-100', 'bg-emerald-50');
        btn.classList.replace('text-green-700', 'text-emerald-700');
      }, 2500);
    } else {
      alert('Gagal generate link: ' + (data.error || 'unknown'));
      btn.innerHTML = original;
      btn.disabled = false;
    }
  } catch (e) {
    alert('Gagal generate link');
    btn.innerHTML = original;
    btn.disabled = false;
  }
}
</script>

<%- include('../partials/footer') %>
