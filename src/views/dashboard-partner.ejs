<%- include('partials/header', { title: 'Dashboard Partner' }) %>

<div class="mb-8">
  <h1 class="text-3xl font-bold text-gray-900">Dashboard Partner</h1>
  <p class="text-gray-500 mt-1">Workspace dan brand yang kamu kelola</p>
</div>

<% if (typeof workspaceRoles !== 'undefined' && workspaceRoles.length > 0) { %>
  <div class="bg-white border rounded-2xl p-5 mb-8">
    <h2 class="font-bold mb-3">Workspace Kamu</h2>
    <div class="flex flex-wrap gap-2">
      <% workspaceRoles.forEach(access => { %>
        <span class="bg-purple-50 text-purple-700 text-sm px-3 py-1.5 rounded-full">
          <%= access.workspace.name %> • <%= access.role %>
        </span>
      <% }) %>
    </div>
  </div>
<% } %>

<!-- Stats -->
<div class="grid grid-cols-3 gap-4 mb-8">
  <div class="bg-white border rounded-2xl p-5 text-center shadow-sm">
    <div class="text-3xl font-bold text-purple-600"><%= brands.length %></div>
    <div class="text-sm text-gray-500 mt-1">Brand Kamu</div>
  </div>
  <div class="bg-white border rounded-2xl p-5 text-center shadow-sm">
    <div class="text-3xl font-bold text-emerald-600"><%= tasksDone %></div>
    <div class="text-sm text-gray-500 mt-1">Task Selesai</div>
  </div>
  <div class="bg-white border rounded-2xl p-5 text-center shadow-sm">
    <div class="text-3xl font-bold text-amber-600"><%= tasksPending %></div>
    <div class="text-sm text-gray-500 mt-1">Task Aktif</div>
  </div>
</div>

<h2 class="text-xl font-bold mb-4">Brand Kamu</h2>

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
  <% if (brands.length === 0) { %>
    <div class="col-span-full bg-white border rounded-3xl p-12 text-center">
      <i class="fas fa-store text-5xl text-gray-200 mb-4"></i>
      <p class="text-gray-500">Belum ada brand yang di-assign ke kamu. Hubungi Owner.</p>
    </div>
  <% } %>
  <% brands.forEach(brand => { %>
    <div class="bg-white border rounded-3xl p-6 shadow-sm hover:shadow-md transition">
      <div class="w-10 h-10 bg-purple-600 rounded-2xl flex items-center justify-center text-white font-bold text-lg mb-3">
        <%= brand.name.charAt(0).toUpperCase() %>
      </div>
      <h3 class="font-bold text-lg mb-1"><%= brand.name %></h3>
      <div class="grid grid-cols-2 gap-2 mb-4 text-xs text-center">
        <div class="bg-gray-50 rounded-xl p-2">
          <div class="font-bold"><%= brand.projects.length %></div>
          <div class="text-gray-500">Proyek</div>
        </div>
        <div class="bg-gray-50 rounded-xl p-2">
          <div class="font-bold"><%= brand.memberships.length %></div>
          <div class="text-gray-500">Anggota</div>
        </div>
      </div>
      <div class="flex gap-2 pt-3 border-t">
        <a href="/projects?companyId=<%= brand.id %>" class="flex-1 text-center py-2 bg-purple-50 text-purple-700 rounded-xl text-xs font-medium hover:bg-purple-100 transition">
          <i class="fas fa-folder mr-1"></i>Proyek
        </a>
        <a href="/members?companyId=<%= brand.id %>" class="flex-1 text-center py-2 bg-gray-50 text-gray-700 rounded-xl text-xs font-medium hover:bg-gray-100 transition">
          <i class="fas fa-users mr-1"></i>Anggota
        </a>
      </div>
    </div>
  <% }) %>
</div>

<%- include('partials/footer') %>
