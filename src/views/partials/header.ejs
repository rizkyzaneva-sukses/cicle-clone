<script>
// Sidebar toggle (mobile)
function toggleSidebar() {
  const sidebar = document.getElementById('sidebar');
  const overlay = document.getElementById('sidebar-overlay');
  if (!sidebar) return;
  const isOpen = sidebar.classList.contains('open');
  if (isOpen) {
    sidebar.classList.remove('open');
    overlay.classList.remove('open');
    setTimeout(() => overlay.classList.add('hidden'), 300);
  } else {
    overlay.classList.remove('hidden');
    // Force reflow so transition triggers
    overlay.offsetHeight;
    sidebar.classList.add('open');
    overlay.classList.add('open');
  }
}

// ===== Sidebar swipe-to-close (touch gesture) =====
(function initSidebarSwipe() {
  let startX = 0, startY = 0, dx = 0, swiping = false;
  document.addEventListener('touchstart', function(e) {
    const sidebar = document.getElementById('sidebar');
    if (!sidebar || !sidebar.classList.contains('open')) return;
    // Only start swipe from within the sidebar area
    const touch = e.touches[0];
    const rect = sidebar.getBoundingClientRect();
    if (touch.clientX > rect.right) return;
    startX = touch.clientX;
    startY = touch.clientY;
    dx = 0;
    swiping = false;
  }, { passive: true });

  document.addEventListener('touchmove', function(e) {
    const sidebar = document.getElementById('sidebar');
    if (!sidebar || !sidebar.classList.contains('open')) return;
    const touch = e.touches[0];
    const dy = Math.abs(touch.clientY - startY);
    // Only horizontal swipe (dx > dy and threshold)
    if (!swiping && touch.clientX - startX > 10 && dy < 30) {
      swiping = true;
    }
    if (!swiping) return;
    dx = touch.clientX - startX;
    if (dx < 0) dx = 0;
    sidebar.style.transition = 'none';
    sidebar.style.transform = 'translateX(' + dx + 'px)';
  }, { passive: true });

  document.addEventListener('touchend', function() {
    const sidebar = document.getElementById('sidebar');
    if (!sidebar || !swiping) return;
    swiping = false;
    sidebar.style.transition = '';
    sidebar.style.transform = '';
    if (dx > 80) {
      toggleSidebar();
    }
    dx = 0;
  }, { passive: true });
})();

function syncThemeIcon() {
  const icon = document.getElementById('theme-icon');
  if (!icon) return;
  const isDark = document.documentElement.classList.contains('dark');
  icon.className = isDark ? 'fas fa-sun text-lg' : 'fas fa-moon text-lg';
}

function toggleTheme() {
  const root = document.documentElement;
  root.classList.toggle('dark');
  localStorage.setItem('theme', root.classList.contains('dark') ? 'dark' : 'light');
  syncThemeIcon();
}

document.addEventListener('DOMContentLoaded', syncThemeIcon);

// Notification dropdown
let notifLoaded = false;
let currentNotifFilter = 'ALL';
function toggleNotifDropdown() {
  const dd = document.getElementById('notif-dropdown');
  dd.classList.toggle('hidden');
  if (!dd.classList.contains('hidden') && !notifLoaded) loadNotifications();
}

function escapeHtml(value) {
  return String(value || '')
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#039;');
}

function notifTypeMeta(type) {
  if (type === 'PROJECT_TASK') return { label: 'Proyek/Task', dot: 'bg-blue-500' };
  if (type === 'DIRECT_CHAT') return { label: 'Chat Personal', dot: 'bg-emerald-500' };
  return { label: 'Lainnya', dot: 'bg-amber-500' };
}

function setNotifFilter(type) {
  currentNotifFilter = type || 'ALL';
  notifLoaded = false;
  document.querySelectorAll('.notif-tab').forEach((tab) => {
    const isActive = tab.dataset.notifTab === currentNotifFilter;
    tab.classList.toggle('bg-blue-50', isActive);
    tab.classList.toggle('text-blue-700', isActive);
    tab.classList.toggle('text-gray-600', !isActive);
  });
  loadNotifications();
}

function formatBadgeCount(count) {
  return count > 9 ? '9+' : String(count);
}

function setHeaderBadge(selector, count, className, parentSelector) {
  const existing = document.querySelector(selector);
  if (count <= 0) {
    existing?.remove();
    return;
  }

  const badge = existing || document.createElement('span');
  badge.textContent = formatBadgeCount(count);
  if (!existing) {
    badge.id = selector.replace('#', '');
    badge.className = className;
    const parent = document.querySelector(parentSelector);
    parent?.appendChild(badge);
  }
}

async function refreshHeaderUnreadCounts() {
  const res = await fetch('/notifications/counts');
  if (!res.ok) return;
  const counts = await res.json();

  setHeaderBadge(
    '#notif-badge',
    counts.unreadNotifications || 0,
    'absolute top-1 right-1 w-4 h-4 bg-red-500 text-white text-xs rounded-full flex items-center justify-center font-bold',
    '#notif-wrapper button'
  );
  setHeaderBadge(
    '#inbox-badge',
    counts.unreadDirectMessages || 0,
    'absolute top-1 right-1 w-4 h-4 bg-blue-600 text-white text-xs rounded-full flex items-center justify-center font-bold',
    'a[href="/inbox"]'
  );

  const allCount = document.getElementById('notif-count-all');
  const projectCount = document.getElementById('notif-count-project-task');
  const directCount = document.getElementById('notif-count-direct-chat');
  const otherCount = document.getElementById('notif-count-other');
  if (allCount) allCount.textContent = counts.unreadNotifications || 0;
  if (projectCount) projectCount.textContent = counts.unreadNotificationGroups?.PROJECT_TASK || 0;
  if (directCount) directCount.textContent = counts.unreadNotificationGroups?.DIRECT_CHAT || 0;
  if (otherCount) otherCount.textContent = counts.unreadNotificationGroups?.OTHER || 0;
}

async function loadNotifications() {
  notifLoaded = true;
  const params = currentNotifFilter === 'ALL' ? '' : `?type=${encodeURIComponent(currentNotifFilter)}`;
  const res = await fetch(`/notifications${params}`);
  const notifications = await res.json();
  const list = document.getElementById('notif-list');

  if (notifications.length === 0) {
    list.innerHTML = '<div class="text-center text-gray-400 text-sm py-8" id="notif-empty">Tidak ada notifikasi</div>';
    return;
  }

  list.innerHTML = notifications.map(n => {
    const meta = notifTypeMeta(n.type);
    return `
    <a href="${escapeHtml(n.link || '#')}" onclick="return openNotification(event, '${escapeHtml(n.id)}')"
      class="flex items-start gap-3 px-4 py-3 hover:bg-gray-50 border-b last:border-b-0 ${n.isRead ? 'opacity-60' : ''}">
      <div class="w-2 h-2 rounded-full mt-2 shrink-0 ${n.isRead ? 'bg-gray-300' : meta.dot}"></div>
      <div class="flex-1 min-w-0">
        <div class="flex items-center gap-2 mb-0.5">
          <span class="text-[10px] uppercase tracking-wide text-gray-400 font-semibold">${meta.label}</span>
        </div>
        <p class="text-sm ${n.isRead ? 'text-gray-500' : 'text-gray-800 font-medium'}">${escapeHtml(n.content)}</p>
        <p class="text-xs text-gray-400 mt-0.5">${new Date(n.createdAt).toLocaleDateString('id-ID', {day:'numeric',month:'short',hour:'2-digit',minute:'2-digit'})}</p>
      </div>
    </a>
  `;
  }).join('');
}

async function markRead(id) {
  await fetch(`/notifications/${id}/read`, { method: 'POST' });
}

async function openNotification(event, id) {
  event.preventDefault();
  const target = event.currentTarget;
  try {
    await markRead(id);
    notifLoaded = false;
    await refreshHeaderUnreadCounts();
  } catch (error) {
    console.error('Mark notification read failed:', error);
  }
  window.location.href = target.getAttribute('href') || '#';
  return false;
}

async function markAllRead() {
  await fetch('/notifications/read-all', { method: 'POST' });
  await refreshHeaderUnreadCounts();
  notifLoaded = false;
  await loadNotifications();
}

// Close dropdown when clicking outside
document.addEventListener('click', (e) => {
  const wrapper = document.getElementById('notif-wrapper');
  if (wrapper && !wrapper.contains(e.target)) {
    document.getElementById('notif-dropdown')?.classList.add('hidden');
  }
});

// Join personal socket room for real-time notifications
<% if (currentUser) { %>
document.addEventListener('DOMContentLoaded', () => {
  if (typeof io !== 'undefined') {
    const socket = io();
    socket.emit('join-user', '<%= currentUser.id %>');
    socket.on('new-notification', () => {
      notifLoaded = false;
      const badge = document.getElementById('notif-badge');
      if (badge) {
        const count = parseInt(badge.textContent) || 0;
        badge.textContent = count + 1 > 9 ? '9+' : count + 1;
      } else {
        const btn = document.querySelector('#notif-wrapper button');
        if (btn) {
          const b = document.createElement('span');
          b.id = 'notif-badge';
          b.className = 'absolute top-1 right-1 w-4 h-4 bg-red-500 text-white text-xs rounded-full flex items-center justify-center font-bold';
          b.textContent = '1';
          btn.appendChild(b);
        }
      }
    });
    socket.on('new-direct-message', () => {
      const badge = document.getElementById('inbox-badge');
      if (badge) {
        const count = parseInt(badge.textContent) || 0;
        badge.textContent = count + 1 > 9 ? '9+' : count + 1;
      } else {
        const link = document.querySelector('a[href="/inbox"]');
        if (link) {
          const b = document.createElement('span');
          b.id = 'inbox-badge';
          b.className = 'absolute top-1 right-1 w-4 h-4 bg-blue-600 text-white text-xs rounded-full flex items-center justify-center font-bold';
          b.textContent = '1';
          link.appendChild(b);
        }
      }
    });
  }
});

// Desktop push notifications
function urlBase64ToUint8Array(base64String) {
  const padding = '='.repeat((4 - base64String.length % 4) % 4);
  const base64 = (base64String + padding).replace(/-/g, '+').replace(/_/g, '/');
  const rawData = atob(base64);
  return Uint8Array.from([...rawData].map(c => c.charCodeAt(0)));
}

function dismissPushBanner() {
  document.getElementById('push-banner')?.classList.add('hidden');
  localStorage.setItem('pushBannerDismissed', '1');
}

async function getPushConfig() {
  const keyRes = await fetch('/notifications/push/public-key');
  return keyRes.json();
}

async function ensurePushSubscription({ requestPermission = false } = {}) {
  if (!('serviceWorker' in navigator) || !('PushManager' in window)) {
    throw new Error('Browser ini tidak mendukung notifikasi desktop');
  }
  if (typeof Notification === 'undefined') {
    throw new Error('Browser ini tidak mendukung notifikasi desktop');
  }

  const { enabled, publicKey } = await getPushConfig();
  if (!enabled || !publicKey) {
    throw new Error('Notifikasi desktop belum diaktifkan oleh admin platform');
  }

  let permission = Notification.permission;
  if (permission === 'default' && requestPermission) {
    permission = await Notification.requestPermission();
  }
  if (permission !== 'granted') {
    throw new Error('Izin notifikasi desktop belum aktif');
  }

  const reg = await navigator.serviceWorker.register('/sw.js');
  let sub = await reg.pushManager.getSubscription();
  if (!sub) {
    sub = await reg.pushManager.subscribe({
      userVisibleOnly: true,
      applicationServerKey: urlBase64ToUint8Array(publicKey)
    });
  }

  const saveRes = await fetch('/notifications/push/subscribe', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(sub.toJSON())
  });
  if (!saveRes.ok) {
    const data = await saveRes.json().catch(() => ({}));
    throw new Error(data.error || 'Gagal menyimpan subscription notifikasi');
  }

  return sub;
}

async function enablePushNotifications() {
  try {
    await ensurePushSubscription({ requestPermission: true });
    dismissPushBanner();
    await testPushNotification(false);
  } catch (err) {
    console.error('Push subscribe failed:', err);
    alert(err.message || 'Gagal mengaktifkan notifikasi desktop');
  }
}

async function testPushNotification(showSuccessAlert = true) {
  try {
    await ensurePushSubscription({ requestPermission: true });
    const res = await fetch('/notifications/push/test', { method: 'POST' });
    const data = await res.json().catch(() => ({}));
    if (!res.ok) throw new Error(data.error || 'Gagal mengirim notif tes');
    if (showSuccessAlert) alert('Notif tes dikirim. Kalau belum muncul, cek Focus Assist/Do Not Disturb OS.');
  } catch (err) {
    console.error('Push test failed:', err);
    alert(err.message || 'Gagal mengirim notif tes');
  }
}

document.addEventListener('DOMContentLoaded', async () => {
  if (!('serviceWorker' in navigator) || !('PushManager' in window)) return;
  if (typeof Notification === 'undefined') return;
  try {
    const res = await fetch('/notifications/push/public-key');
    const { enabled } = await res.json();
    if (!enabled) return;

    if (Notification.permission === 'granted') {
      await ensurePushSubscription();
      return;
    }

    if (Notification.permission === 'default' && !localStorage.getItem('pushBannerDismissed')) {
      document.getElementById('push-banner')?.classList.remove('hidden');
    }
  } catch (e) {}
});
<% } %>
</script>

