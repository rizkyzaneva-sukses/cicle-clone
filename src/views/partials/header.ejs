<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'Cicle' %> | Task Management</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <style>
    .kanban-column { min-height: 400px; }
    .task-card { transition: all 0.2s ease; }
    .task-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1);
    }
  </style>
</head>
<body class="bg-gray-50">

  <!-- Top Navbar -->
  <header class="fixed top-0 left-0 right-0 h-16 bg-white border-b z-50 flex items-center px-6 gap-4">
    <a href="/" class="flex items-center gap-3 shrink-0">
      <div class="w-9 h-9 bg-blue-600 rounded-xl flex items-center justify-center">
        <i class="fas fa-tasks text-white"></i>
      </div>
      <div>
        <span class="font-bold text-xl text-gray-900">Cicle</span>
        <span class="text-xs text-gray-400 block -mt-0.5">Task Management</span>
      </div>
    </a>

    <div class="ml-auto flex items-center gap-3">
      <% if (currentUser) { %>
        <div class="flex items-center gap-2 text-sm text-gray-700 bg-gray-100 px-3 py-1.5 rounded-full">
          <div class="w-6 h-6 bg-blue-600 rounded-full flex items-center justify-center text-white text-xs font-bold">
            <%= currentUser.name.charAt(0).toUpperCase() %>
          </div>
          <span class="font-medium"><%= currentUser.name %></span>
          <% if (typeof userRole !== 'undefined' && userRole === 'admin') { %>
            <span class="bg-blue-100 text-blue-700 text-xs px-1.5 py-0.5 rounded-full font-semibold">Admin</span>
          <% } %>
        </div>
        <a href="/auth/logout" class="text-sm text-red-500 hover:text-red-700 flex items-center gap-1.5 px-3 py-1.5 hover:bg-red-50 rounded-lg transition">
          <i class="fas fa-sign-out-alt"></i>
          <span>Keluar</span>
        </a>
      <% } %>
    </div>
  </header>

  <div class="flex" style="padding-top:64px; min-height:100vh;">

    <!-- Sidebar (hanya tampil kalau sudah login) -->
    <% if (currentUser) { %>
    <aside class="fixed left-0 top-16 bottom-0 w-56 bg-white border-r z-40 flex flex-col">
      <nav class="flex-1 py-4 px-3 space-y-0.5 overflow-y-auto">

        <a href="/" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-colors
          <%- (currentPath === '/') ? 'bg-blue-600 text-white' : 'text-gray-700 hover:bg-gray-100' %>">
          <i class="fas fa-home w-4 text-center"></i>
          <span>Dashboard</span>
        </a>

        <a href="/projects" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-colors
          <%- (currentPath && currentPath.startsWith('/projects')) ? 'bg-blue-600 text-white' : 'text-gray-700 hover:bg-gray-100' %>">
          <i class="fas fa-folder w-4 text-center"></i>
          <span>Proyek</span>
        </a>

        <a href="/my-tasks" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-colors
          <%- (currentPath && currentPath.startsWith('/my-tasks')) ? 'bg-blue-600 text-white' : 'text-gray-700 hover:bg-gray-100' %>">
          <i class="fas fa-check-square w-4 text-center"></i>
          <span>Tugas Saya</span>
        </a>

        <a href="/members" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-colors
          <%- (currentPath && currentPath.startsWith('/members')) ? 'bg-blue-600 text-white' : 'text-gray-700 hover:bg-gray-100' %>">
          <i class="fas fa-users w-4 text-center"></i>
          <span>Anggota Tim</span>
        </a>

        <div class="pt-3 mt-3 border-t">
          <a href="/panduan" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-colors
            <%- (currentPath && currentPath.startsWith('/panduan')) ? 'bg-blue-600 text-white' : 'text-gray-600 hover:bg-gray-100' %>">
            <i class="fas fa-book w-4 text-center"></i>
            <span>Panduan</span>
          </a>
        </div>
      </nav>

      <!-- Workspace info di bawah sidebar -->
      <% if (typeof currentCompany !== 'undefined' && currentCompany) { %>
      <div class="p-3 border-t">
        <div class="bg-gray-50 rounded-xl px-3 py-2.5">
          <div class="text-xs text-gray-400 font-medium uppercase tracking-wide mb-0.5">Workspace</div>
          <div class="text-sm font-semibold text-gray-800 truncate"><%= currentCompany.name %></div>
        </div>
      </div>
      <% } %>
    </aside>
    <% } %>

    <!-- Main Content -->
    <main class="<%= currentUser ? 'ml-56' : '' %> flex-1 p-8">

      <!-- Flash Messages -->
      <% if (flash && flash.success) { %>
        <div class="mb-6 bg-green-50 border border-green-200 text-green-800 px-4 py-3 rounded-xl flex items-center gap-2">
          <i class="fas fa-check-circle text-green-500"></i>
          <span><%= flash.success %></span>
        </div>
      <% } %>
      <% if (flash && flash.error) { %>
        <div class="mb-6 bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-xl flex items-center gap-2">
          <i class="fas fa-exclamation-circle text-red-500"></i>
          <span><%= flash.error %></span>
        </div>
      <% } %>
