<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'Maulana Corp' %> | Project Management</title>
  <script>
    window.tailwind = window.tailwind || {};
    window.tailwind.config = { darkMode: 'class' };
    (() => {
      const saved = localStorage.getItem('theme');
      const prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
      if (saved === 'dark' || (!saved && prefersDark)) document.documentElement.classList.add('dark');
    })();
  </script>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <% if (typeof currentUser !== 'undefined' && currentUser) { %>
    <script src="https://cdn.socket.io/4.7.5/socket.io.min.js"></script>
    <script src="/js/mention.js"></script>
  <% } %>
  <style>
    html { color-scheme: light; }
    html.dark { color-scheme: dark; }
    .kanban-column { min-height: 400px; }
    .task-card { transition: all 0.2s ease; }
    .task-card:hover { transform: translateY(-2px); box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1); }
    html.dark body,
    html.dark .bg-gray-50 { background-color: #0b1120 !important; }
    html.dark .bg-white { background-color: #111827 !important; }
    html.dark .bg-gray-100 { background-color: #1f2937 !important; }
    html.dark .bg-gray-200 { background-color: #374151 !important; }
    html.dark .bg-blue-50 { background-color: #172554 !important; }
    html.dark .bg-emerald-50 { background-color: #052e2b !important; }
    html.dark .bg-amber-50 { background-color: #3b2f10 !important; }
    html.dark .bg-purple-50 { background-color: #2e1065 !important; }
    html.dark .bg-red-50 { background-color: #3f1111 !important; }
    html.dark .bg-yellow-50 { background-color: #3b2f10 !important; }
    html.dark .bg-teal-50 { background-color: #042f2e !important; }
    html.dark .text-gray-900,
    html.dark .text-gray-800,
    html.dark .text-gray-700 { color: #e5e7eb !important; }
    html.dark .text-gray-600,
    html.dark .text-gray-500 { color: #cbd5e1 !important; }
    html.dark .text-gray-400 { color: #94a3b8 !important; }
    html.dark .border,
    html.dark .border-t,
    html.dark .border-b,
    html.dark .border-r,
    html.dark .divide-y > :not([hidden]) ~ :not([hidden]) { border-color: #334155 !important; }
    html.dark input,
    html.dark textarea,
    html.dark select {
      background-color: #0f172a !important;
      color: #e5e7eb !important;
      border-color: #334155 !important;
    }
    html.dark input::placeholder,
    html.dark textarea::placeholder { color: #64748b !important; }
    html.dark .shadow-sm,
    html.dark .shadow-xl,
    html.dark .shadow-2xl { box-shadow: 0 16px 40px rgb(0 0 0 / 0.35) !important; }
    html.dark .hover\:bg-gray-50:hover,
    html.dark .hover\:bg-gray-100:hover,
    html.dark .hover\:bg-gray-200:hover { background-color: #1e293b !important; }
    html.dark .hover\:bg-blue-50:hover { background-color: #1d4ed8 !important; color: #fff !important; }
    html.dark .task-card:hover { box-shadow: 0 12px 28px rgb(0 0 0 / 0.45); }
    html.dark img { border-color: #334155; }
    @media (max-width: 1023px) {
      #sidebar { transform: translateX(-100%); width: min(18rem, 86vw); }
      #sidebar.open { transform: translateX(0); }
    }
    @media (max-width: 767px) {
      #notif-dropdown { width: calc(100vw - 2rem); right: 0; left: auto; }
      main { padding: 0.75rem !important; }
      .kanban-column { min-height: 200px; }
      .mobile-card-grid { grid-template-columns: 1fr !important; }
      .mobile-scroll-x { overflow-x: auto; -webkit-overflow-scrolling: touch; }
      /* Mobile responsive overrides */
      .mobile-stack { flex-direction: column !important; }
      .mobile-full { width: 100% !important; }
      .mobile-p-3 { padding: 0.75rem !important; }
      .mobile-text-sm { font-size: 0.8rem !important; }
      .mobile-gap-2 { gap: 0.5rem !important; }
      /* Task cards */
      .task-card { padding: 0.75rem !important; font-size: 0.85rem; }
      .task-card .text-xs { font-size: 0.7rem !important; }
      /* Buttons */
      .mobile-btn { padding: 0.5rem 1rem !important; font-size: 0.8rem !important; border-radius: 0.75rem !important; }
      /* Modals */
      .mobile-modal { padding: 1rem !important; margin: 0.5rem !important; border-radius: 1rem !important; max-height: 90vh !important; }
      /* Kanban */
      #kanban-board { gap: 0.75rem !important; }
      #kanban-board > div { min-width: 0; }
      /* Tables / detail */
      .detail-grid { grid-template-columns: 1fr !important; }
      /* Preview panel */
      #preview-panel { max-width: 100% !important; }
      /* Header */
      header { padding: 0 0.75rem !important; }
      header .font-bold.text-xl { font-size: 1rem !important; }
      /* Bulk bar */
      #bulk-bar { flex-wrap: wrap; justify-content: center; padding: 0.75rem 1rem !important; gap: 0.5rem !important; bottom: 1rem !important; width: calc(100% - 2rem); transform: none !important; left: 1rem !important; }
    }

    /* ===== Critical Layout Fallbacks (agar layout tetap benar bila Tailwind CDN gagal load) ===== */
    /* Display (.hidden must be defined LAST so it always wins when combined with e.g. "hidden flex") */
    .block { display: block !important; }
    .inline-block { display: inline-block !important; }
    .inline { display: inline !important; }
    .flex { display: flex !important; }
    .inline-flex { display: inline-flex !important; }
    .grid { display: grid !important; }
    .hidden { display: none !important; }

    /* Position */
    .static { position: static !important; }
    .relative { position: relative !important; }
    .absolute { position: absolute !important; }
    .fixed { position: fixed !important; }
    .sticky { position: sticky !important; }
    .inset-0 { inset: 0 !important; }
    .top-0 { top: 0 !important; }
    .top-1 { top: 0.25rem !important; }
    .top-12 { top: 3rem !important; }
    .top-16 { top: 4rem !important; }
    .right-0 { right: 0 !important; }
    .right-1 { right: 0.25rem !important; }
    .bottom-0 { bottom: 0 !important; }
    .left-0 { left: 0 !important; }

    /* Z-index */
    .z-10 { z-index: 10 !important; }
    .z-20 { z-index: 20 !important; }
    .z-30 { z-index: 30 !important; }
    .z-40 { z-index: 40 !important; }
    .z-50 { z-index: 50 !important; }

    /* Flex utilities */
    .flex-col { flex-direction: column !important; }
    .flex-row { flex-direction: row !important; }
    .flex-wrap { flex-wrap: wrap !important; }
    .flex-1 { flex: 1 1 0% !important; }
    .flex-none { flex: none !important; }
    .shrink-0 { flex-shrink: 0 !important; }
    .grow { flex-grow: 1 !important; }
    .items-start { align-items: flex-start !important; }
    .items-center { align-items: center !important; }
    .items-end { align-items: flex-end !important; }
    .justify-start { justify-content: flex-start !important; }
    .justify-center { justify-content: center !important; }
    .justify-between { justify-content: space-between !important; }
    .justify-end { justify-content: flex-end !important; }

    /* Grid columns */
    .grid-cols-1 { grid-template-columns: repeat(1, minmax(0, 1fr)); }
    .grid-cols-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .grid-cols-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    .grid-cols-4 { grid-template-columns: repeat(4, minmax(0, 1fr)); }
    .grid-cols-5 { grid-template-columns: repeat(5, minmax(0, 1fr)); }
    .grid-cols-6 { grid-template-columns: repeat(6, minmax(0, 1fr)); }
    .col-span-2 { grid-column: span 2 / span 2; }
    .col-span-3 { grid-column: span 3 / span 3; }
    .col-span-full { grid-column: 1 / -1; }

    /* Gap */
    .gap-1 { gap: 0.25rem !important; }
    .gap-2 { gap: 0.5rem !important; }
    .gap-3 { gap: 0.75rem !important; }
    .gap-4 { gap: 1rem !important; }
    .gap-5 { gap: 1.25rem !important; }
    .gap-6 { gap: 1.5rem !important; }
    .gap-8 { gap: 2rem !important; }

    /* Margin & spacing helpers */
    .ml-auto { margin-left: auto !important; }
    .mr-auto { margin-right: auto !important; }
    .min-w-0 { min-width: 0 !important; }

    /* Width / Height */
    .w-full { width: 100% !important; }
    .h-full { height: 100% !important; }
    .min-h-screen { min-height: 100vh !important; }
    .w-56 { width: 14rem !important; }
    .max-w-md { max-width: 28rem !important; }
    .max-w-7xl { max-width: 80rem !important; }

    /* Overflow */
    .overflow-hidden { overflow: hidden !important; }
    .overflow-y-auto { overflow-y: auto !important; }
    .overflow-x-auto { overflow-x: auto !important; }

    /* Responsive sm (640px+) */
    @media (min-width: 640px) {
      .sm\:block { display: block !important; }
      .sm\:inline { display: inline !important; }
      .sm\:inline-flex { display: inline-flex !important; }
      .sm\:flex { display: flex !important; }
      .sm\:grid { display: grid !important; }
      .sm\:grid-cols-2 { grid-template-columns: repeat(2, minmax(0, 1fr)) !important; }
      .sm\:grid-cols-3 { grid-template-columns: repeat(3, minmax(0, 1fr)) !important; }
      .sm\:grid-cols-4 { grid-template-columns: repeat(4, minmax(0, 1fr)) !important; }
      .sm\:hidden { display: none !important; }
    }

    /* Responsive md (768px+) */
    @media (min-width: 768px) {
      .md\:block { display: block !important; }
      .md\:inline { display: inline !important; }
      .md\:inline-flex { display: inline-flex !important; }
      .md\:flex { display: flex !important; }
      .md\:grid { display: grid !important; }
      .md\:grid-cols-2 { grid-template-columns: repeat(2, minmax(0, 1fr)) !important; }
      .md\:grid-cols-3 { grid-template-columns: repeat(3, minmax(0, 1fr)) !important; }
      .md\:grid-cols-4 { grid-template-columns: repeat(4, minmax(0, 1fr)) !important; }
      .md\:hidden { display: none !important; }
    }

    /* Responsive lg (1024px+) */
    @media (min-width: 1024px) {
      .lg\:block { display: block !important; }
      .lg\:inline { display: inline !important; }
      .lg\:inline-flex { display: inline-flex !important; }
      .lg\:flex { display: flex !important; }
      .lg\:grid { display: grid !important; }
      .lg\:grid-cols-2 { grid-template-columns: repeat(2, minmax(0, 1fr)) !important; }
      .lg\:grid-cols-3 { grid-template-columns: repeat(3, minmax(0, 1fr)) !important; }
      .lg\:grid-cols-4 { grid-template-columns: repeat(4, minmax(0, 1fr)) !important; }
      .lg\:col-span-2 { grid-column: span 2 / span 2 !important; }
      .lg\:col-span-3 { grid-column: span 3 / span 3 !important; }
      .lg\:min-w-0 { min-width: 0 !important; }
      .lg\:ml-56 { margin-left: 14rem !important; }
      .lg\:p-8 { padding: 2rem !important; }
      .lg\:px-6 { padding-left: 1.5rem !important; padding-right: 1.5rem !important; }
      .lg\:hidden { display: none !important; }
    }
  </style>
</head>
<body class="bg-gray-50">

  <!-- Top Navbar -->
  <header class="fixed top-0 left-0 right-0 h-16 bg-white border-b z-40 flex items-center px-4 lg:px-6 gap-3">
    <!-- Hamburger (mobile only) -->
    <% if (currentUser) { %>
    <button onclick="toggleSidebar()" class="lg:hidden p-2 rounded-xl hover:bg-gray-100 text-gray-600">
      <i class="fas fa-bars text-lg"></i>
    </button>
    <% } %>

    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5 shrink-0">
      <div class="w-9 h-9 bg-blue-600 rounded-xl flex items-center justify-center">
        <i class="fas fa-tasks text-white text-sm"></i>
      </div>
      <div class="hidden sm:block">
        <span class="font-bold text-xl text-gray-900">Maulana Corp</span>
        <span class="text-xs text-gray-400 block -mt-0.5">Project Management</span>
      </div>
    </a>

    <% if (currentUser) { %>
    <form action="/search" method="GET" class="hidden md:flex ml-4 w-full max-w-md">
      <div class="relative w-full">
        <i class="fas fa-search absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm"></i>
        <input type="search" name="q" placeholder="Cari task, proyek, user..."
          class="w-full bg-gray-100 border border-transparent rounded-2xl pl-9 pr-4 py-2 text-sm focus:outline-none focus:bg-white focus:border-blue-300">
      </div>
    </form>
    <% } %>

    <div class="ml-auto flex items-center gap-2">
      <button type="button" onclick="toggleTheme()" class="p-2 rounded-xl hover:bg-gray-100 text-gray-600 transition" title="Dark mode">
        <i id="theme-icon" class="fas fa-moon text-lg"></i>
      </button>

      <% if (currentUser) { %>

        <!-- Inbox -->
        <a href="/inbox" class="relative p-2 rounded-xl hover:bg-gray-100 text-gray-600" title="Inbox">
          <i class="fas fa-inbox text-lg"></i>
          <% if (unreadDirectMessages > 0) { %>
            <span class="absolute top-1 right-1 w-4 h-4 bg-blue-600 text-white text-xs rounded-full flex items-center justify-center font-bold" id="inbox-badge">
              <%= unreadDirectMessages > 9 ? '9+' : unreadDirectMessages %>
            </span>
          <% } %>
        </a>

        <!-- Notification Bell -->
        <div class="relative z-[60]" id="notif-wrapper">
          <button onclick="toggleNotifDropdown()" class="relative p-2 rounded-xl hover:bg-gray-100 text-gray-600">
            <i class="fas fa-bell text-lg"></i>
            <% if (unreadNotifications > 0) { %>
              <span class="absolute top-1 right-1 w-4 h-4 bg-red-500 text-white text-xs rounded-full flex items-center justify-center font-bold" id="notif-badge">
                <%= unreadNotifications > 9 ? '9+' : unreadNotifications %>
              </span>
            <% } %>
          </button>

          <!-- Notification Dropdown -->
          <div id="notif-dropdown" class="hidden absolute right-0 top-12 w-80 bg-white border shadow-xl rounded-2xl overflow-hidden z-[60]">
            <div class="flex items-center justify-between px-4 py-3 border-b bg-gray-50">
              <span class="font-semibold text-sm">Notifikasi</span>
              <button onclick="markAllRead()" class="text-xs text-blue-600 hover:underline">Tandai semua dibaca</button>
            </div>
            <div id="notif-list" class="max-h-72 overflow-y-auto">
              <div class="text-center text-gray-400 text-sm py-8" id="notif-empty">Memuat...</div>
            </div>
          </div>
        </div>

        <!-- User Avatar + Profile Link -->
        <a href="/profile" class="flex items-center gap-2 text-sm text-gray-700 bg-gray-100 hover:bg-gray-200 px-3 py-1.5 rounded-full transition">
          <div class="w-6 h-6 bg-blue-600 rounded-full flex items-center justify-center text-white text-xs font-bold">
            <%= currentUser.name.charAt(0).toUpperCase() %>
          </div>
          <span class="font-medium hidden sm:inline"><%= currentUser.name.split(' ')[0] %></span>
          <% if (currentUser.platformRole === 'owner') { %>
            <span class="bg-yellow-100 text-yellow-700 text-xs px-1.5 py-0.5 rounded-full font-semibold hidden md:inline">Owner</span>
          <% } else if (currentUser.platformRole === 'partner') { %>
            <span class="bg-purple-100 text-purple-700 text-xs px-1.5 py-0.5 rounded-full font-semibold hidden md:inline">Partner</span>
          <% } else if (userRole === 'admin') { %>
            <span class="bg-blue-100 text-blue-700 text-xs px-1.5 py-0.5 rounded-full font-semibold hidden md:inline">Admin</span>
          <% } %>
        </a>

        <a href="/auth/logout" class="p-2 rounded-xl text-red-500 hover:bg-red-50 transition" title="Keluar">
          <i class="fas fa-sign-out-alt"></i>
        </a>
      <% } %>
    </div>
  </header>

  <!-- Mobile Overlay -->
  <% if (currentUser) { %>
  <div id="sidebar-overlay" class="fixed inset-0 bg-black/40 z-30 hidden lg:hidden" onclick="toggleSidebar()"></div>
  <% } %>

  <div class="flex" style="padding-top:64px; min-height:100vh;">

    <!-- Sidebar -->
    <% if (currentUser) { %>
    <aside id="sidebar" class="fixed left-0 top-16 bottom-0 w-56 bg-white border-r z-40 flex flex-col transition-transform duration-200">
      <nav class="flex-1 py-4 px-3 space-y-0.5 overflow-y-auto">

        <a href="/" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-colors
          <%- (currentPath === '/') ? 'bg-blue-600 text-white' : 'text-gray-700 hover:bg-gray-100' %>">
          <i class="fas fa-home w-4 text-center"></i><span>Dashboard</span>
        </a>

        <!-- Owner: kelola semua brand -->
        <% if (currentUser.platformRole === 'owner') { %>
          <a href="/brands" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-colors
            <%- (currentPath && currentPath.startsWith('/brands')) ? 'bg-blue-600 text-white' : 'text-gray-700 hover:bg-gray-100' %>">
            <i class="fas fa-store w-4 text-center"></i><span>Kelola Brand</span>
          </a>
        <% } %>

        <!-- Partner & Admin/Member: akses proyek -->
        <% if (['partner','user'].includes(currentUser.platformRole) || !currentUser.platformRole) { %>
          <a href="/projects" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-colors
            <%- (currentPath && currentPath.startsWith('/projects')) ? 'bg-blue-600 text-white' : 'text-gray-700 hover:bg-gray-100' %>">
            <i class="fas fa-folder w-4 text-center"></i><span>Proyek</span>
          </a>
        <% } %>

        <!-- Owner juga bisa lihat semua proyek -->
        <% if (currentUser.platformRole === 'owner') { %>
          <a href="/projects" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-colors
            <%- (currentPath && currentPath.startsWith('/projects')) ? 'bg-blue-600 text-white' : 'text-gray-700 hover:bg-gray-100' %>">
            <i class="fas fa-folder w-4 text-center"></i><span>Semua Proyek</span>
          </a>
        <% } %>

        <a href="/my-tasks" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-colors
          <%- (currentPath && currentPath.startsWith('/my-tasks')) ? 'bg-blue-600 text-white' : 'text-gray-700 hover:bg-gray-100' %>">
          <i class="fas fa-check-square w-4 text-center"></i><span>Tugas Saya</span>
        </a>

        <a href="/inbox" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-colors
          <%- (currentPath && currentPath.startsWith('/inbox')) ? 'bg-blue-600 text-white' : 'text-gray-700 hover:bg-gray-100' %>">
          <i class="fas fa-inbox w-4 text-center"></i><span>Inbox</span>
          <% if (unreadDirectMessages > 0) { %>
            <span class="ml-auto bg-blue-100 text-blue-700 text-xs px-2 py-0.5 rounded-full"><%= unreadDirectMessages > 9 ? '9+' : unreadDirectMessages %></span>
          <% } %>
        </a>

        <a href="/reminders" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-colors
          <%- (currentPath && currentPath.startsWith('/reminders')) ? 'bg-blue-600 text-white' : 'text-gray-700 hover:bg-gray-100' %>">
          <i class="fas fa-bell w-4 text-center"></i><span>Reminder</span>
        </a>

        <a href="/performance" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-colors
          <%- (currentPath && currentPath.startsWith('/performance')) ? 'bg-blue-600 text-white' : 'text-gray-700 hover:bg-gray-100' %>">
          <i class="fas fa-chart-bar w-4 text-center"></i><span>Kinerja Tim</span>
        </a>

        <a href="/search" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-colors md:hidden
          <%- (currentPath && currentPath.startsWith('/search')) ? 'bg-blue-600 text-white' : 'text-gray-700 hover:bg-gray-100' %>">
          <i class="fas fa-search w-4 text-center"></i><span>Search</span>
        </a>

        <% if (currentUser.platformRole !== 'owner') { %>
          <a href="/members" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-colors
            <%- (currentPath && currentPath.startsWith('/members')) ? 'bg-blue-600 text-white' : 'text-gray-700 hover:bg-gray-100' %>">
            <i class="fas fa-users w-4 text-center"></i><span>Anggota Tim</span>
          </a>
        <% } %>

        <a href="/profile" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-colors
          <%- (currentPath && currentPath.startsWith('/profile')) ? 'bg-blue-600 text-white' : 'text-gray-700 hover:bg-gray-100' %>">
          <i class="fas fa-user-cog w-4 text-center"></i><span>Profil Saya</span>
        </a>

        <div class="pt-3 mt-3 border-t">
          <a href="/panduan" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-colors
            <%- (currentPath && currentPath.startsWith('/panduan')) ? 'bg-blue-600 text-white' : 'text-gray-600 hover:bg-gray-100' %>">
            <i class="fas fa-book w-4 text-center"></i><span>Panduan</span>
          </a>
        </div>
      </nav>

      <% if (typeof currentCompany !== 'undefined' && currentCompany) { %>
      <div class="p-3 border-t">
        <div class="bg-gray-50 rounded-xl px-3 py-2.5">
          <div class="text-xs text-gray-400 font-medium uppercase tracking-wide mb-0.5">Workspace</div>
          <div class="text-sm font-semibold text-gray-800 truncate"><%= currentCompany.name %></div>
        </div>
      </div>
      <% } %>
    </aside>
    <% } %>

    <!-- Main Content -->
    <main class="<%= currentUser ? 'lg:ml-56' : '' %> flex-1 p-5 lg:p-8">

      <!-- Flash Messages -->
      <% if (flash && flash.success) { %>
        <div class="mb-6 bg-green-50 border border-green-200 text-green-800 px-4 py-3 rounded-xl flex items-center gap-2">
          <i class="fas fa-check-circle text-green-500"></i><span><%= flash.success %></span>
        </div>
      <% } %>
      <% if (flash && flash.error) { %>
        <div class="mb-6 bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-xl flex items-center gap-2">
          <i class="fas fa-exclamation-circle text-red-500"></i><span><%= flash.error %></span>
        </div>
      <% } %>

      <!-- Desktop notification reminder -->
      <% if (currentUser) { %>
      <div id="push-banner" class="hidden mb-6 bg-blue-50 border border-blue-200 text-blue-800 px-4 py-3 rounded-xl flex items-center justify-between gap-3 flex-wrap">
        <div class="flex items-center gap-2">
          <i class="fas fa-bell text-blue-500"></i>
          <span class="text-sm">Aktifkan notifikasi desktop biar nggak ketinggalan chat, tugas baru, dan tag dari tim.</span>
        </div>
        <div class="flex items-center gap-2 shrink-0">
          <button onclick="dismissPushBanner()" class="text-xs text-blue-600 hover:underline px-2 py-1">Nanti aja</button>
          <button onclick="enablePushNotifications()" class="text-xs bg-blue-600 text-white px-3 py-1.5 rounded-lg font-medium hover:bg-blue-700">Aktifkan</button>
        </div>
      </div>
      <% } %>

<script>
// Sidebar toggle (mobile)
function toggleSidebar() {
  const sidebar = document.getElementById('sidebar');
  const overlay = document.getElementById('sidebar-overlay');
  if (!sidebar) return;
  sidebar.classList.toggle('open');
  overlay.classList.toggle('hidden');
}

function syncThemeIcon() {
  const icon = document.getElementById('theme-icon');
  if (!icon) return;
  const isDark = document.documentElement.classList.contains('dark');
  icon.className = isDark ? 'fas fa-sun text-lg' : 'fas fa-moon text-lg';
}

function toggleTheme() {
  const root = document.documentElement;
  root.classList.toggle('dark');
  localStorage.setItem('theme', root.classList.contains('dark') ? 'dark' : 'light');
  syncThemeIcon();
}

document.addEventListener('DOMContentLoaded', syncThemeIcon);

// Notification dropdown
let notifLoaded = false;
function toggleNotifDropdown() {
  const dd = document.getElementById('notif-dropdown');
  dd.classList.toggle('hidden');
  if (!dd.classList.contains('hidden') && !notifLoaded) loadNotifications();
}

async function loadNotifications() {
  notifLoaded = true;
  const res = await fetch('/notifications');
  const notifications = await res.json();
  const list = document.getElementById('notif-list');
  const empty = document.getElementById('notif-empty');

  if (notifications.length === 0) {
    if (empty) empty.textContent = 'Tidak ada notifikasi';
    return;
  }
  if (empty) empty.remove();

  list.innerHTML = notifications.map(n => `
    <a href="${n.link || '#'}" onclick="markRead('${n.id}')"
      class="flex items-start gap-3 px-4 py-3 hover:bg-gray-50 border-b last:border-b-0 ${n.isRead ? 'opacity-60' : ''}">
      <div class="w-2 h-2 rounded-full mt-2 shrink-0 ${n.isRead ? 'bg-gray-300' : 'bg-blue-500'}"></div>
      <div class="flex-1 min-w-0">
        <p class="text-sm ${n.isRead ? 'text-gray-500' : 'text-gray-800 font-medium'}">${n.content}</p>
        <p class="text-xs text-gray-400 mt-0.5">${new Date(n.createdAt).toLocaleDateString('id-ID', {day:'numeric',month:'short',hour:'2-digit',minute:'2-digit'})}</p>
      </div>
    </a>
  `).join('');
}

async function markRead(id) {
  await fetch(`/notifications/${id}/read`, { method: 'POST' });
}

async function markAllRead() {
  await fetch('/notifications/read-all', { method: 'POST' });
  document.getElementById('notif-badge')?.remove();
  await loadNotifications();
}

// Close dropdown when clicking outside
document.addEventListener('click', (e) => {
  const wrapper = document.getElementById('notif-wrapper');
  if (wrapper && !wrapper.contains(e.target)) {
    document.getElementById('notif-dropdown')?.classList.add('hidden');
  }
});

// Join personal socket room for real-time notifications
<% if (currentUser) { %>
document.addEventListener('DOMContentLoaded', () => {
  if (typeof io !== 'undefined') {
    const socket = io();
    socket.emit('join-user', '<%= currentUser.id %>');
    socket.on('new-notification', () => {
      notifLoaded = false;
      const badge = document.getElementById('notif-badge');
      if (badge) {
        const count = parseInt(badge.textContent) || 0;
        badge.textContent = count + 1 > 9 ? '9+' : count + 1;
      } else {
        const btn = document.querySelector('#notif-wrapper button');
        if (btn) {
          const b = document.createElement('span');
          b.id = 'notif-badge';
          b.className = 'absolute top-1 right-1 w-4 h-4 bg-red-500 text-white text-xs rounded-full flex items-center justify-center font-bold';
          b.textContent = '1';
          btn.appendChild(b);
        }
      }
    });
    socket.on('new-direct-message', () => {
      const badge = document.getElementById('inbox-badge');
      if (badge) {
        const count = parseInt(badge.textContent) || 0;
        badge.textContent = count + 1 > 9 ? '9+' : count + 1;
      } else {
        const link = document.querySelector('a[href="/inbox"]');
        if (link) {
          const b = document.createElement('span');
          b.id = 'inbox-badge';
          b.className = 'absolute top-1 right-1 w-4 h-4 bg-blue-600 text-white text-xs rounded-full flex items-center justify-center font-bold';
          b.textContent = '1';
          link.appendChild(b);
        }
      }
    });
  }
});

// Desktop push notifications
function urlBase64ToUint8Array(base64String) {
  const padding = '='.repeat((4 - base64String.length % 4) % 4);
  const base64 = (base64String + padding).replace(/-/g, '+').replace(/_/g, '/');
  const rawData = atob(base64);
  return Uint8Array.from([...rawData].map(c => c.charCodeAt(0)));
}

function dismissPushBanner() {
  document.getElementById('push-banner')?.classList.add('hidden');
  localStorage.setItem('pushBannerDismissed', '1');
}

async function enablePushNotifications() {
  if (!('serviceWorker' in navigator) || !('PushManager' in window)) {
    alert('Browser ini tidak mendukung notifikasi desktop');
    return;
  }
  try {
    const keyRes = await fetch('/notifications/push/public-key');
    const { enabled, publicKey } = await keyRes.json();
    if (!enabled || !publicKey) {
      alert('Notifikasi desktop belum diaktifkan oleh admin platform');
      return;
    }

    const permission = await Notification.requestPermission();
    if (permission !== 'granted') {
      dismissPushBanner();
      return;
    }

    const reg = await navigator.serviceWorker.register('/sw.js');
    let sub = await reg.pushManager.getSubscription();
    if (!sub) {
      sub = await reg.pushManager.subscribe({
        userVisibleOnly: true,
        applicationServerKey: urlBase64ToUint8Array(publicKey)
      });
    }

    await fetch('/notifications/push/subscribe', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(sub.toJSON())
    });

    dismissPushBanner();
  } catch (err) {
    console.error('Push subscribe failed:', err);
  }
}

document.addEventListener('DOMContentLoaded', async () => {
  if (!('serviceWorker' in navigator) || !('PushManager' in window)) return;
  if (typeof Notification === 'undefined' || Notification.permission !== 'default') return;
  if (localStorage.getItem('pushBannerDismissed')) return;

  try {
    const res = await fetch('/notifications/push/public-key');
    const { enabled } = await res.json();
    if (enabled) document.getElementById('push-banner')?.classList.remove('hidden');
  } catch (e) {}
});
<% } %>
</script>
