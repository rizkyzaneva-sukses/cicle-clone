<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'Cicle' %> | Task Management</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <style>
    .kanban-column {
      min-height: 400px;
    }
    .task-card {
      transition: all 0.2s ease;
    }
    .task-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1);
    }
    .nav-active {
      background-color: #1e40af;
      color: white;
    }
  </style>
</head>
<body class="bg-gray-50">
  <!-- Navbar -->
  <nav class="bg-white border-b shadow-sm">
    <div class="max-w-7xl mx-auto px-6">
      <div class="flex justify-between items-center h-16">
        <div class="flex items-center gap-3">
          <div class="w-9 h-9 bg-blue-600 rounded-xl flex items-center justify-center">
            <i class="fas fa-tasks text-white text-xl"></i>
          </div>
          <div>
            <span class="font-bold text-2xl text-gray-900">Cicle</span>
            <span class="text-xs text-gray-500 block -mt-1">by Grok</span>
          </div>
        </div>

        <% if (currentUser) { %>
        <div class="flex items-center gap-4">
          <a href="/panduan" class="text-sm px-4 py-2 hover:bg-gray-100 rounded-full flex items-center gap-1 transition">
            <i class="fas fa-book"></i>
            <span>Panduan</span>
          </a>
          <div class="flex items-center gap-2 bg-gray-100 px-4 py-1.5 rounded-full">
            <i class="fas fa-user text-gray-600"></i>
            <span class="font-medium text-sm"><%= currentUser.name %></span>
          </div>
          <a href="/auth/logout" class="text-sm text-red-600 hover:text-red-700 flex items-center gap-1">
            <i class="fas fa-sign-out-alt"></i>
            <span>Keluar</span>
          </a>
        </div>
        <% } %>
      </div>
    </div>
  </nav>

  <!-- Flash Messages -->
  <% if (flash && flash.success) { %>
    <div class="max-w-7xl mx-auto px-6 mt-4">
      <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded-xl flex items-center gap-2">
        <i class="fas fa-check-circle"></i>
        <span><%= flash.success %></span>
      </div>
    </div>
  <% } %>
  <% if (flash && flash.error) { %>
    <div class="max-w-7xl mx-auto px-6 mt-4">
      <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded-xl flex items-center gap-2">
        <i class="fas fa-exclamation-circle"></i>
        <span><%= flash.error %></span>
      </div>
    </div>
  <% } %>

  <!-- Main Content -->
  <div class="max-w-7xl mx-auto px-6 py-8">
    <%- body %>
  </div>

  <footer class="text-center text-gray-500 text-sm py-8">
    Dibuat dengan ❤️ menggunakan Node.js + Prisma + EasyPanel • Mirip Cicle.app
  </footer>

  <script>
    // Tailwind script
    function initializeTailwind() {
      document.documentElement.style.setProperty('--accent', '#2563eb');
    }
    window.onload = initializeTailwind;
  </script>
</body>
</html>
