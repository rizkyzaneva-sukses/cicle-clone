<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'Maulana Corp' %> | Project Management</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <style>
    .kanban-column {
      min-height: 400px;
    }
    .task-card {
      transition: all 0.2s ease;
    }
    .task-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1);
    }
    .nav-active {
      background-color: #1e40af;
      color: white;
    }

    /* ===== Bottom Tab Bar (Mobile) ===== */
    .bottom-tab-bar {
      display: none;
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      background: rgba(255, 255, 255, 0.85);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-top: 1px solid rgba(0, 0, 0, 0.08);
      z-index: 50;
      padding-bottom: env(safe-area-inset-bottom);
      justify-content: space-around;
      align-items: center;
      height: 3.5rem;
    }
    html.dark .bottom-tab-bar {
      background: rgba(15, 23, 42, 0.88);
      border-top-color: rgba(255, 255, 255, 0.08);
    }
    .bottom-tab {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 2px;
      padding: 6px 0;
      min-width: 48px;
      min-height: 44px;
      color: #6b7280;
      text-decoration: none;
      transition: color 0.15s ease;
      font-size: 0.625rem;
      line-height: 1;
    }
    .bottom-tab i {
      font-size: 1.125rem;
      line-height: 1;
    }
    .bottom-tab.active {
      color: #2563eb;
    }
    html.dark .bottom-tab {
      color: #94a3b8;
    }
    html.dark .bottom-tab.active {
      color: #3b82f6;
    }

    @media (max-width: 1023px) {
      .bottom-tab-bar { display: flex; }
      body { padding-bottom: calc(3.5rem + env(safe-area-inset-bottom, 0px)); }
    }

    /* ===== Better Touch Targets (Mobile) ===== */
    @media (max-width: 1023px) {
      a, button, [role="button"] {
        min-height: 44px;
      }
    }

    /* ===== Smooth Scroll (Mobile) ===== */
    @media (max-width: 1023px) {
      html { scroll-behavior: smooth; }
    }

    /* ===== Bottom Sheet Base Styles (Mobile) ===== */
    @media (max-width: 1023px) {
      .bottom-sheet-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.5);
        z-index: 99;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.3s ease;
      }
      .bottom-sheet-overlay.open {
        opacity: 1;
        pointer-events: auto;
      }
      .bottom-sheet {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        background: white;
        border-radius: 1rem 1rem 0 0;
        z-index: 100;
        transform: translateY(100%);
        transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);
        max-height: 85vh;
        padding-bottom: env(safe-area-inset-bottom);
        overflow-y: auto;
      }
      html.dark .bottom-sheet { background: #111827; }
      .bottom-sheet.open { transform: translateY(0); }
      .bottom-sheet .drag-handle {
        width: 2rem;
        height: 0.25rem;
        background: #d1d5db;
        border-radius: 9999px;
        margin: 0.5rem auto 0;
      }
    }

    /* ===== iOS Rubber-Band Overscroll Prevention ===== */
    @media (max-width: 1023px) {
      .modal-content, .bottom-sheet {
        overscroll-behavior: contain;
      }
    }
    </style>
</head>
<body class="bg-gray-50">
  <!-- Navbar -->
  <nav class="bg-white border-b shadow-sm">
    <div class="max-w-7xl mx-auto px-6">
      <div class="flex justify-between items-center h-16">
        <div class="flex items-center gap-3">
          <div class="w-9 h-9 bg-blue-600 rounded-xl flex items-center justify-center">
            <i class="fas fa-tasks text-white text-xl"></i>
          </div>
          <div>
            <span class="font-bold text-2xl text-gray-900">Maulana Corp</span>
            <span class="text-xs text-gray-500 block -mt-1">Project Management</span>
          </div>
        </div>

        <% if (currentUser) { %>
        <div class="flex items-center gap-4">
          <a href="/panduan" class="text-sm px-4 py-2 hover:bg-gray-100 rounded-full flex items-center gap-1 transition">
            <i class="fas fa-book"></i>
            <span>Panduan</span>
          </a>
          <div class="flex items-center gap-2 bg-gray-100 px-4 py-1.5 rounded-full">
            <i class="fas fa-user text-gray-600"></i>
            <span class="font-medium text-sm"><%= currentUser.name %></span>
          </div>
          <a href="/auth/logout" class="text-sm text-red-600 hover:text-red-700 flex items-center gap-1">
            <i class="fas fa-sign-out-alt"></i>
            <span>Keluar</span>
          </a>
        </div>
        <% } %>
      </div>
    </div>
  </nav>

  <!-- Flash Messages -->
  <% if (flash && flash.success) { %>
    <div class="max-w-7xl mx-auto px-6 mt-4">
      <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded-xl flex items-center gap-2">
        <i class="fas fa-check-circle"></i>
        <span><%= flash.success %></span>
      </div>
    </div>
  <% } %>
  <% if (flash && flash.error) { %>
    <div class="max-w-7xl mx-auto px-6 mt-4">
      <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded-xl flex items-center gap-2">
        <i class="fas fa-exclamation-circle"></i>
        <span><%= flash.error %></span>
      </div>
    </div>
  <% } %>

  <!-- Main Content -->
  <div class="max-w-7xl mx-auto px-6 py-8">
    <%- body %>
  </div>

  <footer class="text-center text-gray-500 text-sm py-8">
    Maulana Corp Project Management • Node.js + Prisma + EasyPanel
  </footer>

  <script>
    // Tailwind script
    function initializeTailwind() {
      document.documentElement.style.setProperty('--accent', '#2563eb');
    }
    window.onload = initializeTailwind;
  </script>

<% if (typeof currentUser !== 'undefined' && currentUser) { %>
<!-- Bottom Tab Bar (Mobile) -->
<nav class="bottom-tab-bar" id="bottom-tab-bar">
  <a href="/" class="bottom-tab <%- currentPath === '/' ? 'active' : '' %>">
    <i class="fas fa-home"></i>
    <span>Dashboard</span>
  </a>
  <a href="/projects" class="bottom-tab <%- (currentPath && currentPath.startsWith('/projects')) ? 'active' : '' %>">
    <i class="fas fa-folder"></i>
    <span>Proyek</span>
  </a>
  <a href="/my-tasks" class="bottom-tab <%- (currentPath && currentPath.startsWith('/my-tasks')) ? 'active' : '' %>">
    <i class="fas fa-check-square"></i>
    <span>Tugas</span>
  </a>
  <a href="/calendar" class="bottom-tab <%- (currentPath && currentPath.startsWith('/calendar')) ? 'active' : '' %>">
    <i class="fas fa-calendar-days"></i>
    <span>Kalender</span>
  </a>
  <a href="/profile" class="bottom-tab <%- (currentPath && currentPath.startsWith('/profile')) ? 'active' : '' %>">
    <i class="fas fa-ellipsis-h"></i>
    <span>Lainnya</span>
  </a>
</nav>
<% } %>
</body>
</html>
