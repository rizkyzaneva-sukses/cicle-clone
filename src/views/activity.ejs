<%- include('partials/header', { title: 'Aktivitas Tim' }) %>

<div class="mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Aktivitas Tim</h1>
  <p class="text-sm text-gray-500 mt-1">Riwayat semua aktivitas di workspace</p>
</div>

<!-- Brand selector -->
<div class="flex gap-2 mb-6 flex-wrap">
  <a href="/activity?brand=ALL" id="brand-ALL"
    class="px-4 py-2 text-sm rounded-xl border transition font-medium
    <%- selectedBrand === 'ALL' ? 'bg-blue-600 text-white border-blue-600' : 'bg-white text-gray-700 hover:bg-gray-50' %>">
    Semua Brand
  </a>
  <% brands.forEach(brand => { %>
    <a href="/activity?brand=<%= brand.id %>" id="brand-<%= brand.id %>"
      class="px-4 py-2 text-sm rounded-xl border transition font-medium
      <%- selectedBrand === brand.id ? 'bg-blue-600 text-white border-blue-600' : 'bg-white text-gray-700 hover:bg-gray-50' %>">
      <%= brand.name %>
    </a>
  <% }) %>
</div>

<!-- Activity Timeline -->
<% const groupNames = Object.keys(activityGroups); %>
<% if (groupNames.length === 0) { %>
  <div class="bg-white border rounded-2xl p-12 text-center shadow-sm">
    <i class="fas fa-clock-rotate-left text-5xl text-gray-200 mb-4"></i>
    <p class="text-gray-500 text-lg">Belum ada aktivitas tercatat</p>
    <p class="text-gray-400 text-sm mt-1">Aktivitas akan muncul di sini setelah ada perubahan di proyek atau tugas.</p>
  </div>
<% } else { %>
  <div class="space-y-8">
    <% groupNames.forEach(groupName => { %>
      <div class="activity-group">
        <div class="flex items-center gap-3 mb-4">
          <div class="h-px flex-1 bg-gray-200"></div>
          <span class="text-xs font-bold text-gray-400 uppercase tracking-wider px-3 py-1 bg-gray-100 rounded-full"><%= groupName %></span>
          <div class="h-px flex-1 bg-gray-200"></div>
        </div>

        <div class="bg-white border rounded-2xl shadow-sm overflow-hidden divide-y">
          <% activityGroups[groupName].forEach(log => { %>
            <div class="flex items-start gap-4 px-5 py-4 hover:bg-gray-50 transition-colors">
              <!-- Avatar -->
              <div class="w-10 h-10 bg-blue-600 rounded-full flex items-center justify-center text-white text-sm font-bold shrink-0">
                <%= log.actor.charAt(0).toUpperCase() %>
              </div>
              <!-- Content -->
              <div class="flex-1 min-w-0">
                <p class="text-sm text-gray-700 leading-relaxed">
                  <span class="font-semibold text-gray-900"><%= log.actor %></span>
                  <span class="text-gray-500"><%= log.actionLabel %></span>
                  <span class="text-gray-500"><%= log.entityLabel %></span>
                  <span class="font-medium text-blue-600">"<%= log.target %>"</span>
                </p>
                <p class="text-xs text-gray-400 mt-1">
                  <i class="far fa-clock mr-1"></i>
                  <%= new Date(log.createdAt).toLocaleDateString('id-ID', { day:'numeric', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit' }) %>
                </p>
              </div>
              <!-- Timestamp relative -->
              <div class="text-xs text-gray-400 shrink-0 whitespace-nowrap">
                <% const diff = Date.now() - new Date(log.createdAt).getTime(); %>
                <% if (diff < 60000) { %><span class="text-emerald-600 font-medium">Baru saja</span>
                <% } else if (diff < 3600000) { %><%= Math.floor(diff/60000) %>m lalu
                <% } else if (diff < 86400000) { %><%= Math.floor(diff/3600000) %>j lalu
                <% } else { %><%= Math.floor(diff/86400000) %>h lalu<% } %>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
    <% }) %>
  </div>

  <!-- Pagination -->
  <% if (totalPages > 1) { %>
    <div class="flex justify-center gap-2 mt-8">
      <% if (currentPage > 1) { %>
        <a href="/activity?brand=<%= selectedBrand %>&page=<%= currentPage - 1 %>"
           class="px-4 py-2 bg-white border rounded-xl text-sm font-medium hover:bg-gray-50 transition">
          <i class="fas fa-chevron-left mr-1"></i> Sebelumnya
        </a>
      <% } %>
      <span class="px-4 py-2 bg-blue-50 text-blue-700 rounded-xl text-sm font-medium">
        Halaman <%= currentPage %> dari <%= totalPages %>
      </span>
      <% if (currentPage < totalPages) { %>
        <a href="/activity?brand=<%= selectedBrand %>&page=<%= currentPage + 1 %>"
           class="px-4 py-2 bg-white border rounded-xl text-sm font-medium hover:bg-gray-50 transition">
          Selanjutnya <i class="fas fa-chevron-right ml-1"></i>
        </a>
      <% } %>
    </div>
  <% } %>

  <p class="text-center text-xs text-gray-400 mt-4">Menampilkan <%= activityGroups[groupNames.reduce((a,b) => [...(activityGroups[a]||[]), ...(activityGroups[b]||[])].length > 0 ? b : a, groupNames[0])].length %> dari <%= totalCount %> aktivitas</p>
<% } %>

<%- include('partials/footer') %>
