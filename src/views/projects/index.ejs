<%- include('../partials/header', { title: 'Proyek Saya' }) %>

<div class="flex flex-col sm:flex-row sm:justify-between sm:items-center mb-8 gap-4">
  <div>
    <h1 class="text-2xl sm:text-3xl font-bold">Semua Proyek</h1>
    <p class="text-sm text-gray-500 mt-1">Project aktif ditampilkan di sini. Kalau semua task selesai, project otomatis pindah ke Arsip.</p>
  </div>

  <div class="flex items-center gap-2 w-full sm:w-auto">
    <% if (currentRole === 'owner' || (manageableCompanyIds || []).length > 0) { %>
      <a href="/projects/archived"
         class="flex items-center justify-center gap-2 px-4 py-3 border rounded-2xl text-gray-600 hover:bg-gray-50 text-sm font-medium">
        <i class="fas fa-box-archive"></i>
        <span>Arsip</span>
      </a>
    <% } %>
    <!-- Create Project Button -->
    <button onclick="showCreateProjectModal()"
            class="flex-1 sm:flex-none justify-center flex items-center gap-2 px-6 py-3 bg-blue-600 text-white rounded-2xl hover:bg-blue-700 text-sm font-medium">
      <i class="fas fa-plus"></i>
      <span>Buat Proyek Baru</span>
    </button>
  </div>
</div>

<% if (memberships && memberships.length > 0) { %>
  <% memberships.forEach(membership => { %>
    <div class="mb-10">
      <div class="flex items-center gap-3 mb-4">
        <div class="font-bold text-xl"><%= membership.company.name %></div>
        <span class="px-3 py-1 text-xs bg-gray-200 text-gray-700 rounded-full"><%= membership.role.toUpperCase() %></span>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        <% if (membership.company.projects && membership.company.projects.length > 0) { %>
          <% membership.company.projects.forEach(project => { %>
            <% const moveTargets = (workspaceBrands || []).filter(brand => brand.workspaceId === membership.company.workspaceId && brand.id !== membership.company.id && (manageableCompanyIds || []).includes(brand.id)); %>
            <div class="group relative bg-white border p-6 rounded-3xl hover:border-blue-300 transition flex flex-col justify-between min-h-[160px]">
              <a href="/projects/<%= project.id %>" class="block">
                <div class="font-bold text-xl group-hover:text-blue-600"><%= project.name %></div>
                <p class="text-sm text-gray-600 mt-2 line-clamp-2"><%= project.description || 'Tidak ada deskripsi' %></p>
              </a>
              <!-- PIC / Project Members -->
              <% const members = project.projectMembers || []; %>
              <% if (members.length > 0) { %>
                <div class="flex items-center gap-1.5 mt-3 pt-3 border-t">
                  <div class="flex -space-x-2">
                    <% members.slice(0, 5).forEach(pm => { %>
                      <div class="w-6 h-6 rounded-full bg-blue-600 border-2 border-white flex items-center justify-center text-white text-[9px] font-bold shrink-0" title="<%= pm.user.name %>">
                        <%= pm.user.name.charAt(0).toUpperCase() %>
                      </div>
                    <% }) %>
                    <% if (members.length > 5) { %>
                      <div class="w-6 h-6 rounded-full bg-gray-300 border-2 border-white flex items-center justify-center text-gray-600 text-[9px] font-bold shrink-0">
                        +<%= members.length - 5 %>
                      </div>
                    <% } %>
                  </div>
                  <span class="text-[10px] text-gray-400 truncate"><%= members.map(m => m.user.name.split(' ')[0]).join(', ') %></span>
                </div>
              <% } %>

              <div class="flex items-center justify-between mt-auto pt-3">
                <% const nextDeadline = project.tasks && project.tasks[0] ? project.tasks[0].dueDate : null; %>
                <% const isOverdue = nextDeadline && new Date(nextDeadline) < new Date(); %>
                <a href="/projects/<%= project.id %>" class="text-xs flex items-center gap-1 <%= isOverdue ? 'text-red-500 font-semibold' : 'text-gray-500' %>">
                  <i class="fas fa-clock"></i>
                  <% if (nextDeadline) { %>
                    <%= isOverdue ? '⚠️ Overdue — ' : '' %><%= new Date(nextDeadline).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                  <% } else { %>
                    Tidak ada deadline
                  <% } %>
                </a>
                <div class="flex items-center gap-1.5">
                  <% if (membership.role !== 'member' && moveTargets.length > 0) { %>
                    <details class="relative">
                      <summary title="Pindah ke brand lain"
                               class="list-none cursor-pointer text-xs text-gray-400 hover:text-blue-600 px-2 py-1 rounded-lg hover:bg-blue-50 transition">
                        <i class="fas fa-right-left"></i>
                      </summary>
                      <form action="/projects/<%= project.id %>/move-brand" method="POST"
                            class="absolute right-0 bottom-full mb-2 w-64 bg-white border rounded-2xl shadow-lg p-3 z-20"
                            onclick="event.stopPropagation()">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <input type="hidden" name="next" value="/projects?companyId=<%= membership.company.id %>">
                        <label class="block text-[11px] font-semibold text-gray-500 mb-2">Pindahkan ke brand lain</label>
                        <select name="targetCompanyId" required class="w-full border rounded-xl px-3 py-2 text-sm mb-3">
                          <option value="">Pilih brand tujuan...</option>
                          <% moveTargets.forEach(target => { %>
                            <option value="<%= target.id %>"><%= target.name %></option>
                          <% }) %>
                        </select>
                        <button type="submit"
                                class="w-full py-2 bg-blue-600 text-white rounded-xl text-sm font-medium hover:bg-blue-700 transition"
                                onclick="return confirm('Pindahkan proyek &quot;<%= project.name %>&quot; ke brand yang dipilih?')">
                          Pindahkan
                        </button>
                      </form>
                    </details>
                  <% } %>
                  <% if (membership.role !== 'member') { %>
                    <form action="/projects/<%= project.id %>/archive" method="POST"
                          onsubmit="return confirm('Arsipkan proyek &quot;<%= project.name %>&quot;? Data tetap tersimpan dan bisa dipulihkan dari Arsip.');">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                      <button type="submit" title="Arsipkan proyek"
                              class="text-xs text-gray-400 hover:text-amber-600 px-2 py-1 rounded-lg hover:bg-amber-50 transition">
                        <i class="fas fa-box-archive"></i>
                      </button>
                    </form>
                  <% } %>
                </div>
              </div>
            </div>
          <% }) %>
        <% } else { %>
          <div class="col-span-full p-8 text-center bg-white border rounded-3xl">
            <p class="text-gray-500">Belum ada proyek di brand ini.</p>
          </div>
        <% } %>
      </div>
    </div>
  <% }) %>
<% } else { %>
  <div class="text-center py-16">
    <i class="fas fa-building text-6xl text-gray-200"></i>
    <p class="mt-4 text-gray-600">Anda belum bergabung dengan perusahaan manapun.</p>
  </div>
<% } %>

<!-- Create Project Modal -->
<div id="createProjectModal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50" style="z-index:9999" onclick="hideCreateProjectModal()">
  <div class="bg-white rounded-3xl p-8 w-full max-w-md mx-4" onclick="event.stopPropagation()">
    <h3 class="font-bold text-2xl mb-6">Buat Proyek Baru</h3>
    
    <form action="/projects/create" method="POST">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="space-y-5">
        <div>
          <label class="block text-sm mb-1.5 font-medium">Nama Proyek</label>
          <input type="text" name="name" required class="w-full border rounded-2xl px-5 py-3.5">
        </div>
        <div>
          <label class="block text-sm mb-1.5 font-medium">Deskripsi (opsional)</label>
          <textarea name="description" rows="3" class="w-full border rounded-2xl px-5 py-3.5"></textarea>
        </div>
        
        <div>
          <label class="block text-sm mb-1.5 font-medium">Pilih Brand</label>
          <select name="companyId" required class="w-full border rounded-2xl px-5 py-3.5">
            <% memberships.forEach(m => { %>
              <option value="<%= m.company.id %>"><%= m.company.name %></option>
            <% }) %>
          </select>
        </div>
      </div>
      
      <div class="flex gap-3 mt-8">
        <button type="button" onclick="hideCreateProjectModal()" class="flex-1 py-3.5 border rounded-2xl hover:bg-gray-100 cursor-pointer">Batal</button>
        <button type="submit" class="flex-1 py-3.5 bg-blue-600 text-white rounded-2xl font-medium">Buat Proyek</button>
      </div>
    </form>
  </div>
</div>

<script>
function showCreateProjectModal() {
  document.getElementById('createProjectModal').classList.remove('hidden');
}
function hideCreateProjectModal() {
  document.getElementById('createProjectModal').classList.add('hidden');
}
</script>
<%- include('../partials/footer') %>
