<%- include('../partials/header', { title: project.name + ' | Gantt' }) %>
<% const canManageProject = currentUser.platformRole === 'owner' || currentUser.platformRole === 'partner' || userRole === 'admin'; %>

<!-- Priority Filter Bar -->
<div class="flex items-center gap-2 mb-5 overflow-x-auto pb-2 lg:flex-wrap" style="-webkit-overflow-scrolling:touch; scrollbar-width:none;">
  <span class="text-sm text-gray-500 font-medium mr-1 shrink-0">Filter:</span>
  <button onclick="setFilter('ALL')" id="filter-ALL"
    class="px-3 py-1.5 text-xs rounded-full border font-medium transition bg-blue-600 text-white border-blue-600 shrink-0">
    Semua
  </button>
  <button onclick="setFilter('URGENT')" id="filter-URGENT"
    class="px-3 py-1.5 text-xs rounded-full border font-medium transition text-red-600 border-red-200 hover:bg-red-50 shrink-0">
    🔴 Urgent
  </button>
  <button onclick="setFilter('HIGH')" id="filter-HIGH"
    class="px-3 py-1.5 text-xs rounded-full border font-medium transition text-orange-600 border-orange-200 hover:bg-orange-50 shrink-0">
    🟠 High
  </button>
  <button onclick="setFilter('MEDIUM')" id="filter-MEDIUM"
    class="px-3 py-1.5 text-xs rounded-full border font-medium transition text-yellow-700 border-yellow-200 hover:bg-yellow-50 shrink-0">
    🟡 Medium
  </button>
  <button onclick="setFilter('LOW')" id="filter-LOW"
    class="px-3 py-1.5 text-xs rounded-full border font-medium transition text-blue-600 border-blue-200 hover:bg-blue-50 shrink-0">
    🔵 Low
  </button>
</div>

<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-6 gap-4">
  <div>
    <a href="/projects/<%= project.id %>" class="text-blue-600 hover:underline text-sm flex items-center gap-1 mb-1">
      <i class="fas fa-arrow-left"></i> Kembali ke Kanban
    </a>
    <h1 class="text-3xl font-bold"><%= project.name %></h1>
    <p class="text-gray-600"><%= project.description || 'Proyek kolaborasi tim' %></p>
  </div>

  <div class="flex items-center gap-2">
    <a href="/projects/<%= project.id %>"
       class="flex items-center gap-1.5 bg-gray-100 hover:bg-gray-200 transition text-gray-700 px-4 py-2.5 rounded-xl text-sm font-medium">
      <i class="fas fa-columns"></i> Kanban
    </a>
    <a href="/projects/<%= project.id %>/gantt"
       class="flex items-center gap-1.5 bg-blue-600 text-white px-4 py-2.5 rounded-xl text-sm font-medium">
      <i class="fas fa-chart-gantt"></i> Gantt
    </a>
  </div>
</div>

<!-- Gantt Chart Container -->
<div class="bg-white rounded-2xl sm:rounded-3xl border shadow-sm overflow-hidden">
  <div class="overflow-x-auto" style="-webkit-overflow-scrolling:touch;">
    <div style="min-width: 900px;">
      <!-- Timeline Header -->
      <div class="flex border-b bg-gray-50 sticky top-0 z-10">
        <!-- Task Name Column -->
        <div class="w-64 shrink-0 px-4 py-3 font-semibold text-sm text-gray-700 border-r">
          Tugas
        </div>
        <!-- Timeline Days -->
        <div id="timeline-header" class="flex flex-1">
          <!-- Generated by JS -->
        </div>
      </div>

      <!-- Task Rows -->
      <div id="gantt-body">
        <!-- Generated by JS -->
      </div>
    </div>
  </div>

  <!-- Empty state -->
  <div id="gantt-empty" class="hidden text-center py-16">
    <div class="text-6xl mb-4">📊</div>
    <h3 class="text-lg font-semibold text-gray-700 mb-2">Belum ada tugas</h3>
    <p class="text-gray-500 text-sm">Buat tugas di view Kanban untuk melihatnya di sini.</p>
  </div>
</div>

<script>
  // Task data from server
  const allTasks = <%- JSON.stringify(project.tasks.map(t => ({
    id: t.id,
    title: t.title,
    status: t.status,
    priority: t.priority,
    createdAt: t.createdAt,
    dueDate: t.dueDate,
    assignees: t.assignees ? t.assignees.map(a => ({ name: a.name })) : []
  }))) %>;

  let currentFilter = 'ALL';
  const DAY_MS = 24 * 60 * 60 * 1000;
  const DAY_WIDTH = 40; // px per day

  function setFilter(filter) {
    currentFilter = filter;
    // Update filter buttons
    document.querySelectorAll('[id^="filter-"]').forEach(btn => {
      const f = btn.id.replace('filter-', '');
      if (f === filter) {
        btn.className = btn.className.replace(/bg-\w+-\d+ text-\w+-\d+ border-\w+-\d+/, 'bg-blue-600 text-white border-blue-600');
      } else {
        btn.className = btn.className.replace(/bg-blue-600 text-white border-blue-600/, 'bg-transparent text-gray-600 border-gray-200 hover:bg-gray-50');
      }
    });
    renderGantt();
  }

  function getPriorityColor(priority) {
    const colors = {
      URGENT: { bg: 'bg-red-500', text: 'text-white' },
      HIGH: { bg: 'bg-orange-500', text: 'text-white' },
      MEDIUM: { bg: 'bg-yellow-400', text: 'text-yellow-900' },
      LOW: { bg: 'bg-blue-400', text: 'text-white' },
      NONE: { bg: 'bg-gray-400', text: 'text-white' }
    };
    return colors[priority] || colors.NONE;
  }

  function getStatusIcon(status) {
    const icons = {
      TODO: '<span class="w-2 h-2 rounded-full bg-gray-400 inline-block"></span>',
      IN_PROGRESS: '<span class="w-2 h-2 rounded-full bg-amber-400 inline-block"></span>',
      DONE: '<span class="w-2 h-2 rounded-full bg-emerald-500 inline-block"></span>'
    };
    return icons[status] || icons.TODO;
  }

  function renderGantt() {
    const filteredTasks = currentFilter === 'ALL'
      ? allTasks
      : allTasks.filter(t => t.priority === currentFilter);

    // Tasks with dueDate
    const tasksWithDates = filteredTasks.filter(t => t.dueDate);
    const tasksWithoutDates = filteredTasks.filter(t => !t.dueDate);

    const ganttBody = document.getElementById('gantt-body');
    const ganttEmpty = document.getElementById('gantt-empty');
    const timelineHeader = document.getElementById('timeline-header');

    if (filteredTasks.length === 0) {
      ganttBody.innerHTML = '';
      ganttEmpty.classList.remove('hidden');
      timelineHeader.innerHTML = '';
      return;
    }

    ganttEmpty.classList.add('hidden');

    // Determine date range
    const now = new Date();
    let minDate = new Date(now);
    let maxDate = new Date(now);

    tasksWithDates.forEach(t => {
      const created = new Date(t.createdAt);
      const due = new Date(t.dueDate);
      if (created < minDate) minDate = new Date(created);
      if (due > maxDate) maxDate = new Date(due);
    });

    // Extend range: 7 days before min, 7 days after max
    minDate.setDate(minDate.getDate() - 7);
    maxDate.setDate(maxDate.getDate() + 14);

    // Normalize to start of day
    minDate.setHours(0, 0, 0, 0);
    maxDate.setHours(0, 0, 0, 0);

    const totalDays = Math.ceil((maxDate - minDate) / DAY_MS) + 1;

    // Generate timeline header (week view)
    let headerHTML = '';
    const tempDate = new Date(minDate);
    for (let i = 0; i < totalDays; i++) {
      const isToday = tempDate.toDateString() === now.toDateString();
      const isWeekend = tempDate.getDay() === 0 || tempDate.getDay() === 6;
      const dayNum = tempDate.getDate();
      const monthNames = ['Jan', 'Feb', 'Mar', 'Apr', 'Mei', 'Jun', 'Jul', 'Agu', 'Sep', 'Okt', 'Nov', 'Des'];
      const showMonth = dayNum === 1 || i === 0;
      const label = showMonth ? `${monthNames[tempDate.getMonth()]} ${dayNum}` : String(dayNum);

      headerHTML += `<div class="shrink-0 text-center py-2 text-[10px] border-r ${isToday ? 'bg-blue-50 text-blue-700 font-bold' : isWeekend ? 'bg-gray-100 text-gray-400' : 'text-gray-500'}" style="width:${DAY_WIDTH}px;">
        ${label}
      </div>`;
      tempDate.setDate(tempDate.getDate() + 1);
    }
    timelineHeader.innerHTML = headerHTML;

    // Render task rows
    let rowsHTML = '';

    tasksWithDates.forEach(task => {
      const created = new Date(task.createdAt);
      const due = new Date(task.dueDate);
      created.setHours(0, 0, 0, 0);
      due.setHours(0, 0, 0, 0);

      const startOffset = Math.max(0, Math.ceil((created - minDate) / DAY_MS));
      const duration = Math.max(1, Math.ceil((due - created) / DAY_MS) + 1);
      const colors = getPriorityColor(task.priority);

      rowsHTML += `<div class="flex border-b hover:bg-gray-50 transition-colors">
        <div class="w-64 shrink-0 px-4 py-3 border-r flex items-center gap-2 min-h-[48px]">
          ${getStatusIcon(task.status)}
          <div class="min-w-0 flex-1">
            <a href="/tasks/${task.id}" class="text-sm font-medium text-gray-800 hover:text-blue-600 truncate block">${task.title}</a>
            ${task.assignees && task.assignees.length > 0 ? `<div class="text-[10px] text-gray-400 truncate">${task.assignees.map(a => a.name).join(', ')}</div>` : ''}
          </div>
        </div>
        <div class="flex-1 relative py-2" style="min-height:48px;">
          <div class="absolute top-1/2 -translate-y-1/2 ${colors.bg} ${colors.text} rounded-md px-2 py-1 text-[10px] font-medium truncate cursor-pointer shadow-sm hover:shadow-md transition-shadow"
               style="left:${startOffset * DAY_WIDTH}px; width:${Math.max(duration * DAY_WIDTH - 4, 20)}px;"
               title="${task.title}: ${new Date(task.createdAt).toLocaleDateString('id-ID')} - ${new Date(task.dueDate).toLocaleDateString('id-ID')}"
               onclick="window.location='/tasks/${task.id}'">
            ${task.title}
          </div>
        </div>
      </div>`;
    });

    // Tasks without dates (shown at bottom)
    if (tasksWithoutDates.length > 0) {
      rowsHTML += `<div class="flex border-b bg-gray-50/50">
        <div class="w-64 shrink-0 px-4 py-2 border-r">
          <span class="text-xs text-gray-400 font-medium">Tanpa Deadline</span>
        </div>
        <div class="flex-1 py-2 text-xs text-gray-400 italic px-4">
          ${tasksWithoutDates.length} tugas tanpa deadline
        </div>
      </div>`;

      tasksWithoutDates.forEach(task => {
        rowsHTML += `<div class="flex border-b hover:bg-gray-50 transition-colors">
          <div class="w-64 shrink-0 px-4 py-3 border-r pl-8 flex items-center gap-2 min-h-[48px]">
            ${getStatusIcon(task.status)}
            <a href="/tasks/${task.id}" class="text-sm text-gray-600 hover:text-blue-600 truncate">${task.title}</a>
          </div>
          <div class="flex-1 py-3 text-xs text-gray-400 italic px-4">
            Belum ada deadline
          </div>
        </div>`;
      });
    }

    ganttBody.innerHTML = rowsHTML;

    // Scroll to today
    const todayOffset = Math.ceil((new Date(now).setHours(0,0,0,0) - minDate.getTime()) / DAY_MS);
    const container = document.querySelector('.overflow-x-auto');
    if (container && todayOffset > 0) {
      const scrollTo = Math.max(0, (todayOffset - 5) * DAY_WIDTH);
      container.scrollLeft = scrollTo;
    }
  }

  // Initial render
  renderGantt();
</script>

<%- include('../partials/footer') %>
