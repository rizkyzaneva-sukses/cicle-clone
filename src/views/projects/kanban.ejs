<%- include('../partials/header', { title: project.name + ' | Kanban' }) %>

<!-- Priority Filter Bar -->
<div class="flex items-center gap-2 mb-5 flex-wrap">
  <span class="text-sm text-gray-500 font-medium mr-1">Filter:</span>
  <button onclick="setFilter('ALL')" id="filter-ALL"
    class="px-3 py-1.5 text-xs rounded-full border font-medium transition bg-blue-600 text-white border-blue-600">
    Semua
  </button>
  <button onclick="setFilter('URGENT')" id="filter-URGENT"
    class="px-3 py-1.5 text-xs rounded-full border font-medium transition text-red-600 border-red-200 hover:bg-red-50">
    🔴 Urgent
  </button>
  <button onclick="setFilter('HIGH')" id="filter-HIGH"
    class="px-3 py-1.5 text-xs rounded-full border font-medium transition text-orange-600 border-orange-200 hover:bg-orange-50">
    🟠 High
  </button>
  <button onclick="setFilter('MEDIUM')" id="filter-MEDIUM"
    class="px-3 py-1.5 text-xs rounded-full border font-medium transition text-yellow-700 border-yellow-200 hover:bg-yellow-50">
    🟡 Medium
  </button>
  <button onclick="setFilter('LOW')" id="filter-LOW"
    class="px-3 py-1.5 text-xs rounded-full border font-medium transition text-blue-600 border-blue-200 hover:bg-blue-50">
    🔵 Low
  </button>
</div>

<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-6 gap-4">
  <div>
    <a href="/" class="text-blue-600 hover:underline text-sm flex items-center gap-1 mb-1">
      <i class="fas fa-arrow-left"></i> Kembali ke Dashboard
    </a>
    <h1 class="text-3xl font-bold"><%= project.name %></h1>
    <p class="text-gray-600"><%= project.description || 'Proyek kolaborasi tim' %></p>
  </div>
  
  <div class="flex items-center gap-3">
    <button onclick="showCreateTaskModal()" 
            class="w-full sm:w-auto justify-center flex items-center gap-2 bg-blue-600 hover:bg-blue-700 transition text-white px-5 py-2.5 rounded-2xl text-sm font-medium">
      <i class="fas fa-plus"></i> 
      <span>Buat Tugas Baru</span>
    </button>
    <button onclick="showTemplateModal()" 
            class="w-full sm:w-auto justify-center flex items-center gap-2 bg-purple-600 hover:bg-purple-700 transition text-white px-5 py-2.5 rounded-2xl text-sm font-medium">
      <i class="fas fa-copy"></i> 
      <span>Dari Template</span>
    </button>
  </div>
</div>

<!-- Kanban Board -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-6" id="kanban-board">
  <!-- To Do -->
  <div class="bg-white rounded-3xl p-5 border shadow-sm">
    <div class="flex items-center justify-between mb-4 px-1">
      <div class="flex items-center gap-2">
        <div class="w-3 h-3 bg-gray-400 rounded-full"></div>
        <span class="font-semibold text-lg">To Do</span>
      </div>
      <span class="bg-gray-100 text-gray-600 text-xs px-3 py-1 rounded-full font-mono" id="count-todo">0</span>
    </div>
    <div id="column-TODO" class="kanban-column space-y-3 min-h-[420px] p-2 rounded-2xl bg-gray-50" 
         ondrop="drop(event, 'TODO')" ondragover="allowDrop(event)">
      <!-- Tasks populated by JS -->
    </div>
  </div>

  <!-- In Progress -->
  <div class="bg-white rounded-3xl p-5 border shadow-sm">
    <div class="flex items-center justify-between mb-4 px-1">
      <div class="flex items-center gap-2">
        <div class="w-3 h-3 bg-amber-400 rounded-full"></div>
        <span class="font-semibold text-lg">In Progress</span>
      </div>
      <span class="bg-amber-100 text-amber-600 text-xs px-3 py-1 rounded-full font-mono" id="count-in_progress">0</span>
    </div>
    <div id="column-IN_PROGRESS" class="kanban-column space-y-3 min-h-[420px] p-2 rounded-2xl bg-gray-50" 
         ondrop="drop(event, 'IN_PROGRESS')" ondragover="allowDrop(event)">
    </div>
  </div>

  <!-- Done -->
  <div class="bg-white rounded-3xl p-5 border shadow-sm">
    <div class="flex items-center justify-between mb-4 px-1">
      <div class="flex items-center gap-2">
        <div class="w-3 h-3 bg-emerald-500 rounded-full"></div>
        <span class="font-semibold text-lg">Done</span>
      </div>
      <span class="bg-emerald-100 text-emerald-600 text-xs px-3 py-1 rounded-full font-mono" id="count-done">0</span>
    </div>
    <div id="column-DONE" class="kanban-column space-y-3 min-h-[420px] p-2 rounded-2xl bg-gray-50" 
         ondrop="drop(event, 'DONE')" ondragover="allowDrop(event)">
    </div>
  </div>
</div>

<!-- Chat Section -->
<div class="mt-10 bg-white rounded-3xl p-6 border shadow-sm">
  <h3 class="font-semibold text-xl mb-4 flex items-center gap-2">
    <i class="fas fa-comments text-blue-600"></i> 
    Chat Proyek
  </h3>
  
  <div id="chat-messages" class="h-72 overflow-y-auto bg-gray-50 rounded-2xl p-4 mb-4 space-y-4 text-sm">
    <!-- Messages loaded via JS -->
  </div>
  
  <div id="chat-file-pill" class="hidden mb-3 text-xs text-blue-700 bg-blue-50 border border-blue-100 rounded-xl px-3 py-2"></div>
  <div class="flex gap-2 sm:gap-3">
    <button type="button" onclick="document.getElementById('chat-files').click()"
            class="px-4 border rounded-2xl text-gray-600 hover:bg-gray-50" title="Lampirkan file">
      <i class="fas fa-paperclip"></i>
    </button>
    <input id="chat-files" type="file" multiple class="hidden" onchange="handleChatFiles(this.files)">
    <input id="chat-input" type="text" placeholder="Ketik pesan..." 
           class="flex-1 border rounded-2xl px-5 py-3 focus:outline-none focus:border-blue-400"
           onkeypress="if(event.key === 'Enter') sendMessage()">
    <button onclick="sendMessage()" 
            class="px-5 sm:px-8 bg-blue-600 text-white rounded-2xl hover:bg-blue-700 flex items-center">
      <i class="fas fa-paper-plane"></i>
    </button>
  </div>
</div>

<!-- Create Task Modal -->
<div id="createTaskModal" class="hidden fixed inset-0 bg-black/60 flex items-center justify-center z-[100]">
  <div class="bg-white w-full max-w-lg mx-4 rounded-3xl p-8">
    <h3 class="text-2xl font-bold mb-6">Buat Tugas Baru</h3>
    
    <form id="createTaskForm" onsubmit="createTask(event)">
      <input type="hidden" name="projectId" value="<%= project.id %>">
      
      <div class="space-y-5">
        <div>
          <label class="block text-sm font-medium mb-1.5">Judul Tugas *</label>
          <input type="text" name="title" required class="w-full border rounded-2xl px-5 py-3">
        </div>
        
        <div>
          <label class="block text-sm font-medium mb-1.5">Deskripsi</label>
          <textarea name="description" rows="3" class="w-full border rounded-2xl px-5 py-3"></textarea>
        </div>
        
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium mb-1.5">Ditugaskan ke</label>
            <select name="assigneeId" class="w-full border rounded-2xl px-5 py-3">
              <option value="">Belum ditugaskan</option>
              <% members.forEach(member => { %>
                <option value="<%= member.id %>"><%= member.name %></option>
              <% }) %>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium mb-1.5">Deadline</label>
            <input type="date" name="dueDate" class="w-full border rounded-2xl px-5 py-3">
          </div>
          <div>
            <label class="block text-sm font-medium mb-1.5">Prioritas</label>
            <select name="priority" class="w-full border rounded-2xl px-5 py-3">
              <option value="NONE">Tanpa Prioritas</option>
              <option value="LOW">🔵 Low</option>
              <option value="MEDIUM">🟡 Medium</option>
              <option value="HIGH">🟠 High</option>
              <option value="URGENT">🔴 Urgent</option>
            </select>
          </div>
        </div>
      </div>
      
      <div class="flex gap-3 mt-8">
        <button type="button" onclick="hideCreateTaskModal()" 
                class="flex-1 py-3.5 border rounded-2xl font-medium">Batal</button>
        <button type="submit" 
                class="flex-1 py-3.5 bg-blue-600 text-white rounded-2xl font-medium hover:bg-blue-700">Buat Tugas</button>
      </div>
    </form>
  </div>
</div>

<script>
const projectId = '<%= project.id %>';
let tasks = <%- JSON.stringify(project.tasks) %>;
const socket = io();
let pendingChatFiles = [];

socket.emit('join-project', projectId);
socket.emit('join-user', '<%= currentUserId %>');

// Priority config
const PRIO = {
  NONE:   { label: '', cls: '' },
  LOW:    { label: 'Low',    cls: 'bg-blue-100 text-blue-700' },
  MEDIUM: { label: 'Medium', cls: 'bg-yellow-100 text-yellow-700' },
  HIGH:   { label: 'High',   cls: 'bg-orange-100 text-orange-700' },
  URGENT: { label: 'Urgent', cls: 'bg-red-100 text-red-700' }
};

let activeFilter = 'ALL';

function escapeHtml(value) {
  return String(value || '').replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#039;'}[c]));
}

function renderAttachment(file) {
  const name = escapeHtml(file.originalName || file.filename);
  if ((file.mimeType || '').startsWith('image/')) {
    return `<a href="${file.url}" target="_blank" class="block mt-2"><img src="${file.url}" alt="${name}" class="max-h-56 rounded-2xl border object-contain bg-white"></a>`;
  }
  return `<a href="${file.url}" target="_blank" class="inline-flex items-center gap-2 mt-2 px-3 py-2 rounded-xl bg-white border text-gray-700 hover:bg-gray-50"><i class="fas fa-file"></i><span>${name}</span></a>`;
}

function setFilter(f) {
  activeFilter = f;
  document.querySelectorAll('[id^="filter-"]').forEach(btn => {
    btn.classList.remove('bg-blue-600','text-white','border-blue-600');
    btn.classList.add('bg-white');
  });
  const active = document.getElementById(`filter-${f}`);
  if (active) { active.classList.add('bg-blue-600','text-white','border-blue-600'); active.classList.remove('bg-white'); }
  renderKanban();
}

// Render Kanban
function renderKanban() {
  const columns = {
    'TODO': document.getElementById('column-TODO'),
    'IN_PROGRESS': document.getElementById('column-IN_PROGRESS'),
    'DONE': document.getElementById('column-DONE')
  };

  Object.values(columns).forEach(col => col.innerHTML = '');
  let counts = { TODO: 0, IN_PROGRESS: 0, DONE: 0 };

  const filtered = activeFilter === 'ALL' ? tasks : tasks.filter(t => t.priority === activeFilter);

  filtered.forEach(task => {
    const column = columns[task.status];
    if (!column) return;
    counts[task.status]++;

    const prio = PRIO[task.priority] || PRIO.NONE;
    const isOverdue = task.dueDate && new Date(task.dueDate) < new Date() && task.status !== 'DONE';
    const labels = (task.labels || []).map(tl => tl.label).filter(Boolean);

    const card = document.createElement('div');
    card.className = 'task-card bg-white border p-4 rounded-2xl cursor-grab active:cursor-grabbing';
    card.draggable = true;
    card.dataset.id = task.id;
    card.ondragstart = (e) => drag(e, task.id);
    card.onclick = () => openPreview(task.id);

    // Quick-move button
    let moveBtn = '';
    if (task.status === 'TODO') moveBtn = `<button onclick="event.stopPropagation(); moveStatus('${task.id}','IN_PROGRESS')" class="px-2.5 py-1 bg-amber-100 text-amber-700 rounded-lg text-[10px] font-semibold hover:bg-amber-200 transition whitespace-nowrap" title="Pindah ke Doing"><i class="fas fa-play mr-1"></i>Mulai</button>`;
    else if (task.status === 'IN_PROGRESS') moveBtn = `<button onclick="event.stopPropagation(); moveStatus('${task.id}','DONE')" class="px-2.5 py-1 bg-emerald-100 text-emerald-700 rounded-lg text-[10px] font-semibold hover:bg-emerald-200 transition whitespace-nowrap" title="Tandai Selesai"><i class="fas fa-check mr-1"></i>Selesai</button>`;
    else moveBtn = `<button onclick="event.stopPropagation(); moveStatus('${task.id}','TODO')" class="px-2.5 py-1 bg-gray-100 text-gray-600 rounded-lg text-[10px] font-semibold hover:bg-gray-200 transition whitespace-nowrap" title="Buka Lagi"><i class="fas fa-undo mr-1"></i>Buka</button>`;

    // Checklist progress
    const checklists = task.checklists || [];
    const doneCount = checklists.filter(c => c.isDone).length;
    const checkPct = checklists.length > 0 ? Math.round(doneCount / checklists.length * 100) : 0;

    card.innerHTML = `
      <div class="flex justify-between items-start mb-2 gap-2">
        <a href="/tasks/${task.id}" onclick="event.stopPropagation()" class="font-semibold text-sm hover:text-blue-600 leading-tight flex-1">${escapeHtml(task.title)}</a>
        ${task.assignee ? `<div class="text-[10px] bg-blue-100 text-blue-700 px-2 py-0.5 rounded-full whitespace-nowrap shrink-0">${escapeHtml(task.assignee.name.split(' ')[0])}</div>` : ''}
      </div>
      ${task.description ? `<p class="text-xs text-gray-500 line-clamp-2 mb-2">${escapeHtml(task.description)}</p>` : ''}
      ${labels.length ? `<div class="flex flex-wrap gap-1 mb-2">${labels.map(label => `<span class="text-[10px] font-semibold rounded-full px-2 py-0.5 text-white" style="background:${escapeHtml(label.color)}">${escapeHtml(label.name)}</span>`).join('')}</div>` : ''}
      ${checklists.length > 0 ? `<div class="flex items-center gap-2 mb-2">
        <div class="flex-1 h-1.5 bg-gray-100 rounded-full overflow-hidden"><div class="h-full rounded-full transition-all ${checkPct === 100 ? 'bg-emerald-500' : 'bg-blue-500'}" style="width:${checkPct}%"></div></div>
        <span class="text-[10px] text-gray-400 whitespace-nowrap">${doneCount}/${checklists.length}</span>
      </div>` : ''}
      <div class="flex items-center justify-between text-xs mt-2 gap-2">
        <div class="flex items-center gap-1.5 flex-wrap">
          ${prio.label ? `<span class="px-2 py-0.5 rounded-full text-[10px] font-semibold ${prio.cls}">${prio.label}</span>` : ''}
          ${task.dueDate ? `<span class="${isOverdue ? 'text-red-500 font-semibold' : 'text-gray-400'}"><i class="fas fa-clock mr-0.5"></i>${new Date(task.dueDate).toLocaleDateString('id-ID',{month:'short',day:'numeric'})}</span>` : ''}
        </div>
        <div class="flex items-center gap-1 shrink-0">
          ${moveBtn}
          <a href="/tasks/${task.id}" onclick="event.stopPropagation()" class="p-1.5 text-gray-400 hover:text-blue-600" title="Lihat Detail"><i class="fas fa-external-link-alt fa-xs"></i></a>
          <button onclick="event.stopPropagation(); deleteTask('${task.id}')" class="p-1.5 text-gray-400 hover:text-red-500" title="Hapus"><i class="fas fa-trash fa-xs"></i></button>
        </div>
      </div>
    `;

    column.appendChild(card);
  });

  document.getElementById('count-todo').textContent = counts.TODO;
  document.getElementById('count-in_progress').textContent = counts.IN_PROGRESS;
  document.getElementById('count-done').textContent = counts.DONE;
}

// Drag and Drop functions
let draggedTaskId = null;

function drag(ev, taskId) {
  draggedTaskId = taskId;
  ev.dataTransfer.setData("text", taskId);
}

// Quick-move status button
async function moveStatus(taskId, newStatus) {
  const task = tasks.find(t => t.id === taskId);
  if (!task) return;
  const oldStatus = task.status;
  task.status = newStatus;
  renderKanban();
  try {
    const res = await fetch(`/tasks/${taskId}/status`, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ status: newStatus })
    });
    if (!res.ok) throw new Error('failed');
    socket.emit('task-updated', { taskId, status: newStatus, projectId });
  } catch (e) {
    task.status = oldStatus;
    renderKanban();
  }
}

// Task preview panel
function openPreview(taskId) {
  const task = tasks.find(t => t.id === taskId);
  if (!task) return;

  const checklists = task.checklists || [];
  const doneCount = checklists.filter(c => c.isDone).length;
  const checkPct = checklists.length > 0 ? Math.round(doneCount / checklists.length * 100) : 0;
  const pendingItems = checklists.filter(c => !c.isDone);

  const PRIO_MAP = { URGENT: { label: '🔴 Urgent', cls: 'bg-red-100 text-red-700' }, HIGH: { label: '🟠 High', cls: 'bg-orange-100 text-orange-700' }, MEDIUM: { label: '🟡 Medium', cls: 'bg-yellow-100 text-yellow-700' }, LOW: { label: '🟢 Low', cls: 'bg-green-100 text-green-700' }, NONE: { label: '', cls: '' } };
  const prio = PRIO_MAP[task.priority] || PRIO_MAP.NONE;
  const STATUS_MAP = { TODO: '📋 To Do', IN_PROGRESS: '🔄 Doing', DONE: '✅ Done' };

  document.getElementById('preview-title').textContent = task.title;
  document.getElementById('preview-status').textContent = STATUS_MAP[task.status] || task.status;
  document.getElementById('preview-priority').innerHTML = prio.label ? `<span class="px-2 py-0.5 rounded-full text-xs font-semibold ${prio.cls}">${prio.label}</span>` : '-';
  document.getElementById('preview-due').textContent = task.dueDate ? new Date(task.dueDate).toLocaleDateString('id-ID', { weekday: 'short', day: 'numeric', month: 'short', year: 'numeric' }) : '-';
  document.getElementById('preview-assignee').textContent = task.assignee ? task.assignee.name : '-';
  document.getElementById('preview-desc').textContent = task.description || '-';

  // Checklist progress
  document.getElementById('preview-check-pct').textContent = checklists.length > 0 ? `${checkPct}%` : '-';
  document.getElementById('preview-check-bar').style.width = `${checkPct}%`;
  document.getElementById('preview-check-bar').className = `h-full rounded-full transition-all ${checkPct === 100 ? 'bg-emerald-500' : 'bg-blue-500'}`;

  // Pending items
  const pendingList = document.getElementById('preview-pending');
  pendingList.innerHTML = '';
  if (pendingItems.length > 0) {
    pendingItems.forEach(item => {
      const div = document.createElement('div');
      div.className = 'flex items-center gap-2 text-sm text-gray-600';
      div.innerHTML = `<i class="far fa-square text-gray-400"></i><span>${escapeHtml(item.content)}</span>`;
      pendingList.appendChild(div);
    });
  } else if (checklists.length > 0) {
    pendingList.innerHTML = '<p class="text-sm text-emerald-600 font-medium"><i class="fas fa-check-circle mr-1"></i>Semua selesai!</p>';
  } else {
    pendingList.innerHTML = '<p class="text-sm text-gray-400">Belum ada checklist</p>';
  }

  document.getElementById('preview-detail-link').href = `/tasks/${task.id}`;
  document.getElementById('preview-panel').classList.remove('translate-x-full');
}

function closePreview() {
  document.getElementById('preview-panel').classList.add('translate-x-full');
}

function allowDrop(ev) {
  ev.preventDefault();
}

async function drop(ev, newStatus) {
  ev.preventDefault();
  const taskId = ev.dataTransfer.getData("text") || draggedTaskId;
  
  if (!taskId) return;

  // Find task
  const taskIndex = tasks.findIndex(t => t.id === taskId);
  if (!taskIndex && taskIndex !== 0) return;

  const oldStatus = tasks[taskIndex].status;
  
  if (oldStatus === newStatus) return;

  // Optimistic update
  tasks[taskIndex].status = newStatus;
  renderKanban();

  // Update backend
  try {
    const res = await fetch(`/tasks/${taskId}/status`, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ status: newStatus })
    });
    
    if (res.ok) {
      // Emit to others
      socket.emit('task-updated', { taskId, status: newStatus, projectId });
    }
  } catch (e) {
    console.error(e);
    // Revert on error
    tasks[taskIndex].status = oldStatus;
    renderKanban();
    alert('Gagal update status tugas');
  }
}

// Socket listeners
socket.on('task-updated', (data) => {
  const taskIndex = tasks.findIndex(t => t.id === data.taskId);
  if (taskIndex > -1) {
    tasks[taskIndex].status = data.status;
    renderKanban();
  }
});

socket.on('new-message', (msg) => {
  appendMessage(msg);
});

// Create Task
function showCreateTaskModal() {
  document.getElementById('createTaskModal').classList.remove('hidden');
}

function hideCreateTaskModal() {
  document.getElementById('createTaskModal').classList.add('hidden');
  document.getElementById('createTaskForm').reset();
}

async function createTask(e) {
  e.preventDefault();
  const form = e.target;
  const formData = new FormData(form);
  
  const data = Object.fromEntries(formData.entries());
  if (!data.priority) data.priority = 'NONE';

  try {
    const res = await fetch('/tasks/create', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data)
    });

    const result = await res.json();
    if (result.success) {
      tasks.push(result.task);
      renderKanban();
      hideCreateTaskModal();
      form.reset();
    }
  } catch (err) {
    alert('Gagal membuat tugas');
  }
}

// Delete task
async function deleteTask(taskId) {
  if (!confirm('Hapus tugas ini?')) return;
  
  try {
    await fetch(`/tasks/${taskId}`, { method: 'DELETE' });
    tasks = tasks.filter(t => t.id !== taskId);
    renderKanban();
  } catch (e) {
    alert('Gagal menghapus');
  }
}


// Chat functions
async function loadChatMessages() {
  try {
    const res = await fetch(`/chat/messages/${projectId}`);
    const messages = await res.json();
    const container = document.getElementById('chat-messages');
    container.innerHTML = '';
    messages.forEach(msg => appendMessage(msg, false));
    container.scrollTop = container.scrollHeight;
  } catch (e) {}
}

function appendMessage(msg, scroll = true) {
  const container = document.getElementById('chat-messages');
  if (msg.id && document.getElementById(`chat-msg-${msg.id}`)) return;
  const isMe = msg.user && msg.user.id === '<%= currentUserId %>';
  
  const div = document.createElement('div');
  if (msg.id) div.id = `chat-msg-${msg.id}`;
  div.className = `flex ${isMe ? 'justify-end' : ''}`;
  div.innerHTML = `
    <div class="${isMe ? 'bg-blue-600 text-white' : 'bg-white border'} max-w-[75%] px-4 py-2.5 rounded-3xl ${isMe ? 'rounded-tr-none' : 'rounded-tl-none'}">
      <div class="text-xs opacity-70 mb-0.5">${msg.user ? escapeHtml(msg.user.name) : 'User'}</div>
      ${msg.content ? `<div class="whitespace-pre-wrap">${escapeHtml(msg.content)}</div>` : ''}
      ${(msg.attachments || []).map(renderAttachment).join('')}
    </div>
  `;
  container.appendChild(div);
  if (scroll) container.scrollTop = container.scrollHeight;
}

function refreshChatFilePill() {
  const pill = document.getElementById('chat-file-pill');
  if (pendingChatFiles.length === 0) {
    pill.classList.add('hidden');
    pill.textContent = '';
    return;
  }
  pill.classList.remove('hidden');
  pill.textContent = `${pendingChatFiles.length} file siap dikirim`;
}

function handleChatFiles(files) {
  pendingChatFiles = [...pendingChatFiles, ...Array.from(files || [])];
  refreshChatFilePill();
}

document.addEventListener('paste', (event) => {
  const files = [];
  for (const item of event.clipboardData?.items || []) {
    if (item.kind === 'file') files.push(item.getAsFile());
  }
  if (files.length > 0) {
    handleChatFiles(files.filter(Boolean));
    event.preventDefault();
  }
});

async function sendMessage() {
  const input = document.getElementById('chat-input');
  const content = input.value.trim();
  if (!content && pendingChatFiles.length === 0) return;

  try {
    const form = new FormData();
    form.append('content', content);
    pendingChatFiles.forEach(file => form.append('files', file));

    const res = await fetch(`/chat/messages/${projectId}`, { method: 'POST', body: form });
    
    const result = await res.json();
    if (result.success) {
      appendMessage(result.message);
      socket.emit('new-message', result.message);
      input.value = '';
      pendingChatFiles = [];
      document.getElementById('chat-files').value = '';
      refreshChatFilePill();
    }
  } catch (e) {
    // Fallback local
    appendMessage({ content, user: { name: 'Anda' } });
    input.value = '';
  }
}

// Initialize everything
function init() {
  renderKanban();
  loadChatMessages();

  // Socket task update listener already set above
  console.log('%c[Maulana Corp] Kanban board initialized with real-time sync', 'color:#666');
}

window.onload = init;
</script>

