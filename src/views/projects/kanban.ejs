// --- Bottom Sheet Swipe-to-Close for Modals ---
function setupBottomSheetClose(modalId) {
  const modal = document.getElementById(modalId);
  if (!modal) return;
  const content = modal.querySelector('.bg-white');
  if (!content) return;
  
  let startY = 0;
  let currentY = 0;
  let isDragging = false;
  
  content.addEventListener('touchstart', (e) => {
    if (window.innerWidth >= 1024) return;
    startY = e.touches[0].clientY;
    isDragging = true;
    content.style.transition = 'none';
  }, { passive: true });
  
  content.addEventListener('touchmove', (e) => {
    if (!isDragging || window.innerWidth >= 1024) return;
    currentY = e.touches[0].clientY - startY;
    if (currentY > 0) {
      content.style.transform = `translateY(${currentY}px)`;
    }
  }, { passive: true });
  
  content.addEventListener('touchend', () => {
    if (!isDragging || window.innerWidth >= 1024) return;
    isDragging = false;
    content.style.transition = 'transform 0.3s ease';
    if (currentY > 100) {
      // Close modal
      modal.classList.add('hidden');
      content.style.transform = '';
    } else {
      content.style.transform = '';
    }
    currentY = 0;
  });
}
setupBottomSheetClose('createTaskModal');
setupBottomSheetClose('membersModal');
setupBottomSheetClose('recurringModal');
setupBottomSheetClose('templateModal');

// --- Task Card Touch Interactions (Swipe & Long Press) ---
let contextMenuTaskId = null;
let longPressTimer = null;
let touchStartX = 0;
let touchStartY = 0;
let touchCard = null;

function showContextMenu(taskId, x, y) {
  contextMenuTaskId = taskId;
  const menu = document.getElementById('context-menu');
  menu.classList.remove('hidden');
  // Position menu
  const menuRect = menu.getBoundingClientRect();
  const maxX = window.innerWidth - menuRect.width - 16;
  const maxY = window.innerHeight - menuRect.height - 16;
  menu.style.left = Math.min(x, maxX) + 'px';
  menu.style.top = Math.min(y, maxY) + 'px';
}

function hideContextMenu() {
  document.getElementById('context-menu')?.classList.add('hidden');
  contextMenuTaskId = null;
}

function contextMenuAction(action) {
  if (!contextMenuTaskId) return;
  switch(action) {
    case 'open': window.location.href = `/tasks/${contextMenuTaskId}`; break;
    case 'todo': moveStatus(contextMenuTaskId, 'TODO'); break;
    case 'doing': moveStatus(contextMenuTaskId, 'IN_PROGRESS'); break;
    case 'done': moveStatus(contextMenuTaskId, 'DONE'); break;
    case 'delete': deleteTask(contextMenuTaskId); break;
  }
  hideContextMenu();
}

document.addEventListener('click', (e) => {
  if (!e.target.closest('#context-menu')) hideContextMenu();
});

// Add touch handlers to kanban board for task cards
document.getElementById('kanban-board')?.addEventListener('touchstart', (e) => {
  const card = e.target.closest('.task-card');
  if (!card) return;
  
  touchStartX = e.touches[0].clientX;
  touchStartY = e.touches[0].clientY;
  touchCard = card;
  
  // Long press detection (500ms)
  longPressTimer = setTimeout(() => {
    if (touchCard === card) {
      // Haptic feedback (vibrate if available)
      if (navigator.vibrate) navigator.vibrate(50);
      showContextMenu(card.dataset.id, touchStartX, touchStartY);
      card.style.transform = 'scale(0.97)';
      card.style.transition = 'transform 0.15s ease';
    }
  }, 500);
}, { passive: true });

document.getElementById('kanban-board')?.addEventListener('touchmove', (e) => {
  // Cancel long press if finger moves too much
  if (touchCard) {
    const dx = Math.abs(e.touches[0].clientX - touchStartX);
    const dy = Math.abs(e.touches[0].clientY - touchStartY);
    if (dx > 10 || dy > 10) {
      clearTimeout(longPressTimer);
    }
  }
}, { passive: true });

document.getElementById('kanban-board')?.addEventListener('touchend', (e) => {
  clearTimeout(longPressTimer);
  
  if (!touchCard) return;
  touchCard.style.transform = '';
  touchCard.style.transition = '';
  
  const touchEndX = e.changedTouches[0].clientX;
  const touchEndY = e.changedTouches[0].clientY;
  const diffX = touchEndX - touchStartX;
  const diffY = touchEndY - touchStartY;
  
  // Swipe detection (minimum 50px horizontal, less vertical)
  if (Math.abs(diffX) > 50 && Math.abs(diffX) > Math.abs(diffY) * 1.5) {
    const taskId = touchCard.dataset.id;
    const task = tasks.find(t => t.id === taskId);
    if (!task) return;
    
    // Haptic feedback
    if (navigator.vibrate) navigator.vibrate(30);
    
    const statusOrder = ['TODO', 'IN_PROGRESS', 'DONE'];
    const currentIndex = statusOrder.indexOf(task.status);
    
    if (diffX > 0 && currentIndex < 2) {
      // Swipe right -> move to next column
      moveStatus(taskId, statusOrder[currentIndex + 1]);
      touchCard.style.transform = 'translateX(50px)';
      touchCard.style.opacity = '0.5';
      setTimeout(() => {
        if (touchCard) {
          touchCard.style.transform = '';
          touchCard.style.opacity = '';
        }
      }, 200);
    } else if (diffX < 0 && currentIndex > 0) {
      // Swipe left -> move to previous column
      moveStatus(taskId, statusOrder[currentIndex - 1]);
      touchCard.style.transform = 'translateX(-50px)';
      touchCard.style.opacity = '0.5';
      setTimeout(() => {
        if (touchCard) {
          touchCard.style.transform = '';
          touchCard.style.opacity = '';
        }
      }, 200);
    }
  }
  
  touchCard = null;
  touchStartX = 0;
  touchStartY = 0;
}, { passive: true });

// --- Pull-to-Refresh Indicator ---
let pullStartY = 0;
let pullIndicator = null;

function createPullIndicator() {
  if (pullIndicator) return;
  pullIndicator = document.createElement('div');
  pullIndicator.className = 'fixed top-0 left-0 right-0 flex justify-center z-50 pointer-events-none';
  pullIndicator.innerHTML = '<div class="w-8 h-8 border-4 border-blue-400 border-t-transparent rounded-full animate-spin opacity-0 transition-opacity duration-200" id="pull-spinner"></div>';
  document.body.appendChild(pullIndicator);
}

document.addEventListener('touchstart', (e) => {
  if (window.scrollY === 0) {
    pullStartY = e.touches[0].clientY;
  }
}, { passive: true });

document.addEventListener('touchmove', (e) => {
  if (pullStartY === 0) return;
  const diff = e.touches[0].clientY - pullStartY;
  if (diff > 80 && window.scrollY === 0) {
    createPullIndicator();
    const spinner = document.getElementById('pull-spinner');
    if (spinner) spinner.style.opacity = '1';
  }
}, { passive: true });

document.addEventListener('touchend', () => {
  const spinner = document.getElementById('pull-spinner');
  if (spinner && spinner.style.opacity === '1') {
    // Trigger refresh
    renderKanban();
    loadChatMessages();
    setTimeout(() => { spinner.style.opacity = '0'; }, 1000);
  }
  pullStartY = 0;
}, { passive: true });

// --- FAB auto-hide on scroll ---
let lastScrollY = 0;
const fab = document.getElementById('fab-create');
if (fab) {
  window.addEventListener('scroll', () => {
    const currentY = window.scrollY;
    if (currentY > lastScrollY && currentY > 200) {
      fab.style.transform = 'scale(0)';
      fab.style.opacity = '0';
    } else {
      fab.style.transform = 'scale(1)';
      fab.style.opacity = '1';
    }
    lastScrollY = currentY;
  }, { passive: true });
  fab.style.transition = 'transform 0.3s ease, opacity 0.3s ease';
}

