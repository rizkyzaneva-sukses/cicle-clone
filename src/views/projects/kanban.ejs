<%- include('../partials/header', { title: project.name + ' | Kanban' }) %>
<% const canManageProject = currentUser.platformRole === 'owner' || currentUser.platformRole === 'partner' || userRole === 'admin'; %>

<!-- Priority Filter Bar -->
<div class="flex items-center gap-2 mb-5 overflow-x-auto pb-2 lg:flex-wrap" style="-webkit-overflow-scrolling:touch; scrollbar-width:none;">
  <span class="text-sm text-gray-500 font-medium mr-1 shrink-0">Filter:</span>
  <button onclick="setFilter('ALL')" id="filter-ALL"
    class="px-3 py-1.5 text-xs rounded-full border font-medium transition bg-blue-600 text-white border-blue-600 shrink-0">
    Semua
  </button>
  <button onclick="setFilter('URGENT')" id="filter-URGENT"
    class="px-3 py-1.5 text-xs rounded-full border font-medium transition text-red-600 border-red-200 hover:bg-red-50 shrink-0">
    🔴 Urgent
  </button>
  <button onclick="setFilter('HIGH')" id="filter-HIGH"
    class="px-3 py-1.5 text-xs rounded-full border font-medium transition text-orange-600 border-orange-200 hover:bg-orange-50 shrink-0">
    🟠 High
  </button>
  <button onclick="setFilter('MEDIUM')" id="filter-MEDIUM"
    class="px-3 py-1.5 text-xs rounded-full border font-medium transition text-yellow-700 border-yellow-200 hover:bg-yellow-50 shrink-0">
    🟡 Medium
  </button>
  <button onclick="setFilter('LOW')" id="filter-LOW"
    class="px-3 py-1.5 text-xs rounded-full border font-medium transition text-blue-600 border-blue-200 hover:bg-blue-50 shrink-0">
    🔵 Low
  </button>
</div>

<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-6 gap-4">
  <div>
    <a href="/" class="text-blue-600 hover:underline text-sm flex items-center gap-1 mb-1">
      <i class="fas fa-arrow-left"></i> Kembali ke Dashboard
    </a>
    <div class="flex items-center gap-3">
      <h1 id="project-title" class="text-3xl font-bold"><%= project.name %></h1>
      <% if (typeof healthScore !== 'undefined') { %>
        <div class="flex items-center gap-2 px-3 py-1 rounded-full text-sm font-medium
          <%= healthScore > 80 ? 'bg-emerald-100 text-emerald-700' : 
              healthScore >= 50 ? 'bg-amber-100 text-amber-700' : 
              'bg-red-100 text-red-700' %>">
          <span><%= healthIndicator %></span>
          <span>Health: <%= healthScore %></span>
        </div>
      <% } %>
    </div>
    <div id="project-desc-display" class="group mt-1 flex items-start gap-2">
      <p id="project-desc-text" class="text-gray-600" data-raw="<%= project.description || '' %>"><%= project.description || 'Proyek kolaborasi tim' %></p>
      <% if (canManageProject) { %>
        <button type="button" onclick="showProjectEdit()" class="mt-0.5 text-gray-400 hover:text-blue-600 transition opacity-100 sm:opacity-0 sm:group-hover:opacity-100" title="Edit deskripsi proyek">
          <i class="fas fa-pen text-xs"></i>
        </button>
      <% } %>
    </div>
    <% if (canManageProject) { %>
      <div id="project-edit-form" class="hidden mt-3 max-w-2xl bg-white border rounded-2xl p-4 shadow-sm">
        <label class="block text-xs font-semibold text-gray-500 mb-1.5">Nama Proyek</label>
        <input id="project-name-input" type="text" value="<%= project.name %>"
          class="w-full border rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-blue-400 focus:ring-2 focus:ring-blue-100">
        <label class="block text-xs font-semibold text-gray-500 mt-3 mb-1.5">Deskripsi</label>
        <textarea id="project-desc-input" rows="3"
          class="w-full border rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-blue-400 focus:ring-2 focus:ring-blue-100"><%= project.description || '' %></textarea>
        <div class="flex flex-col sm:flex-row gap-2 mt-3">
          <button type="button" onclick="saveProjectEdit()" class="px-4 py-2 bg-blue-600 text-white rounded-xl text-sm font-semibold hover:bg-blue-700">
            Simpan
          </button>
          <button type="button" onclick="hideProjectEdit()" class="px-4 py-2 border rounded-xl text-sm font-semibold text-gray-600 hover:bg-gray-50">
            Batal
          </button>
        </div>
      </div>
    <% } %>
    
    <% if (typeof healthBreakdown !== 'undefined' && healthBreakdown.overdue) { %>
      <div class="flex flex-wrap gap-3 mt-2 text-xs text-gray-500">
        <span title="Overdue Rate (40% weight)">
          <i class="fas fa-clock text-red-400"></i> Overdue: <%= healthBreakdown.overdue.rate %>%
        </span>
        <span title="Completion Rate (30% weight)">
          <i class="fas fa-check-circle text-emerald-400"></i> Completion: <%= healthBreakdown.completion.rate %>%
        </span>
        <span title="Activity Level (20% weight)">
          <i class="fas fa-comments text-blue-400"></i> Activity: <%= healthBreakdown.activity.messages %> msgs
        </span>
        <span title="Member Engagement (10% weight)">
          <i class="fas fa-users text-purple-400"></i> Engagement: <%= healthBreakdown.engagement.rate %>%
        </span>
      </div>
    <% } %>
  </div>
  
  <div class="hidden sm:flex items-center gap-2 flex-wrap">
    <a href="/projects/<%= project.id %>/gantt"
       class="flex-1 sm:flex-none justify-center flex items-center gap-1.5 bg-indigo-600 hover:bg-indigo-700 transition text-white px-3 sm:px-5 py-2 sm:py-2.5 rounded-xl sm:rounded-2xl text-xs sm:text-sm font-medium">
      <i class="fas fa-chart-gantt"></i>
      <span>Gantt</span>
    </a>
    <button onclick="showCreateTaskModal()"
            class="flex-1 sm:flex-none justify-center flex items-center gap-1.5 bg-blue-600 hover:bg-blue-700 transition text-white px-3 sm:px-5 py-2 sm:py-2.5 rounded-xl sm:rounded-2xl text-xs sm:text-sm font-medium">
      <i class="fas fa-plus"></i> 
      <span>Baru</span>
    </button>
    <button onclick="showTemplateModal()"
            class="flex-1 sm:flex-none justify-center flex items-center gap-1.5 bg-purple-600 hover:bg-purple-700 transition text-white px-3 sm:px-5 py-2 sm:py-2.5 rounded-xl sm:rounded-2xl text-xs sm:text-sm font-medium">
      <i class="fas fa-copy"></i>
      <span>Template</span>
    </button>
    <% if (canManageProject) { %>
      <button onclick="showRecurringModal()"
              class="flex-1 sm:flex-none justify-center flex items-center gap-1.5 bg-teal-600 hover:bg-teal-700 transition text-white px-3 sm:px-5 py-2 sm:py-2.5 rounded-xl sm:rounded-2xl text-xs sm:text-sm font-medium">
        <i class="fas fa-repeat"></i>
        <span>Berulang</span>
        <% if (recurringTemplates.length > 0) { %><span class="bg-white/20 text-[10px] px-1.5 py-0.5 rounded-full"><%= recurringTemplates.length %></span><% } %>
      </button>
    <% } %>
    <button onclick="toggleBulkMode()"
            class="flex-1 sm:flex-none justify-center flex items-center gap-1.5 bg-gray-700 hover:bg-gray-800 transition text-white px-3 sm:px-5 py-2 sm:py-2.5 rounded-xl sm:rounded-2xl text-xs sm:text-sm font-medium">
      <i class="fas fa-check-double"></i> 
      <span>Bulk</span>
    </button>
    <button onclick="document.getElementById('shortcuts-help').classList.toggle('hidden')"
            class="p-2 sm:p-2.5 rounded-xl sm:rounded-2xl border hover:bg-gray-50 text-gray-500" title="Keyboard shortcuts (?)">
      <i class="fas fa-keyboard"></i>
    </button>
    <button onclick="showMembersModal()"
            class="flex items-center gap-1.5 p-2 sm:px-3 sm:py-2.5 rounded-xl sm:rounded-2xl border hover:bg-gray-50 text-gray-600 text-xs sm:text-sm font-medium" title="Anggota Proyek">
      <i class="fas fa-user-group"></i>
      <span class="hidden sm:inline">Anggota</span>
      <span class="bg-gray-100 text-gray-600 text-[10px] px-1.5 py-0.5 rounded-full"><%= projectMembers.length %></span>
    </button>
    <% if (canManageProject) { %>
      <form action="/projects/<%= project.id %>/archive" method="POST"
            onsubmit="return confirm('Arsipkan proyek &quot;<%= project.name %>&quot;? Proyek akan hilang dari daftar tapi datanya tetap tersimpan dan bisa dipulihkan dari Arsip.');">
        <button type="submit" class="p-2 sm:p-2.5 rounded-xl sm:rounded-2xl border hover:bg-amber-50 text-gray-500 hover:text-amber-600" title="Arsipkan proyek">
          <i class="fas fa-box-archive"></i>
        </button>
      </form>
    <% } %>
  </div>
</div>

<!-- Bulk action bar -->
<div id="bulk-bar" class="hidden fixed bottom-6 left-1/2 -translate-x-1/2 bg-gray-900 text-white px-6 py-3 rounded-2xl shadow-2xl flex items-center gap-4 z-50">
  <div class="flex items-center gap-3 flex-wrap justify-center">
    <span class="text-sm font-medium whitespace-nowrap"><i class="fas fa-check-double mr-1"></i><span id="bulk-count" class="font-bold">0</span> dipilih</span>
    <div class="h-5 w-px bg-gray-600 hidden sm:block"></div>
    <div class="flex items-center gap-2 flex-wrap justify-center">
      <button onclick="bulkMove('TODO')" class="px-3 py-1.5 bg-gray-600 hover:bg-gray-500 rounded-xl text-xs font-medium">📋 To Do</button>
      <button onclick="bulkMove('IN_PROGRESS')" class="px-3 py-1.5 bg-amber-600 hover:bg-amber-500 rounded-xl text-xs font-medium">🔄 Doing</button>
      <button onclick="bulkMove('DONE')" class="px-3 py-1.5 bg-emerald-600 hover:bg-emerald-500 rounded-xl text-xs font-medium">✅ Done</button>
    </div>
    <div class="h-5 w-px bg-gray-600 hidden sm:block"></div>
    <!-- Bulk Assign -->
    <div class="relative">
      <select id="bulk-assign-select" onchange="bulkAssign()" class="bg-gray-700 text-white text-xs px-2 py-1.5 rounded-xl border border-gray-600 focus:outline-none focus:border-blue-400 cursor-pointer">
        <option value="">👤 Assign</option>
        <option value="__clear__">✕ Hapus Assign</option>
        <% members.forEach(m => { %>
          <option value="<%= m.id %>"><%= m.name %></option>
        <% }) %>
      </select>
    </div>
    <!-- Bulk Deadline -->
    <div class="relative">
      <input type="date" id="bulk-deadline" onchange="bulkSetDeadline()" class="bg-gray-700 text-white text-xs px-2 py-1.5 rounded-xl border border-gray-600 focus:outline-none focus:border-blue-400 cursor-pointer w-28">
    </div>
    <!-- Bulk Move to Project -->
    <div class="relative">
      <select id="bulk-project-select" onchange="bulkMoveToProject()" class="bg-gray-700 text-white text-xs px-2 py-1.5 rounded-xl border border-gray-600 focus:outline-none focus:border-blue-400 cursor-pointer max-w-[140px]">
        <option value="">📁 Pindah Proyek</option>
        <% projects.forEach(p => { %>
          <% if (p.id !== project.id) { %>
            <option value="<%= p.id %>"><%= p.name %></option>
          <% } %>
        <% }) %>
      </select>
    </div>
    <button onclick="bulkDelete()" class="px-3 py-1.5 bg-red-600 hover:bg-red-500 rounded-xl text-xs font-medium whitespace-nowrap"><i class="fas fa-trash mr-1"></i>Hapus</button>
    <button onclick="toggleBulkMode()" class="px-3 py-1.5 bg-gray-700 hover:bg-gray-600 rounded-xl text-xs font-medium whitespace-nowrap">Batal</button>
  </div>
</div>

<!-- Shortcuts help -->
<div id="shortcuts-help" class="hidden fixed bottom-6 right-6 bg-white border rounded-2xl shadow-xl p-5 w-64 z-50">
  <h4 class="font-bold text-sm mb-3">Keyboard Shortcuts</h4>
  <div class="space-y-2 text-xs">
    <div class="flex justify-between"><span class="text-gray-600">Buat task baru</span><kbd class="bg-gray-100 px-2 py-0.5 rounded font-mono">N</kbd></div>
    <div class="flex justify-between"><span class="text-gray-600">Bulk select</span><kbd class="bg-gray-100 px-2 py-0.5 rounded font-mono">B</kbd></div>
    <div class="flex justify-between"><span class="text-gray-600">Tutup modal/panel</span><kbd class="bg-gray-100 px-2 py-0.5 rounded font-mono">Esc</kbd></div>
    <div class="flex justify-between"><span class="text-gray-600">Bantuan</span><kbd class="bg-gray-100 px-2 py-0.5 rounded font-mono">?</kbd></div>
  </div>
</div>

<!-- Kanban Board -->
<div class="flex lg:grid lg:grid-cols-3 gap-4 lg:gap-6 overflow-x-auto pb-4 lg:pb-0 snap-x snap-mandatory" id="kanban-board" style="-webkit-overflow-scrolling:touch">
  <!-- To Do -->
  <div class="bg-white rounded-2xl lg:rounded-3xl p-3 sm:p-5 border shadow-sm min-w-[85vw] lg:min-w-0 snap-start">
    <div class="flex items-center justify-between mb-3 sm:mb-4 px-1">
      <div class="flex items-center gap-2">
        <div class="w-2.5 h-2.5 sm:w-3 sm:h-3 bg-gray-400 rounded-full"></div>
        <span class="font-semibold text-sm sm:text-lg">To Do</span>
      </div>
      <span class="bg-gray-100 text-gray-600 text-[10px] sm:text-xs px-2 sm:px-3 py-0.5 sm:py-1 rounded-full font-mono" id="count-todo">0</span>
    </div>
    <div id="column-TODO" class="kanban-column space-y-2 sm:space-y-3 min-h-[200px] sm:min-h-[420px] p-1.5 sm:p-2 rounded-xl sm:rounded-2xl bg-gray-50" 
         ondrop="drop(event, 'TODO')" ondragover="allowDrop(event)">
      <!-- Tasks populated by JS -->
    </div>
  </div>

  <!-- In Progress -->
  <div class="bg-white rounded-2xl lg:rounded-3xl p-3 sm:p-5 border shadow-sm min-w-[85vw] lg:min-w-0 snap-start">
    <div class="flex items-center justify-between mb-3 sm:mb-4 px-1">
      <div class="flex items-center gap-2">
        <div class="w-2.5 h-2.5 sm:w-3 sm:h-3 bg-amber-400 rounded-full"></div>
        <span class="font-semibold text-sm sm:text-lg">Doing</span>
      </div>
      <span class="bg-amber-100 text-amber-600 text-[10px] sm:text-xs px-2 sm:px-3 py-0.5 sm:py-1 rounded-full font-mono" id="count-in_progress">0</span>
    </div>
    <div id="column-IN_PROGRESS" class="kanban-column space-y-2 sm:space-y-3 min-h-[200px] sm:min-h-[420px] p-1.5 sm:p-2 rounded-xl sm:rounded-2xl bg-gray-50" 
         ondrop="drop(event, 'IN_PROGRESS')" ondragover="allowDrop(event)">
    </div>
  </div>

  <!-- Done -->
  <div class="bg-white rounded-2xl lg:rounded-3xl p-3 sm:p-5 border shadow-sm min-w-[85vw] lg:min-w-0 snap-start">
    <div class="flex items-center justify-between mb-3 sm:mb-4 px-1">
      <div class="flex items-center gap-2">
        <div class="w-2.5 h-2.5 sm:w-3 sm:h-3 bg-emerald-500 rounded-full"></div>
        <span class="font-semibold text-sm sm:text-lg">Done</span>
      </div>
      <span class="bg-emerald-100 text-emerald-600 text-[10px] sm:text-xs px-2 sm:px-3 py-0.5 sm:py-1 rounded-full font-mono" id="count-done">0</span>
    </div>
    <div id="column-DONE" class="kanban-column space-y-2 sm:space-y-3 min-h-[200px] sm:min-h-[420px] p-1.5 sm:p-2 rounded-xl sm:rounded-2xl bg-gray-50" 
         ondrop="drop(event, 'DONE')" ondragover="allowDrop(event)">
    </div>
  </div>
</div>

<!-- Swipe hint (mobile) -->
<p class="text-center text-xs text-gray-400 mt-2 lg:hidden"><i class="fas fa-arrows-alt-h mr-1"></i>Geser ke kiri/kanan untuk lihat kolom lain</p>

<!-- Column Indicator Dots (mobile) -->
<div id="column-dots" class="flex justify-center gap-2 mt-3 lg:hidden">
  <button onclick="scrollToColumn(0)" class="column-dot w-2.5 h-2.5 rounded-full bg-blue-600 transition-all" data-col="0"></button>
  <button onclick="scrollToColumn(1)" class="column-dot w-2.5 h-2.5 rounded-full bg-gray-300 transition-all" data-col="1"></button>
  <button onclick="scrollToColumn(2)" class="column-dot w-2.5 h-2.5 rounded-full bg-gray-300 transition-all" data-col="2"></button>
</div>

<!-- Chat Section -->
<div class="mt-6 sm:mt-10 bg-white rounded-2xl sm:rounded-3xl border shadow-sm">
  <button onclick="toggleChat()" id="chat-toggle-btn" class="w-full px-4 sm:px-6 py-4 sm:py-6 flex items-center justify-between">
    <h3 class="font-semibold text-base sm:text-xl flex items-center gap-2">
      <i class="fas fa-comments text-blue-600"></i>
      Chat Proyek
    </h3>
    <i class="fas fa-chevron-down text-gray-400 transform transition-transform duration-300 sm:hidden" id="chat-chevron"></i>
  </button>
  <div id="chat-content" class="px-4 sm:px-6 pb-4 sm:pb-6">

  <div id="pinned-messages" class="hidden mb-3 space-y-1.5"></div>

  <div id="chat-messages" class="h-48 sm:h-72 overflow-y-auto bg-gray-50 rounded-xl sm:rounded-2xl p-3 sm:p-4 mb-3 sm:mb-4 space-y-3 sm:space-y-4 text-xs sm:text-sm">
    <!-- Messages loaded via JS -->
  </div>
  
  <div id="chat-file-pill" class="hidden mb-3 text-xs text-blue-700 bg-blue-50 border border-blue-100 rounded-xl px-3 py-2"></div>
  <div class="flex gap-2 sm:gap-3">
    <button type="button" onclick="document.getElementById('chat-files').click()"
            class="px-4 border rounded-2xl text-gray-600 hover:bg-gray-50" title="Lampirkan file">
      <i class="fas fa-paperclip"></i>
    </button>
    <input id="chat-files" type="file" multiple class="hidden" onchange="handleChatFiles(this.files)">
    <input id="chat-input" type="text" placeholder="Ketik pesan..." 
           class="flex-1 border rounded-2xl px-5 py-3 focus:outline-none focus:border-blue-400"
           onkeypress="if(event.key === 'Enter' && !event.shiftKey) sendMessage()">
    <button onclick="sendMessage()" 
             class="px-5 sm:px-8 bg-blue-600 text-white rounded-2xl hover:bg-blue-700 flex items-center">
      <i class="fas fa-paper-plane"></i>
    </button>
    </div>
    </div>
    </div>

<!-- Create Task Modal -->
<div id="createTaskModal" class="hidden fixed inset-0 flex items-end sm:items-center justify-center z-[100]" style="backdrop-filter:blur(4px); background:rgba(0,0,0,0.5);">
  <div class="bg-white w-full sm:max-w-lg mx-0 sm:mx-4 rounded-t-3xl sm:rounded-3xl p-5 sm:p-8 max-h-[85vh] overflow-y-auto transform transition-transform duration-300 translate-y-0">
    <!-- Drag handle (mobile) -->
    <div class="flex justify-center mb-4 sm:hidden cursor-grab active:cursor-grabbing" id="create-modal-handle">
      <div class="w-10 h-1.5 bg-gray-300 rounded-full"></div>
    </div>
    <h3 class="text-2xl font-bold mb-6">Buat Tugas Baru</h3>
    
    <form id="createTaskForm" onsubmit="createTask(event)">
      <input type="hidden" name="projectId" value="<%= project.id %>">
      
      <div class="space-y-5">
        <div>
          <label class="block text-sm font-medium mb-1.5">Judul Tugas *</label>
          <input type="text" name="title" required class="w-full border rounded-2xl px-5 py-3">
        </div>
        
        <div>
          <label class="block text-sm font-medium mb-1.5">Deskripsi</label>
          <textarea name="description" rows="3" class="w-full border rounded-2xl px-5 py-3"></textarea>
        </div>
        
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium mb-1.5">Ditugaskan ke</label>
            <select name="assigneeId" class="w-full border rounded-2xl px-5 py-3">
              <option value="">Belum ditugaskan</option>
              <% members.forEach(member => { %>
                <option value="<%= member.id %>"><%= member.name %></option>
              <% }) %>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium mb-1.5">Deadline</label>
            <input type="date" name="dueDate" class="w-full border rounded-2xl px-5 py-3">
          </div>
          <div>
            <label class="block text-sm font-medium mb-1.5">Prioritas</label>
            <select name="priority" class="w-full border rounded-2xl px-5 py-3">
              <option value="NONE">Tanpa Prioritas</option>
              <option value="LOW">🔵 Low</option>
              <option value="MEDIUM">🟡 Medium</option>
              <option value="HIGH">🟠 High</option>
              <option value="URGENT">🔴 Urgent</option>
            </select>
          </div>
        </div>
      </div>
      
      <div class="flex gap-3 mt-8">
        <button type="button" onclick="hideCreateTaskModal()"
                class="flex-1 py-3.5 border rounded-2xl font-medium">Batal</button>
        <button type="submit"
                class="flex-1 py-3.5 bg-blue-600 text-white rounded-2xl font-medium hover:bg-blue-700">Buat Tugas</button>
      </div>
    </form>
  </div>
</div>

<!-- Project Members Modal -->
<div id="membersModal" class="hidden fixed inset-0 flex items-end sm:items-center justify-center z-[100]" onclick="if(event.target===this) hideMembersModal()" style="backdrop-filter:blur(4px); background:rgba(0,0,0,0.5);">
  <div class="bg-white w-full sm:max-w-md mx-0 sm:mx-4 rounded-t-3xl sm:rounded-3xl p-6 sm:p-8 max-h-[85vh] overflow-y-auto transform transition-transform duration-300 translate-y-0">
    <!-- Drag handle (mobile) -->
    <div class="flex justify-center mb-4 sm:hidden cursor-grab active:cursor-grabbing" id="members-modal-handle">
      <div class="w-10 h-1.5 bg-gray-300 rounded-full"></div>
    </div>
    <div class="flex items-center justify-between mb-2">
      <h3 class="text-xl font-bold">Anggota Proyek</h3>
      <button onclick="hideMembersModal()" class="p-1.5 rounded-xl hover:bg-gray-100 text-gray-500"><i class="fas fa-times"></i></button>
    </div>
    <p class="text-xs text-gray-400 mb-5">
      <% if (canManageProject) { %>
        Hanya yang ada di daftar ini yang bisa lihat proyek ini. Owner/Partner/Admin brand selalu bisa lihat semua proyek.
      <% } else { %>
        Daftar orang yang punya akses ke proyek ini.
      <% } %>
    </p>

    <div id="members-list" class="space-y-2 mb-5">
      <% if (projectMembers.length === 0) { %>
        <p class="text-sm text-gray-400 text-center py-3" id="members-empty">Belum ada anggota spesifik ditambahkan.</p>
      <% } %>
      <% projectMembers.forEach(pm => { %>
        <div class="flex items-center gap-3 p-2 rounded-xl hover:bg-gray-50" id="member-row-<%= pm.user.id %>">
          <div class="w-8 h-8 bg-blue-600 rounded-full flex items-center justify-center text-white text-xs font-bold shrink-0">
            <%= pm.user.name.charAt(0).toUpperCase() %>
          </div>
          <div class="flex-1 min-w-0">
            <div class="text-sm font-medium truncate"><%= pm.user.name %></div>
            <div class="text-xs text-gray-400 truncate"><%= pm.user.email %></div>
          </div>
          <% if (canManageProject) { %>
            <button onclick="removeProjectMember('<%= pm.user.id %>')" class="text-red-400 hover:text-red-600 text-xs p-1.5" title="Hapus akses">
              <i class="fas fa-times"></i>
            </button>
          <% } %>
        </div>
      <% }) %>
    </div>

    <% if (canManageProject) { %>
      <div class="border-t pt-4">
        <label class="block text-xs font-medium text-gray-500 mb-2">Tambah anggota brand ke proyek ini</label>
        <div class="flex gap-2">
          <select id="add-member-select" class="flex-1 border rounded-xl px-3 py-2 text-sm">
            <option value="">Pilih anggota...</option>
            <% members.forEach(m => { %>
              <% if (!projectMembers.some(pm => pm.user.id === m.id)) { %>
                <option value="<%= m.id %>"><%= m.name %></option>
              <% } %>
            <% }) %>
          </select>
          <button onclick="addProjectMember()" class="px-4 py-2 bg-blue-600 text-white rounded-xl text-sm font-medium hover:bg-blue-700">
            <i class="fas fa-plus"></i>
          </button>
        </div>
      </div>
    <% } %>
  </div>
</div>

<!-- Recurring Task Modal -->
<div id="recurringModal" class="hidden fixed inset-0 flex items-end sm:items-center justify-center z-[100]" onclick="if(event.target===this) hideRecurringModal()" style="backdrop-filter:blur(4px); background:rgba(0,0,0,0.5);">
  <div class="bg-white w-full sm:max-w-lg mx-0 sm:mx-4 rounded-t-3xl sm:rounded-3xl p-6 sm:p-8 max-h-[85vh] overflow-y-auto transform transition-transform duration-300 translate-y-0">
    <!-- Drag handle (mobile) -->
    <div class="flex justify-center mb-4 sm:hidden cursor-grab active:cursor-grabbing" id="recurring-modal-handle">
      <div class="w-10 h-1.5 bg-gray-300 rounded-full"></div>
    </div>
    <div class="flex items-center justify-between mb-2">
      <h3 class="text-xl font-bold">Tugas Berulang</h3>
      <button onclick="hideRecurringModal()" class="p-1.5 rounded-xl hover:bg-gray-100 text-gray-500"><i class="fas fa-times"></i></button>
    </div>
    <p class="text-xs text-gray-400 mb-5">Task baru otomatis dibuat tiap hari/minggu sesuai jadwal, tanpa perlu input manual.</p>

    <div id="recurring-list" class="space-y-2 mb-5">
      <% if (recurringTemplates.length === 0) { %>
        <p class="text-sm text-gray-400 text-center py-3" id="recurring-empty">Belum ada tugas berulang.</p>
      <% } %>
      <% const freqLabel = { DAILY: 'Setiap hari', WEEKDAYS: 'Senin-Jumat', WEEKLY: 'Mingguan' }; %>
      <% const weekdayLabel = ['Minggu','Senin','Selasa','Rabu','Kamis','Jumat','Sabtu']; %>
      <% recurringTemplates.forEach(t => { %>
        <div class="flex items-center gap-3 p-3 rounded-xl border <%= t.active ? '' : 'opacity-50' %>" id="recurring-row-<%= t.id %>">
          <div class="flex-1 min-w-0">
            <div class="text-sm font-medium truncate"><%= t.title %></div>
            <div class="text-xs text-gray-400 truncate">
              <%= freqLabel[t.frequency] %><% if (t.frequency === 'WEEKLY' && t.weekday !== null) { %> (<%= weekdayLabel[t.weekday] %>)<% } %>
              <% if (t.assignee) { %> • PIC: <%= t.assignee.name %><% } %>
            </div>
          </div>
          <button onclick="toggleRecurring('<%= t.id %>')" class="text-xs px-2 py-1 rounded-lg <%= t.active ? 'bg-emerald-50 text-emerald-600 hover:bg-emerald-100' : 'bg-gray-100 text-gray-500 hover:bg-gray-200' %>" title="<%= t.active ? 'Jeda' : 'Lanjutkan' %>">
            <i class="fas <%= t.active ? 'fa-pause' : 'fa-play' %>"></i>
          </button>
          <button onclick="deleteRecurring('<%= t.id %>')" class="text-red-400 hover:text-red-600 text-xs p-1.5" title="Hapus">
            <i class="fas fa-trash"></i>
          </button>
        </div>
      <% }) %>
    </div>

    <div class="border-t pt-4">
      <label class="block text-xs font-medium text-gray-500 mb-2">Buat tugas berulang baru</label>
      <div class="space-y-2">
        <input type="text" id="recurring-title" placeholder="Judul (mis. Posting Konten TikTok)" class="w-full border rounded-xl px-3 py-2 text-sm">
        <div class="grid grid-cols-2 gap-2">
          <select id="recurring-frequency" class="border rounded-xl px-3 py-2 text-sm" onchange="document.getElementById('recurring-weekday-wrap').classList.toggle('hidden', this.value !== 'WEEKLY')">
            <option value="DAILY">Setiap hari</option>
            <option value="WEEKDAYS">Senin-Jumat</option>
            <option value="WEEKLY">Mingguan (pilih hari)</option>
          </select>
          <select id="recurring-assignee" class="border rounded-xl px-3 py-2 text-sm">
            <option value="">Belum ditugaskan</option>
            <% members.forEach(m => { %>
              <option value="<%= m.id %>"><%= m.name %></option>
            <% }) %>
          </select>
        </div>
        <div id="recurring-weekday-wrap" class="hidden">
          <select id="recurring-weekday" class="w-full border rounded-xl px-3 py-2 text-sm">
            <option value="1">Senin</option>
            <option value="2">Selasa</option>
            <option value="3">Rabu</option>
            <option value="4">Kamis</option>
            <option value="5">Jumat</option>
            <option value="6">Sabtu</option>
            <option value="0">Minggu</option>
          </select>
        </div>
        <button onclick="createRecurring()" class="w-full py-2.5 bg-teal-600 text-white rounded-xl text-sm font-medium hover:bg-teal-700">
          <i class="fas fa-plus mr-1"></i>Buat Tugas Berulang
        </button>
      </div>
    </div>
  </div>
</div>

<script>
const projectId = '<%= project.id %>';
const companyId = '<%= project.companyId %>';
let tasks = <%- JSON.stringify(project.tasks) %>;
const socket = io();
let pendingChatFiles = [];

socket.emit('join-project', projectId);
socket.emit('join-user', '<%= currentUserId %>');

// Priority config
const PRIO = {
  NONE:   { label: '', cls: '' },
  LOW:    { label: 'Low',    cls: 'bg-blue-100 text-blue-700' },
  MEDIUM: { label: 'Medium', cls: 'bg-yellow-100 text-yellow-700' },
  HIGH:   { label: 'High',   cls: 'bg-orange-100 text-orange-700' },
  URGENT: { label: 'Urgent', cls: 'bg-red-100 text-red-700' }
};

let activeFilter = 'ALL';

function escapeHtml(value) {
  return String(value || '').replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#039;'}[c]));
}

function showProjectEdit() {
  document.getElementById('project-edit-form')?.classList.remove('hidden');
  document.getElementById('project-desc-display')?.classList.add('hidden');
  document.getElementById('project-name-input')?.focus();
}

function hideProjectEdit() {
  const form = document.getElementById('project-edit-form');
  if (!form) return;
  form.classList.add('hidden');
  document.getElementById('project-desc-display')?.classList.remove('hidden');
  document.getElementById('project-name-input').value = document.getElementById('project-title').textContent.trim();
  document.getElementById('project-desc-input').value = document.getElementById('project-desc-text').dataset.raw || '';
}

async function saveProjectEdit() {
  const nameInput = document.getElementById('project-name-input');
  const descInput = document.getElementById('project-desc-input');
  const name = nameInput.value.trim();
  const description = descInput.value.trim();

  if (!name) {
    alert('Nama proyek wajib diisi');
    nameInput.focus();
    return;
  }

  const res = await fetch(`/projects/${projectId}`, {
    method: 'PATCH',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ name, description })
  });
  const data = await res.json().catch(() => ({}));
  if (!res.ok || !data.success) {
    alert(data.error || 'Gagal memperbarui proyek');
    return;
  }

  document.getElementById('project-title').textContent = data.project.name;
  const descText = document.getElementById('project-desc-text');
  descText.textContent = data.project.description || 'Proyek kolaborasi tim';
  descText.dataset.raw = data.project.description || '';
  hideProjectEdit();
}

function renderAttachment(file) {
  const name = escapeHtml(file.originalName || file.filename);
  if ((file.mimeType || '').startsWith('image/')) {
    return `<a href="${file.url}" target="_blank" class="block mt-2"><img src="${file.url}" alt="${name}" class="max-h-56 rounded-2xl border object-contain bg-white"></a>`;
  }
  return `<a href="${file.url}" target="_blank" class="inline-flex items-center gap-2 mt-2 px-3 py-2 rounded-xl bg-white border text-gray-700 hover:bg-gray-50"><i class="fas fa-file"></i><span>${name}</span></a>`;
}

function setFilter(f) {
  activeFilter = f;
  document.querySelectorAll('[id^="filter-"]').forEach(btn => {
    btn.classList.remove('bg-blue-600','text-white','border-blue-600');
    btn.classList.add('bg-white');
  });
  const active = document.getElementById(`filter-${f}`);
  if (active) { active.classList.add('bg-blue-600','text-white','border-blue-600'); active.classList.remove('bg-white'); }
  renderKanban();
}

// Render Kanban
function renderKanban() {
  const columns = {
    'TODO': document.getElementById('column-TODO'),
    'IN_PROGRESS': document.getElementById('column-IN_PROGRESS'),
    'DONE': document.getElementById('column-DONE')
  };

  Object.values(columns).forEach(col => col.innerHTML = '');
  let counts = { TODO: 0, IN_PROGRESS: 0, DONE: 0 };

  const filtered = activeFilter === 'ALL' ? tasks : tasks.filter(t => t.priority === activeFilter);

  filtered.forEach(task => {
    const column = columns[task.status];
    if (!column) return;
    counts[task.status]++;

    const prio = PRIO[task.priority] || PRIO.NONE;
    const isOverdue = task.dueDate && new Date(task.dueDate) < new Date() && task.status !== 'DONE';
    const labels = (task.labels || []).map(tl => tl.label).filter(Boolean);

    const card = document.createElement('div');
    card.className = 'task-card bg-white border p-3 sm:p-4 rounded-xl sm:rounded-2xl cursor-grab active:cursor-grabbing';
    card.draggable = true;
    card.dataset.id = task.id;
    card.id = `card-${task.id}`;
    card.ondragstart = (e) => drag(e, task.id);
    card.onclick = () => { if (bulkMode) { toggleSelect(task.id); } else { openPreview(task.id); } };
    if (selectedTasks.has(task.id)) { card.classList.add('ring-2', 'ring-blue-500'); }

    // Quick-move button
    let moveBtn = '';
    if (task.status === 'TODO') moveBtn = `<button onclick="event.stopPropagation(); moveStatus('${task.id}','IN_PROGRESS')" class="px-2 py-0.5 sm:px-2.5 sm:py-1 bg-amber-100 text-amber-700 rounded-md sm:rounded-lg text-[9px] sm:text-[10px] font-semibold hover:bg-amber-200 transition whitespace-nowrap" title="Pindah ke Doing"><i class="fas fa-play mr-0.5 sm:mr-1"></i>Mulai</button>`;
    else if (task.status === 'IN_PROGRESS') moveBtn = `<button onclick="event.stopPropagation(); moveStatus('${task.id}','DONE')" class="px-2 py-0.5 sm:px-2.5 sm:py-1 bg-emerald-100 text-emerald-700 rounded-md sm:rounded-lg text-[9px] sm:text-[10px] font-semibold hover:bg-emerald-200 transition whitespace-nowrap" title="Tandai Selesai"><i class="fas fa-check mr-0.5 sm:mr-1"></i>Selesai</button>`;
    else moveBtn = `<button onclick="event.stopPropagation(); moveStatus('${task.id}','TODO')" class="px-2 py-0.5 sm:px-2.5 sm:py-1 bg-gray-100 text-gray-600 rounded-md sm:rounded-lg text-[9px] sm:text-[10px] font-semibold hover:bg-gray-200 transition whitespace-nowrap" title="Buka Lagi"><i class="fas fa-undo mr-0.5 sm:mr-1"></i>Buka</button>`;

    // Checklist progress
    const checklists = task.checklists || [];
    const doneCount = checklists.filter(c => c.isDone).length;
    const checkPct = checklists.length > 0 ? Math.round(doneCount / checklists.length * 100) : 0;

    // Children count
    const childrenCount = task.children ? task.children.length : 0;

    card.innerHTML = `
      <div class="flex justify-between items-start mb-2 gap-2">
        <a href="/tasks/${task.id}" onclick="event.stopPropagation()" class="font-semibold text-sm hover:text-blue-600 leading-tight flex-1">${escapeHtml(task.title)}</a>
        ${task.assignee ? `<div class="text-[10px] bg-blue-100 text-blue-700 px-2 py-0.5 rounded-full whitespace-nowrap shrink-0">${escapeHtml(task.assignee.name.split(' ')[0])}</div>` : ''}
      </div>
      ${task.description ? `<p class="text-xs text-gray-500 line-clamp-2 mb-2">${escapeHtml(task.description)}</p>` : ''}
      ${labels.length ? `<div class="flex flex-wrap gap-1 mb-2">${labels.map(label => `<span class="text-[10px] font-semibold rounded-full px-2 py-0.5 text-white" style="background:${escapeHtml(label.color)}">${escapeHtml(label.name)}</span>`).join('')}</div>` : ''}
      ${checklists.length > 0 ? `<div class="flex items-center gap-2 mb-2">
        <div class="flex-1 h-1.5 bg-gray-100 rounded-full overflow-hidden"><div class="h-full rounded-full transition-all ${checkPct === 100 ? 'bg-emerald-500' : 'bg-blue-500'}" style="width:${checkPct}%"></div></div>
        <span class="text-[10px] text-gray-400 whitespace-nowrap">${doneCount}/${checklists.length}</span>
      </div>` : ''}
      <div class="flex items-center justify-between text-xs mt-2 gap-2">
        <div class="flex items-center gap-1.5 flex-wrap">
          ${prio.label ? `<span class="px-2 py-0.5 rounded-full text-[10px] font-semibold ${prio.cls}">${prio.label}</span>` : ''}
          ${task.dueDate ? `<span class="${isOverdue ? 'text-red-500 font-semibold' : 'text-gray-400'}"><i class="fas fa-clock mr-0.5"></i>${new Date(task.dueDate).toLocaleDateString('id-ID',{month:'short',day:'numeric'})}</span>` : ''}
          ${childrenCount > 0 ? `<span class="px-2 py-0.5 rounded-full text-[10px] font-semibold bg-indigo-100 text-indigo-700"><i class="fas fa-sitemap mr-0.5"></i>${childrenCount}</span>` : ''}
        </div>
        <div class="flex items-center gap-1 shrink-0">
          ${moveBtn}
          <a href="/tasks/${task.id}" onclick="event.stopPropagation()" class="p-1.5 text-gray-400 hover:text-blue-600" title="Lihat Detail"><i class="fas fa-external-link-alt fa-xs"></i></a>
          <button onclick="event.stopPropagation(); deleteTask('${task.id}')" class="p-1.5 text-gray-400 hover:text-red-500" title="Hapus"><i class="fas fa-trash fa-xs"></i></button>
        </div>
      </div>
    `;

    column.appendChild(card);
  });

  document.getElementById('count-todo').textContent = counts.TODO;
  document.getElementById('count-in_progress').textContent = counts.IN_PROGRESS;
  document.getElementById('count-done').textContent = counts.DONE;
}

// Drag and Drop functions
let draggedTaskId = null;

function drag(ev, taskId) {
  draggedTaskId = taskId;
  ev.dataTransfer.setData("text", taskId);
}

// Quick-move status button
async function moveStatus(taskId, newStatus) {
  const task = tasks.find(t => t.id === taskId);
  if (!task) return;
  const oldStatus = task.status;
  task.status = newStatus;
  renderKanban();
  try {
    const res = await fetch(`/tasks/${taskId}/status`, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ status: newStatus })
    });
    if (!res.ok) throw new Error('failed');
    socket.emit('task-updated', { taskId, status: newStatus, projectId });
  } catch (e) {
    task.status = oldStatus;
    renderKanban();
  }
}

// Task preview panel
function openPreview(taskId) {
  const task = tasks.find(t => t.id === taskId);
  if (!task) return;

  const checklists = task.checklists || [];
  const doneCount = checklists.filter(c => c.isDone).length;
  const checkPct = checklists.length > 0 ? Math.round(doneCount / checklists.length * 100) : 0;
  const pendingItems = checklists.filter(c => !c.isDone);

  const PRIO_MAP = { URGENT: { label: '🔴 Urgent', cls: 'bg-red-100 text-red-700' }, HIGH: { label: '🟠 High', cls: 'bg-orange-100 text-orange-700' }, MEDIUM: { label: '🟡 Medium', cls: 'bg-yellow-100 text-yellow-700' }, LOW: { label: '🟢 Low', cls: 'bg-green-100 text-green-700' }, NONE: { label: '', cls: '' } };
  const prio = PRIO_MAP[task.priority] || PRIO_MAP.NONE;
  const STATUS_MAP = { TODO: '📋 To Do', IN_PROGRESS: '🔄 Doing', DONE: '✅ Done' };

  document.getElementById('preview-title').textContent = task.title;
  document.getElementById('preview-status').textContent = STATUS_MAP[task.status] || task.status;
  document.getElementById('preview-priority').innerHTML = prio.label ? `<span class="px-2 py-0.5 rounded-full text-xs font-semibold ${prio.cls}">${prio.label}</span>` : '-';
  document.getElementById('preview-due').textContent = task.dueDate ? new Date(task.dueDate).toLocaleDateString('id-ID', { weekday: 'short', day: 'numeric', month: 'short', year: 'numeric' }) : '-';
  document.getElementById('preview-assignee').textContent = task.assignee ? task.assignee.name : '-';
  document.getElementById('preview-desc').textContent = task.description || '-';

  // Checklist progress
  document.getElementById('preview-check-pct').textContent = checklists.length > 0 ? `${checkPct}%` : '-';
  document.getElementById('preview-check-bar').style.width = `${checkPct}%`;
  document.getElementById('preview-check-bar').className = `h-full rounded-full transition-all ${checkPct === 100 ? 'bg-emerald-500' : 'bg-blue-500'}`;

  // Pending items
  const pendingList = document.getElementById('preview-pending');
  pendingList.innerHTML = '';
  if (pendingItems.length > 0) {
    pendingItems.forEach(item => {
      const div = document.createElement('div');
      div.className = 'flex items-center gap-2 text-sm text-gray-600';
      div.innerHTML = `<i class="far fa-square text-gray-400"></i><span>${escapeHtml(item.content)}</span>`;
      pendingList.appendChild(div);
    });
  } else if (checklists.length > 0) {
    pendingList.innerHTML = '<p class="text-sm text-emerald-600 font-medium"><i class="fas fa-check-circle mr-1"></i>Semua selesai!</p>';
  } else {
    pendingList.innerHTML = '<p class="text-sm text-gray-400">Belum ada checklist</p>';
  }

  document.getElementById('preview-detail-link').href = `/tasks/${task.id}`;
  document.getElementById('preview-panel').classList.remove('translate-x-full');
}

function closePreview() {
  document.getElementById('preview-panel').classList.add('translate-x-full');
}

function allowDrop(ev) {
  ev.preventDefault();
}

async function drop(ev, newStatus) {
  ev.preventDefault();
  const taskId = ev.dataTransfer.getData("text") || draggedTaskId;
  
  if (!taskId) return;

  // Find task
  const taskIndex = tasks.findIndex(t => t.id === taskId);
  if (!taskIndex && taskIndex !== 0) return;

  const oldStatus = tasks[taskIndex].status;
  
  if (oldStatus === newStatus) return;

  // Optimistic update
  tasks[taskIndex].status = newStatus;
  renderKanban();

  // Update backend
  try {
    const res = await fetch(`/tasks/${taskId}/status`, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ status: newStatus })
    });
    
    if (res.ok) {
      // Emit to others
      socket.emit('task-updated', { taskId, status: newStatus, projectId });
    }
  } catch (e) {
    console.error(e);
    // Revert on error
    tasks[taskIndex].status = oldStatus;
    renderKanban();
    alert('Gagal update status tugas');
  }
}

// Socket listeners
socket.on('task-updated', (data) => {
  const taskIndex = tasks.findIndex(t => t.id === data.taskId);
  if (taskIndex > -1) {
    tasks[taskIndex].status = data.status;
    renderKanban();
  }
});

socket.on('new-message', (msg) => {
  appendMessage(msg);
});

// Create Task
function showCreateTaskModal() {
  document.getElementById('createTaskModal').classList.remove('hidden');
}

function hideCreateTaskModal() {
  document.getElementById('createTaskModal').classList.add('hidden');
  document.getElementById('createTaskForm').reset();
}

async function createTask(e) {
  e.preventDefault();
  const form = e.target;
  const formData = new FormData(form);
  
  const data = Object.fromEntries(formData.entries());
  if (!data.priority) data.priority = 'NONE';

  try {
    const res = await fetch('/tasks/create', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data)
    });

    const result = await res.json();
    if (result.success) {
      const newTask = result.task;
      newTask.labels = newTask.labels || [];
      newTask.checklists = newTask.checklists || [];
      tasks.push(newTask);
      renderKanban();
      hideCreateTaskModal();
      form.reset();
    }
  } catch (err) {
    alert('Gagal membuat tugas');
  }
}

// Project members
function showMembersModal() {
  document.getElementById('membersModal').classList.remove('hidden');
}

function hideMembersModal() {
  document.getElementById('membersModal').classList.add('hidden');
}

async function addProjectMember() {
  const select = document.getElementById('add-member-select');
  const userId = select.value;
  if (!userId) return;
  const name = select.options[select.selectedIndex].textContent;

  try {
    const res = await fetch(`/projects/${projectId}/members`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ userId })
    });
    const data = await res.json();
    if (!data.success) return alert(data.error || 'Gagal menambah anggota');

    document.getElementById('members-empty')?.remove();
    const list = document.getElementById('members-list');
    const row = document.createElement('div');
    row.className = 'flex items-center gap-3 p-2 rounded-xl hover:bg-gray-50';
    row.id = `member-row-${userId}`;
    row.innerHTML = `
      <div class="w-8 h-8 bg-blue-600 rounded-full flex items-center justify-center text-white text-xs font-bold shrink-0">${name.charAt(0).toUpperCase()}</div>
      <div class="flex-1 min-w-0"><div class="text-sm font-medium truncate">${escapeHtml(name)}</div></div>
      <button onclick="removeProjectMember('${userId}')" class="text-red-400 hover:text-red-600 text-xs p-1.5" title="Hapus akses"><i class="fas fa-times"></i></button>
    `;
    list.appendChild(row);
    select.querySelector(`option[value="${userId}"]`)?.remove();
    select.value = '';
  } catch (e) {
    alert('Gagal menambah anggota');
  }
}

async function removeProjectMember(userId) {
  if (!confirm('Hapus akses proyek untuk anggota ini?')) return;
  try {
    const res = await fetch(`/projects/${projectId}/members/${userId}`, { method: 'DELETE' });
    const data = await res.json();
    if (data.success) {
      document.getElementById(`member-row-${userId}`)?.remove();
    } else {
      alert(data.error || 'Gagal menghapus anggota');
    }
  } catch (e) {
    alert('Gagal menghapus anggota');
  }
}

// Recurring tasks
function showRecurringModal() {
  document.getElementById('recurringModal').classList.remove('hidden');
}

function hideRecurringModal() {
  document.getElementById('recurringModal').classList.add('hidden');
}

async function createRecurring() {
  const title = document.getElementById('recurring-title').value.trim();
  if (!title) return alert('Judul wajib diisi');
  const frequency = document.getElementById('recurring-frequency').value;
  const assigneeId = document.getElementById('recurring-assignee').value;
  const weekday = document.getElementById('recurring-weekday').value;

  try {
    const res = await fetch(`/projects/${projectId}/recurring`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ title, frequency, assigneeId, weekday })
    });
    const data = await res.json();
    if (!data.success) return alert(data.error || 'Gagal membuat tugas berulang');

    const freqLabel = { DAILY: 'Setiap hari', WEEKDAYS: 'Senin-Jumat', WEEKLY: 'Mingguan' };
    const weekdayLabel = ['Minggu','Senin','Selasa','Rabu','Kamis','Jumat','Sabtu'];
    const t = data.template;
    document.getElementById('recurring-empty')?.remove();
    const row = document.createElement('div');
    row.className = 'flex items-center gap-3 p-3 rounded-xl border';
    row.id = `recurring-row-${t.id}`;
    row.innerHTML = `
      <div class="flex-1 min-w-0">
        <div class="text-sm font-medium truncate">${escapeHtml(t.title)}</div>
        <div class="text-xs text-gray-400 truncate">${freqLabel[t.frequency]}${t.frequency === 'WEEKLY' && t.weekday !== null ? ` (${weekdayLabel[t.weekday]})` : ''}${t.assignee ? ` • PIC: ${escapeHtml(t.assignee.name)}` : ''}</div>
      </div>
      <button onclick="toggleRecurring('${t.id}')" class="text-xs px-2 py-1 rounded-lg bg-emerald-50 text-emerald-600 hover:bg-emerald-100" title="Jeda"><i class="fas fa-pause"></i></button>
      <button onclick="deleteRecurring('${t.id}')" class="text-red-400 hover:text-red-600 text-xs p-1.5" title="Hapus"><i class="fas fa-trash"></i></button>
    `;
    document.getElementById('recurring-list').appendChild(row);
    document.getElementById('recurring-title').value = '';
  } catch (e) {
    alert('Gagal membuat tugas berulang');
  }
}

async function toggleRecurring(id) {
  try {
    const res = await fetch(`/projects/${projectId}/recurring/${id}/toggle`, { method: 'POST' });
    const data = await res.json();
    if (!data.success) return alert(data.error || 'Gagal update');
    const row = document.getElementById(`recurring-row-${id}`);
    const btn = row.querySelector('button');
    row.classList.toggle('opacity-50', !data.active);
    btn.className = `text-xs px-2 py-1 rounded-lg ${data.active ? 'bg-emerald-50 text-emerald-600 hover:bg-emerald-100' : 'bg-gray-100 text-gray-500 hover:bg-gray-200'}`;
    btn.innerHTML = `<i class="fas ${data.active ? 'fa-pause' : 'fa-play'}"></i>`;
  } catch (e) {
    alert('Gagal update tugas berulang');
  }
}

async function deleteRecurring(id) {
  if (!confirm('Hapus tugas berulang ini? Task yang sudah pernah dibuat tidak akan terhapus.')) return;
  try {
    const res = await fetch(`/projects/${projectId}/recurring/${id}`, { method: 'DELETE' });
    const data = await res.json();
    if (data.success) document.getElementById(`recurring-row-${id}`)?.remove();
    else alert(data.error || 'Gagal menghapus');
  } catch (e) {
    alert('Gagal menghapus');
  }
}

// Delete task
async function deleteTask(taskId) {
  if (!confirm('Hapus tugas ini?')) return;
  
  try {
    await fetch(`/tasks/${taskId}`, { method: 'DELETE' });
    tasks = tasks.filter(t => t.id !== taskId);
    renderKanban();
  } catch (e) {
    alert('Gagal menghapus');
  }
}


// Chat functions
let chatMessages = [];

async function loadChatMessages() {
  try {
    const res = await fetch(`/chat/messages/${projectId}`);
    const messages = await res.json();
    chatMessages = messages;
    const container = document.getElementById('chat-messages');
    container.innerHTML = '';
    messages.forEach(msg => appendMessage(msg, false));
    container.scrollTop = container.scrollHeight;
    renderPinnedBar();
  } catch (e) {}
}

function appendMessage(msg, scroll = true) {
  const container = document.getElementById('chat-messages');
  if (msg.id && document.getElementById(`chat-msg-${msg.id}`)) return;
  if (msg.id && !chatMessages.some(m => m.id === msg.id)) chatMessages.push(msg);
  const isMe = msg.user && msg.user.id === '<%= currentUserId %>';

  const div = document.createElement('div');
  if (msg.id) div.id = `chat-msg-${msg.id}`;
  div.className = `flex ${isMe ? 'justify-end' : ''} group`;
  div.innerHTML = `
    <div class="relative ${isMe ? 'bg-blue-600 text-white' : 'bg-white border'} max-w-[75%] px-4 py-2.5 rounded-3xl ${isMe ? 'rounded-tr-none' : 'rounded-tl-none'}">
      ${msg.id ? `<button onclick="togglePin('${msg.id}')" class="absolute -top-2 ${isMe ? '-left-2' : '-right-2'} w-6 h-6 rounded-full bg-white border shadow text-[10px] opacity-0 group-hover:opacity-100 transition flex items-center justify-center ${msg.pinned ? 'text-amber-500 opacity-100' : 'text-gray-400 hover:text-amber-500'}" title="${msg.pinned ? 'Lepas pin' : 'Pin pesan'}"><i class="fas fa-thumbtack"></i></button>` : ''}
      <div class="text-xs opacity-70 mb-0.5">${msg.user ? escapeHtml(msg.user.name) : 'User'}</div>
      ${msg.content ? `<div class="whitespace-pre-wrap">${escapeHtml(msg.content)}</div>` : ''}
      ${(msg.attachments || []).map(renderAttachment).join('')}
    </div>
  `;
  container.appendChild(div);
  if (scroll) container.scrollTop = container.scrollHeight;
}

function renderPinnedBar() {
  const wrap = document.getElementById('pinned-messages');
  const pinned = chatMessages.filter(m => m.pinned);
  if (pinned.length === 0) {
    wrap.classList.add('hidden');
    wrap.innerHTML = '';
    return;
  }
  wrap.classList.remove('hidden');
  wrap.innerHTML = pinned.map(m => `
    <div class="flex items-center gap-2 bg-amber-50 border border-amber-200 rounded-xl px-3 py-2 text-xs">
      <i class="fas fa-thumbtack text-amber-500 shrink-0"></i>
      <span class="font-medium shrink-0">${escapeHtml(m.user?.name || 'User')}:</span>
      <span class="truncate flex-1">${escapeHtml(m.content || '(file)')}</span>
      <button onclick="togglePin('${m.id}')" class="text-amber-600 hover:text-amber-800 shrink-0" title="Lepas pin"><i class="fas fa-times"></i></button>
    </div>
  `).join('');
}

async function togglePin(messageId) {
  try {
    const res = await fetch(`/chat/messages/${messageId}/pin`, { method: 'POST' });
    const data = await res.json();
    if (!data.success) return;
    const msg = chatMessages.find(m => m.id === messageId);
    if (msg) msg.pinned = data.pinned;
    const btn = document.querySelector(`#chat-msg-${messageId} button[onclick^="togglePin"]`);
    if (btn) {
      btn.classList.toggle('text-amber-500', data.pinned);
      btn.classList.toggle('opacity-100', data.pinned);
      btn.classList.toggle('text-gray-400', !data.pinned);
      btn.title = data.pinned ? 'Lepas pin' : 'Pin pesan';
    }
    renderPinnedBar();
  } catch (e) {
    alert('Gagal pin pesan');
  }
}

function refreshChatFilePill() {
  const pill = document.getElementById('chat-file-pill');
  if (pendingChatFiles.length === 0) {
    pill.classList.add('hidden');
    pill.textContent = '';
    return;
  }
  pill.classList.remove('hidden');
  pill.textContent = `${pendingChatFiles.length} file siap dikirim`;
}

function handleChatFiles(files) {
  pendingChatFiles = [...pendingChatFiles, ...Array.from(files || [])];
  refreshChatFilePill();
}

document.addEventListener('paste', (event) => {
  const files = [];
  for (const item of event.clipboardData?.items || []) {
    if (item.kind === 'file') files.push(item.getAsFile());
  }
  if (files.length > 0) {
    handleChatFiles(files.filter(Boolean));
    event.preventDefault();
  }
});

async function sendMessage() {
  const input = document.getElementById('chat-input');
  const content = input.value.trim();
  if (!content && pendingChatFiles.length === 0) return;

  try {
    const form = new FormData();
    form.append('content', content);
    pendingChatFiles.forEach(file => form.append('files', file));

    const res = await fetch(`/chat/messages/${projectId}`, { method: 'POST', body: form });
    
    const result = await res.json();
    if (result.success) {
      appendMessage(result.message);
      socket.emit('new-message', result.message);
      input.value = '';
      pendingChatFiles = [];
      document.getElementById('chat-files').value = '';
      refreshChatFilePill();
    }
  } catch (e) {
    // Fallback local
    appendMessage({ content, user: { name: 'Anda' } });
    input.value = '';
  }
}

// Initialize everything
// Bulk select
let selectedTasks = new Set();
let bulkMode = false;

function toggleBulkMode() {
  bulkMode = !bulkMode;
  selectedTasks.clear();
  document.getElementById('bulk-bar').classList.toggle('hidden', !bulkMode);
  renderKanban();
}

function toggleSelect(taskId) {
  if (selectedTasks.has(taskId)) selectedTasks.delete(taskId);
  else selectedTasks.add(taskId);
  document.getElementById(`card-${taskId}`).classList.toggle('ring-2', selectedTasks.has(taskId));
  document.getElementById(`card-${taskId}`).classList.toggle('ring-blue-500', selectedTasks.has(taskId));
  document.getElementById('bulk-count').textContent = selectedTasks.size;
}

async function bulkMove(status) {
  for (const taskId of selectedTasks) {
    const task = tasks.find(t => t.id === taskId);
    if (task) {
      task.status = status;
      await fetch(`/tasks/${taskId}/status`, {
        method: 'PATCH', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ status })
      });
    }
  }
  selectedTasks.clear();
  bulkMode = false;
  document.getElementById('bulk-bar').classList.add('hidden');
  renderKanban();
}

async function bulkDelete() {
  if (!confirm(`Hapus ${selectedTasks.size} task?`)) return;
  for (const taskId of selectedTasks) {
    await fetch(`/tasks/${taskId}`, { method: 'DELETE' });
    tasks = tasks.filter(t => t.id !== taskId);
  }
  selectedTasks.clear();
  bulkMode = false;
  document.getElementById('bulk-bar').classList.add('hidden');
  renderKanban();
}

async function bulkAssign() {
  const select = document.getElementById('bulk-assign-select');
  const assigneeId = select.value;
  if (!assigneeId) return;

  const isClear = assigneeId === '__clear__';
  const body = { assigneeId: isClear ? null : assigneeId };

  for (const taskId of selectedTasks) {
    await fetch(`/tasks/${taskId}/assignee`, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body)
    });
    const task = tasks.find(t => t.id === taskId);
    if (task) {
      task.assignee = isClear ? null : { id: assigneeId, name: select.options[select.selectedIndex].textContent };
    }
  }
  select.value = '';
  renderKanban();
}

async function bulkSetDeadline() {
  const input = document.getElementById('bulk-deadline');
  const dueDate = input.value || null;
  const body = { dueDate };

  for (const taskId of selectedTasks) {
    await fetch(`/tasks/${taskId}/due-date`, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body)
    });
    const task = tasks.find(t => t.id === taskId);
    if (task) {
      task.dueDate = dueDate ? new Date(dueDate).toISOString() : null;
    }
  }
  input.value = '';
  renderKanban();
}

async function bulkMoveToProject() {
  const select = document.getElementById('bulk-project-select');
  const targetProjectId = select.value;
  if (!targetProjectId) return;
  if (!confirm(`Pindahkan ${selectedTasks.size} task ke proyek ini?`)) {
    select.value = '';
    return;
  }

  for (const taskId of selectedTasks) {
    await fetch(`/tasks/${taskId}/project`, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ projectId: targetProjectId })
    });
    // Remove from local list since it moved
    tasks = tasks.filter(t => t.id !== taskId);
  }
  selectedTasks.clear();
  bulkMode = false;
  document.getElementById('bulk-bar').classList.add('hidden');
  select.value = '';
  renderKanban();
}

// Keyboard shortcuts
document.addEventListener('keydown', (e) => {
  if (e.key === 'Enter' && e.shiftKey && e.target.id === 'chat-input') {
    e.preventDefault();
    sendMessage();
    return;
  }

  if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA' || e.target.tagName === 'SELECT') return;
  switch(e.key) {
    case 'n': case 'N':
      showCreateTaskModal();
      e.preventDefault();
      break;
    case 'b': case 'B':
      toggleBulkMode();
      e.preventDefault();
      break;
    case 'Escape':
      hideCreateTaskModal();
      hideTemplateModal();
      closePreview();
      if (bulkMode) toggleBulkMode();
      break;
    case '?':
      document.getElementById('shortcuts-help').classList.toggle('hidden');
      break;
  }
});

