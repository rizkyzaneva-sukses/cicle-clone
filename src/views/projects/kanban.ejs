// --- Column Indicator Dots & Scroll ---
function scrollToColumn(index) {
  const board = document.getElementById('kanban-board');
  const columns = board.querySelectorAll(':scope > div');
  if (columns[index]) {
    columns[index].scrollIntoView({ behavior: 'smooth', inline: 'start', block: 'nearest' });
  }
}

function updateColumnDots() {
  const board = document.getElementById('kanban-board');
  if (!board || window.innerWidth >= 1024) return;
  const columns = Array.from(board.querySelectorAll(':scope > div'));
  const scrollLeft = board.scrollLeft;
  const columnWidth = columns[0]?.offsetWidth || 1;
  const activeIndex = Math.round(scrollLeft / columnWidth);
  document.querySelectorAll('.column-dot').forEach((dot, i) => {
    dot.classList.toggle('bg-blue-600', i === activeIndex);
    dot.classList.toggle('bg-gray-300', i !== activeIndex);
    dot.classList.toggle('w-6', i === activeIndex);
    dot.classList.toggle('w-2.5', i !== activeIndex);
  });
}

document.getElementById('kanban-board')?.addEventListener('scroll', updateColumnDots);
window.addEventListener('resize', updateColumnDots);

