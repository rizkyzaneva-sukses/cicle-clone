        <button type="button" onclick="openPreviewPopover('status', event)" id="preview-status"
          class="w-full text-left text-sm font-semibold px-2 py-1.5 -mx-2 rounded-lg bg-gray-50 hover:bg-gray-100 transition"></button>
        <div id="preview-popover-status" class="hidden absolute left-0 top-full mt-1 z-40 bg-white border rounded-xl shadow-lg p-1.5 w-44">
          <% ['TODO','IN_PROGRESS','DONE'].forEach(s => { %>
            <button type="button" data-value="<%= s %>" class="preview-pop-option w-full text-left flex items-center gap-2 px-2 py-1.5 rounded-lg hover:bg-gray-50 text-sm">
              <% if (s==='TODO') { %><i class="fas fa-circle text-gray-400 text-xs"></i>To Do
              <% } else if (s==='IN_PROGRESS') { %><i class="fas fa-circle text-amber-400 text-xs"></i>In Progress
              <% } else { %><i class="fas fa-circle text-emerald-500 text-xs"></i>Done<% } %>
            </button>
          <% }) %>
        </div>
      </div>
      <div class="relative">
        <div class="text-xs text-gray-400 font-medium mb-1 flex items-center gap-1.5">
          Priority
          <button type="button" onclick="openPreviewPopover('priority', event)" class="text-gray-300 hover:text-blue-500 transition" title="Edit prioritas"><i class="fas fa-pen text-[9px]"></i></button>
        </div>
        <button type="button" onclick="openPreviewPopover('priority', event)" id="preview-priority"
          class="w-full text-left text-sm px-2 py-1.5 -mx-2 rounded-lg bg-gray-50 hover:bg-gray-100 transition"></button>
        <div id="preview-popover-priority" class="hidden absolute right-0 top-full mt-1 z-40 bg-white border rounded-xl shadow-lg p-1.5 w-44">
          <% [
            { v: 'URGENT', l: '🔴 Urgent', c: 'text-red-600' },
            { v: 'HIGH',   l: '🟠 High',   c: 'text-orange-600' },
            { v: 'MEDIUM', l: '🟡 Medium', c: 'text-yellow-600' },
            { v: 'LOW',    l: '🟢 Low',    c: 'text-green-600' },
            { v: 'NONE',   l: 'Tanpa Prioritas', c: 'text-gray-500' }
          ].forEach(p => { %>
            <button type="button" data-value="<%= p.v %>" class="preview-pop-option w-full text-left px-2 py-1.5 rounded-lg hover:bg-gray-50 text-sm <%= p.c %>"><%= p.l %></button>
          <% }) %>
        </div>
      </div>
      <div class="relative">
        <div class="text-xs text-gray-400 font-medium mb-1 flex items-center gap-1.5">
          Due Date
          <button type="button" onclick="openPreviewPopover('due', event)" class="text-gray-300 hover:text-blue-500 transition" title="Edit deadline"><i class="fas fa-pen text-[9px]"></i></button>
        </div>
        <button type="button" onclick="openPreviewPopover('due', event)" id="preview-due"
          class="w-full text-left text-sm px-2 py-1.5 -mx-2 rounded-lg bg-gray-50 hover:bg-gray-100 transition"></button>
        <div id="preview-popover-due" class="hidden absolute left-0 top-full mt-1 z-40 bg-white border rounded-xl shadow-lg p-3 w-56">
          <input type="date" id="preview-due-input"
            class="w-full border rounded-lg px-2 py-1.5 text-sm focus:outline-none focus:border-blue-400">
          <div class="flex gap-2 mt-2">
            <button type="button" onclick="clearPreviewDue()" class="flex-1 py-1 text-xs text-gray-600 border rounded-lg hover:bg-gray-50">Hapus</button>
            <button type="button" onclick="closeAllPreviewPopovers()" class="flex-1 py-1 text-xs text-gray-600 border rounded-lg hover:bg-gray-50">Batal</button>
            <button type="button" onclick="savePreviewDue()" class="flex-1 py-1 text-xs bg-blue-600 text-white rounded-lg hover:bg-blue-700">Simpan</button>
          </div>
        </div>
      </div>
      <div class="relative">
        <div class="text-xs text-gray-400 font-medium mb-1 flex items-center gap-1.5">
          Assignee
          <button type="button" onclick="openPreviewPopover('assignee', event)" class="text-gray-300 hover:text-blue-500 transition" title="Edit assignee"><i class="fas fa-pen text-[9px]"></i></button>
        </div>
        <button type="button" onclick="openPreviewPopover('assignee', event)" id="preview-assignee"
          class="w-full text-left text-sm px-2 py-1.5 -mx-2 rounded-lg bg-gray-50 hover:bg-gray-100 transition truncate"></button>
        <div id="preview-popover-assignee" class="hidden absolute right-0 top-full mt-1 z-40 bg-white border rounded-xl shadow-lg p-1.5 w-56">
          <div class="max-h-60 overflow-y-auto" id="preview-assignee-options">
            <button type="button" data-id="" class="preview-pop-option w-full text-left flex items-center gap-2 px-2 py-1.5 rounded-lg hover:bg-gray-50 text-sm">
              <div class="w-6 h-6 bg-gray-200 rounded-full flex items-center justify-center text-gray-500 text-xs"><i class="fas fa-user-slash text-[10px]"></i></div>
              <span class="text-gray-500">Belum ditugaskan</span>
            </button>
            <% members.forEach(m => { %>
              <button type="button" data-id="<%= m.id %>" data-name="<%= m.name %>"
                class="preview-pop-option w-full text-left flex items-center gap-2 px-2 py-1.5 rounded-lg hover:bg-blue-50 text-sm">
                <div class="w-6 h-6 bg-blue-600 rounded-full flex items-center justify-center text-white text-xs font-bold shrink-0"><%= m.name.charAt(0) %></div>
                <span class="truncate"><%= m.name %></span>
              </button>
            <% }) %>
          </div>
        </div>
      </div>
    </div>

    <!-- Description -->
    <div>
      <div class="text-xs text-gray-400 font-medium mb-1">Deskripsi</div>
      <p class="text-sm text-gray-700" id="preview-desc"></p>
    </div>

    <!-- Checklist Progress -->
    <div>
      <div class="flex items-center justify-between mb-2">
        <span class="text-xs text-gray-400 font-medium">Checklist Progress</span>
        <span class="text-sm font-bold text-blue-600" id="preview-check-pct"></span>
      </div>
      <div class="h-2 bg-gray-100 rounded-full overflow-hidden mb-3">
        <div class="h-full bg-blue-500 rounded-full transition-all" id="preview-check-bar" style="width:0%"></div>
      </div>
      <div class="text-xs text-gray-400 font-medium mb-2">Belum Selesai:</div>
      <div class="space-y-1.5" id="preview-pending"></div>
    </div>
  </div>
  <div class="border-t p-4">
    <a id="preview-detail-link" href="#" class="block w-full py-3 bg-blue-600 text-white rounded-2xl text-center font-semibold hover:bg-blue-700 transition">
      <i class="fas fa-external-link-alt mr-2"></i>Buka Detail Task
    </a>
  </div>
</div>
<!-- Overlay -->
<div id="preview-overlay" onclick="closePreview()" class="fixed inset-0 bg-black/30 z-40 hidden"></div>

<!-- Mobile FAB (Floating Action Button) -->
<button id="fab-create" onclick="showCreateTaskModal()" class="fixed bottom-6 right-6 sm:hidden w-14 h-14 bg-blue-600 text-white rounded-full shadow-2xl flex items-center justify-center z-40 hover:bg-blue-700 active:scale-95 transition-all duration-200">
  <i class="fas fa-plus text-xl"></i>
</button>

<!-- Mobile Context Menu (shown on long press) -->
<div id="context-menu" class="hidden fixed z-[200] bg-white rounded-2xl shadow-2xl border p-2 w-56" style="backdrop-filter:blur(8px);">
  <button onclick="contextMenuAction('open')" class="w-full flex items-center gap-3 px-4 py-3 text-sm text-gray-700 hover:bg-gray-50 rounded-xl transition">
    <i class="fas fa-external-link-alt text-blue-500"></i> Buka Detail
  </button>
  <button onclick="contextMenuAction('todo')" class="w-full flex items-center gap-3 px-4 py-3 text-sm text-gray-700 hover:bg-gray-50 rounded-xl transition">
    <i class="fas fa-circle text-gray-400"></i> Pindah ke To Do
  </button>
  <button onclick="contextMenuAction('doing')" class="w-full flex items-center gap-3 px-4 py-3 text-sm text-gray-700 hover:bg-gray-50 rounded-xl transition">
    <i class="fas fa-circle text-amber-400"></i> Pindah ke Doing
  </button>
  <button onclick="contextMenuAction('done')" class="w-full flex items-center gap-3 px-4 py-3 text-sm text-gray-700 hover:bg-gray-50 rounded-xl transition">
    <i class="fas fa-circle text-emerald-500"></i> Tandai Selesai
  </button>
  <div class="border-t my-1"></div>
  <button onclick="contextMenuAction('delete')" class="w-full flex items-center gap-3 px-4 py-3 text-sm text-red-500 hover:bg-red-50 rounded-xl transition">
    <i class="fas fa-trash"></i> Hapus Task
  </button>
</div>

<script>
// Overlay toggle
const _origOpen = openPreview;
openPreview = function(taskId) {
  document.getElementById('preview-overlay').classList.remove('hidden');
  previewTaskId = taskId;
  _origOpen(taskId);
  refreshPreviewUI();
  initPreviewPopoverState();
};
const _origClose = closePreview;
closePreview = function() {
  document.getElementById('preview-overlay').classList.add('hidden');
  closeAllPreviewPopovers();
  _origClose();
};

let previewTaskId = null;
const PRIO_LABEL_PREVIEW = {
  URGENT: { l: '🔴 Urgent', c: 'bg-red-100 text-red-700' },
  HIGH:   { l: '🟠 High',   c: 'bg-orange-100 text-orange-700' },
  MEDIUM: { l: '🟡 Medium', c: 'bg-yellow-100 text-yellow-700' },
  LOW:    { l: '🟢 Low',    c: 'bg-green-100 text-green-700' },
  NONE:   { l: 'Tanpa Prioritas', c: 'text-gray-400 text-sm' }
};
const STATUS_LABEL_PREVIEW = { TODO: '📋 To Do', IN_PROGRESS: '🔄 Doing', DONE: '✅ Done' };

function openPreviewPopover(kind, e) {
  e.stopPropagation();
  closeAllPreviewPopovers();
  document.getElementById(`preview-popover-${kind}`)?.classList.remove('hidden');
  if (kind === 'due') {
    const t = tasks.find(x => x.id === previewTaskId);
    const input = document.getElementById('preview-due-input');
    input.value = t && t.dueDate ? new Date(t.dueDate).toISOString().split('T')[0] : '';
  }
}

function closeAllPreviewPopovers() {
  ['status', 'priority', 'due', 'assignee'].forEach(k => {
    document.getElementById(`preview-popover-${k}`)?.classList.add('hidden');
  });
}

document.addEventListener('click', (e) => {
  if (e.target.closest('[id^="preview-popover-"]')) return;
  if (e.target.closest('[onclick^="openPreviewPopover"]')) return;
  closeAllPreviewPopovers();
});

// Wire up popover options
document.querySelectorAll('#preview-popover-status .preview-pop-option').forEach(btn => {
  btn.addEventListener('click', async () => {
    const status = btn.dataset.value;
    closeAllPreviewPopovers();
    await previewUpdateField('status', status);
  });
});
document.querySelectorAll('#preview-popover-priority .preview-pop-option').forEach(btn => {
  btn.addEventListener('click', async () => {
    const priority = btn.dataset.value;
    closeAllPreviewPopovers();
    await previewUpdateField('priority', priority);
  });
});
document.querySelectorAll('#preview-popover-assignee .preview-pop-option').forEach(btn => {
  btn.addEventListener('click', async () => {
    const id = btn.dataset.id || null;
    const name = btn.dataset.name || '';
    closeAllPreviewPopovers();
    await previewUpdateField('assignee', { id, name });
  });
});

async function savePreviewDue() {
  const val = document.getElementById('preview-due-input').value || null;
  closeAllPreviewPopovers();
  await previewUpdateField('due', val);
}
async function clearPreviewDue() {
  closeAllPreviewPopovers();
  await previewUpdateField('due', null);
}

async function previewUpdateField(kind, value) {
  if (!previewTaskId) return;
  const t = tasks.find(x => x.id === previewTaskId);
  if (!t) return;
  const before = JSON.parse(JSON.stringify(t));
  let endpoint = '', body = {};
  if (kind === 'status')    { endpoint = `/tasks/${previewTaskId}/status`;    body = { status: value }; t.status = value; }
  if (kind === 'priority')  { endpoint = `/tasks/${previewTaskId}/priority`;  body = { priority: value }; t.priority = value; }
  if (kind === 'due')       { endpoint = `/tasks/${previewTaskId}/due-date`;  body = { dueDate: value }; t.dueDate = value ? new Date(value).toISOString() : null; }
  if (kind === 'assignee')  { endpoint = `/tasks/${previewTaskId}/assignee`;  body = { assigneeId: value.id }; t.assignee = value.id ? { id: value.id, name: value.name } : null; }
  try {
    const res = await fetch(endpoint, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body)
    });
    const data = await res.json();
    if (!data.success) throw new Error(data.error || 'Gagal');
    if (data.task) {
      if (data.task.status) t.status = data.task.status;
      if (data.task.priority) t.priority = data.task.priority;
      if (data.task.dueDate !== undefined) t.dueDate = data.task.dueDate;
    }
    refreshPreviewUI();
    renderKanban();
    if (kind === 'status') socket.emit('task-updated', { taskId: previewTaskId, status: t.status, projectId });
  } catch (err) {
    Object.assign(t, before);
    refreshPreviewUI();
    renderKanban();
    alert(err.message || 'Gagal update');
  }
}

function refreshPreviewUI() {
  const t = tasks.find(x => x.id === previewTaskId);
  if (!t) return;
  document.getElementById('preview-status').textContent = STATUS_LABEL_PREVIEW[t.status] || t.status;
  const p = PRIO_LABEL_PREVIEW[t.priority] || PRIO_LABEL_PREVIEW.NONE;
  document.getElementById('preview-priority').innerHTML = t.priority && t.priority !== 'NONE'
    ? `<span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold ${p.c}">${p.l}</span>`
    : `<span class="text-gray-400 text-sm">-</span>`;
  if (t.dueDate) {
    const d = new Date(t.dueDate);
    const isOverdue = d < new Date() && t.status !== 'DONE';
    document.getElementById('preview-due').innerHTML = `<span class="${isOverdue ? 'text-red-600 font-semibold' : ''}">${(isOverdue ? '⚠️ ' : '') + d.toLocaleDateString('id-ID', { weekday: 'short', day: 'numeric', month: 'short', year: 'numeric' })}</span>`;
  } else {
    document.getElementById('preview-due').innerHTML = '<span class="text-gray-400">-</span>';
  }
  if (t.assignee) {
    document.getElementById('preview-assignee').innerHTML = `
      <div class="flex items-center gap-2">
        <div class="w-6 h-6 bg-blue-600 rounded-full flex items-center justify-center text-white text-xs font-bold shrink-0">${escapeHtml(t.assignee.name.charAt(0))}</div>
        <span class="truncate">${escapeHtml(t.assignee.name)}</span>
      </div>`;
  } else {
    document.getElementById('preview-assignee').innerHTML = '<span class="text-gray-400">-</span>';
  }
}

function initPreviewPopoverState() {
  const t = tasks.find(x => x.id === previewTaskId);
  if (!t) return;
  // mark active status
  document.querySelectorAll('#preview-popover-status .preview-pop-option').forEach(b => {
    b.classList.toggle('bg-blue-50', b.dataset.value === t.status);
  });
  document.querySelectorAll('#preview-popover-priority .preview-pop-option').forEach(b => {
    b.classList.toggle('bg-blue-50', b.dataset.value === t.priority);
  });
  document.querySelectorAll('#preview-popover-assignee .preview-pop-option').forEach(b => {
    b.classList.toggle('bg-blue-50', (b.dataset.id || '') === (t.assignee?.id || ''));
  });
}
</script>

<!-- Template Modal -->
<div id="templateModal" class="hidden fixed inset-0 flex items-end sm:items-center justify-center z-50" style="backdrop-filter:blur(4px); background:rgba(0,0,0,0.5);">
  <div class="bg-white rounded-t-3xl sm:rounded-3xl p-5 sm:p-8 w-full sm:max-w-lg mx-0 sm:mx-4 shadow-2xl max-h-[85vh] overflow-y-auto transform transition-transform duration-300 translate-y-0">
    <!-- Drag handle (mobile) -->
    <div class="flex justify-center mb-4 sm:hidden cursor-grab active:cursor-grabbing" id="template-modal-handle">
      <div class="w-10 h-1.5 bg-gray-300 rounded-full"></div>
    </div>
    <div class="flex items-center justify-between mb-6">
      <div>
        <h3 class="text-2xl font-bold">Template Task</h3>
        <p class="text-sm text-gray-500 mt-1">Pakai ulang task beserta checklist-nya.</p>
      </div>
      <button onclick="hideTemplateModal()" class="p-2 rounded-xl hover:bg-gray-100 text-gray-500"><i class="fas fa-times"></i></button>
    </div>
    <div class="text-xs text-blue-600 bg-blue-50 border border-blue-100 rounded-2xl px-4 py-3 mb-4">
      Tips: buka detail task yang sudah rapi, lalu klik <b>Simpan Template</b> di bagian Checklist.
    </div>
    <div id="template-list" class="space-y-3 mb-4">
      <p class="text-gray-400 text-sm text-center py-4">Memuat template...</p>
    </div>
    <div class="border-t pt-4 mt-4">
      <h4 class="font-semibold text-sm mb-3">Buat Template Manual</h4>
      <input type="text" id="tpl-name" placeholder="Nama template (contoh: Buat Konten IG)"
        class="w-full border rounded-xl px-4 py-2.5 text-sm mb-3 focus:outline-none focus:border-blue-400">
      <textarea id="tpl-desc" placeholder="Deskripsi (opsional)" rows="2"
        class="w-full border rounded-xl px-4 py-2.5 text-sm mb-3 focus:outline-none focus:border-blue-400"></textarea>
      <div class="mb-3">
        <label class="text-xs text-gray-500 font-medium">Checklist (satu per baris)</label>
        <textarea id="tpl-checks" placeholder="Riset keyword&#10;Buat draft&#10;Desain visual&#10;Review" rows="4"
          class="w-full border rounded-xl px-4 py-2.5 text-sm mt-1 focus:outline-none focus:border-blue-400"></textarea>
      </div>
      <button onclick="saveTemplate()" class="w-full py-2.5 bg-purple-600 text-white rounded-xl text-sm font-medium hover:bg-purple-700 transition">
        <i class="fas fa-save mr-1"></i>Simpan Template
      </button>
    </div>
  </div>
</div>

<script>
async function showTemplateModal() {
  document.getElementById('templateModal').classList.remove('hidden');
  await loadTemplates();
}
function hideTemplateModal() {
  document.getElementById('templateModal').classList.add('hidden');
}

async function loadTemplates() {
  const list = document.getElementById('template-list');
  try {
    const res = await fetch(`/templates/brand/${companyId}`);
    const templates = await res.json();
    if (templates.length === 0) {
      list.innerHTML = '<p class="text-gray-400 text-sm text-center py-4">Belum ada template tersimpan</p>';
      return;
    }
    list.innerHTML = templates.map(t => `
      <div class="border rounded-2xl p-4 hover:bg-gray-50 transition">
        <div class="flex items-start justify-between gap-2 mb-2">
          <div class="min-w-0">
            <div class="font-semibold text-sm">${escapeHtml(t.name)}</div>
            ${t.description ? `<div class="text-xs text-gray-400 mt-0.5">${escapeHtml(t.description)}</div>` : ''}
            <div class="text-xs text-gray-400 mt-1">${t.checklists.length} checklist item</div>
          </div>
          <div class="flex gap-1 shrink-0">
            <button onclick="useTemplate('${t.id}')" class="px-3 py-1.5 bg-blue-600 text-white rounded-xl text-xs font-medium hover:bg-blue-700">
              <i class="fas fa-plus mr-1"></i>Pakai
            </button>
            <button onclick="deleteTemplate('${t.id}')" class="px-2 py-1.5 text-red-400 hover:text-red-600 text-xs"><i class="fas fa-trash"></i></button>
          </div>
        </div>
        ${t.checklists.length > 0 ? `<div class="mt-3 max-h-24 overflow-y-auto rounded-xl bg-gray-50 px-3 py-2 text-xs text-gray-500 space-y-1">${t.checklists.slice(0, 8).map(c => `<div>${escapeHtml(c.content)}</div>`).join('')}${t.checklists.length > 8 ? `<div>+${t.checklists.length - 8} item lagi</div>` : ''}</div>` : ''}
      </div>
    `).join('');
  } catch (e) {
    list.innerHTML = '<p class="text-red-400 text-sm text-center py-4">Gagal memuat template</p>';
  }
}

async function useTemplate(templateId) {
  try {
    const res = await fetch(`/templates/${templateId}/create-task`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ projectId })
    });
    const data = await res.json();
    if (data.success) {
      tasks.push(data.task);
      renderKanban();
      hideTemplateModal();
      openPreview(data.task.id);
    } else {
      alert('Gagal: ' + (data.error || 'unknown'));
    }
  } catch (e) {
    alert('Gagal membuat task dari template');
  }
}

async function saveTemplate() {
  const name = document.getElementById('tpl-name').value.trim();
  if (!name) return alert('Nama template wajib diisi');
  const description = document.getElementById('tpl-desc').value.trim();
  const checksRaw = document.getElementById('tpl-checks').value.trim();
  const checklists = checksRaw ? checksRaw.split('\n').map(s => s.trim()).filter(Boolean) : [];

  try {
    const res = await fetch('/templates', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name, description, companyId, checklists })
    });
    const data = await res.json();
    if (data.success) {
      document.getElementById('tpl-name').value = '';
      document.getElementById('tpl-desc').value = '';
      document.getElementById('tpl-checks').value = '';
      await loadTemplates();
    } else {
      alert('Gagal: ' + (data.error || 'unknown'));
    }
  } catch (e) {
    alert('Gagal menyimpan template');
  }
}

async function deleteTemplate(id) {
  if (!confirm('Hapus template ini?')) return;
  await fetch(`/templates/${id}`, { method: 'DELETE' });
  await loadTemplates();
}
</script>

