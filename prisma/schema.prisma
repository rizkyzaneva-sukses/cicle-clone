generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  password     String
  avatar       String?
  platformRole String   @default("user") // owner, partner, user
  telegramChatId String?
  onboardingCompleted Boolean @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships    Membership[]
  tasks          Task[]          @relation("TaskAssignee")
  comments       Comment[]
  messages       ChatMessage[]
  directSent     DirectMessage[] @relation("DirectSent")
  directReceived DirectMessage[] @relation("DirectReceived")
  notifications  Notification[]
  partnerAccess  PartnerAccess[]
  ownedWorkspaces Workspace[]       @relation("WorkspaceOwner")
  workspaceRoles  WorkspacePartner[]
  uploads        Attachment[]
  activityLogs   ActivityLog[]
  chatReactions  ChatReaction[]
  projectChatReads ProjectChatRead[]
  commentFiles   CommentFile[]
  projectMembers    ProjectMember[]
  pushSubscriptions PushSubscription[]
  recurringTaskTemplates RecurringTaskTemplate[] @relation("RecurringAssignee")
  announcements          Announcement[]
  projectReportEntries   ProjectReportEntry[] @relation("ReportCreatedBy")
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  ownerId   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner    User?              @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  brands   Company[]
  partners WorkspacePartner[]

  @@index([ownerId])
}

model WorkspacePartner {
  id          String   @id @default(cuid())
  userId      String
  workspaceId String
  role        String   @default("COO") // CEO, COO
  assignedAt  DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId])
}

model Company {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  workspaceId String?
  inviteToken String?  @unique
  description String?
  avatar      String?
  createdAt   DateTime @default(now())

  workspace     Workspace?      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  memberships   Membership[]
  projects      Project[]
  partnerAccess PartnerAccess[]
  labels        Label[]
  taskTemplates TaskTemplate[]
  reportEntries ProjectReportEntry[]

  @@index([workspaceId])
}

// Menghubungkan Partner ke Brand yang dia kelola
model PartnerAccess {
  id         String   @id @default(cuid())
  userId     String
  companyId  String
  assignedAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
}

model Membership {
  id        String   @id @default(cuid())
  userId    String
  companyId String
  role      String   @default("member") // admin, member
  joinedAt  DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  company Company @relation(fields: [companyId], references: [id])

  @@unique([userId, companyId])
}

model Project {
  id          String    @id @default(cuid())
  name        String
  description String?
  companyId   String
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  company        Company         @relation(fields: [companyId], references: [id])
  tasks          Task[]
  messages       ChatMessage[]
  attachments    Attachment[]
  activityLogs   ActivityLog[]
  projectMembers ProjectMember[]
  recurringTaskTemplates RecurringTaskTemplate[]
  reportConfig   ProjectReportConfig?
  reportEntries  ProjectReportEntry[]
  chatReadStates ProjectChatRead[]
}

model ProjectReportConfig {
  id        String   @id @default(cuid())
  projectId String   @unique
  columns   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ProjectReportEntry {
  id          String   @id @default(cuid())
  projectId   String
  reportDate  DateTime
  companyId   String?
  values      Json
  note        String?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  createdBy User?    @relation("ReportCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([projectId, reportDate])
  @@index([companyId])
}

// Template task berulang (mis. posting harian) — generator membuat Task baru otomatis tiap hari/minggu
model RecurringTaskTemplate {
  id          String    @id @default(cuid())
  title       String
  description String?
  priority    String    @default("NONE")
  projectId   String
  assigneeId  String?
  frequency   String    // DAILY, WEEKDAYS, WEEKLY
  weekday     Int?      // 0=Minggu..6=Sabtu, dipakai kalau frequency=WEEKLY
  active      Boolean   @default(true)
  lastRunDate String?   // YYYY-MM-DD terakhir kali task di-generate (dedup)
  createdAt   DateTime  @default(now())

  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee User?   @relation("RecurringAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([projectId])
}

// Pengumuman broadcast dari Owner ke semua user
model Announcement {
  id          String   @id @default(cuid())
  content     String
  createdById String?
  createdAt   DateTime @default(now())

  createdBy User? @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([createdAt])
}

// Siapa yang diberi akses lihat/kerja di proyek ini (selain owner/partner/admin brand yang otomatis full akses)
model ProjectMember {
  id        String   @id @default(cuid())
  userId    String
  projectId String
  addedAt   DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([projectId])
}

// Browser push subscription (Web Push API) per device
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("TODO") // TODO, IN_PROGRESS, DONE
  priority    String    @default("NONE") // NONE, LOW, MEDIUM, HIGH, URGENT
  position    Int       @default(0)
  dueDate     DateTime?
  projectId   String
  assigneeId  String?
  parentId    String?   // parent task for sub-task hierarchy
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project      Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee     User?           @relation("TaskAssignee", fields: [assigneeId], references: [id])
  parent       Task?           @relation("TaskParent", fields: [parentId], references: [id], onDelete: SetNull)
  children     Task[]          @relation("TaskParent")
  comments     Comment[]
  checklists   ChecklistItem[]
  labels       TaskLabel[]
  attachments  Attachment[]
  activityLogs ActivityLog[]
  taskDeps     TaskDependency[] @relation("TaskDeps")
  depOfDeps    TaskDependency[] @relation("TaskDependents")
  telegramReminderLogs TelegramReminderLog[]
}

// Tracks which deadline reminder (H-2/H-1/H/OVERDUE) was already sent for a task on a given day,
// so the daily scheduler doesn't resend the same reminder twice and OVERDUE can resend once per day.
model TelegramReminderLog {
  id        String   @id @default(cuid())
  taskId    String
  bucket    String   // H-2, H-1, H, OVERDUE
  sentDate  String   // YYYY-MM-DD
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, bucket, sentDate])
  @@index([taskId])
}

model ChecklistItem {
  id        String   @id @default(cuid())
  content   String
  isDone    Boolean  @default(false)
  taskId    String
  parentId  String?  // sub-checklist
  position  Int      @default(0)
  createdAt DateTime @default(now())

  task     Task            @relation(fields: [taskId], references: [id], onDelete: Cascade)
  parent   ChecklistItem?  @relation("SubChecklist", fields: [parentId], references: [id], onDelete: Cascade)
  children ChecklistItem[] @relation("SubChecklist")

  @@index([taskId])
  @@index([parentId])
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  taskId    String
  userId    String
  parentId  String?    // threaded comment
  reactions Json?
  createdAt DateTime @default(now())

  task     Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user     User        @relation(fields: [userId], references: [id])
  parent   Comment?    @relation("CommentThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Comment[]   @relation("CommentThread")
  files    CommentFile[]

  @@index([taskId])
  @@index([parentId])
}

model CommentFile {
  id        String   @id @default(cuid())
  filename  String
  originalName String
  mimeType  String
  size      Int
  url       String
  commentId String
  uploadedById String
  createdAt DateTime @default(now())

  comment    Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  uploadedBy User    @relation(fields: [uploadedById], references: [id], onDelete: Cascade)

  @@index([commentId])
}

model TaskDependency {
  id           String @id @default(cuid())
  taskId       String
  dependsOnId  String
  createdAt    DateTime @default(now())

  task      Task @relation("TaskDeps", fields: [taskId], references: [id], onDelete: Cascade)
  dependsOn Task @relation("TaskDependents", fields: [dependsOnId], references: [id], onDelete: Cascade)

  @@unique([taskId, dependsOnId])
  @@index([taskId])
  @@index([dependsOnId])
}

model ChatReaction {
  id            String   @id @default(cuid())
  chatMessageId String
  userId        String
  emoji         String
  createdAt     DateTime @default(now())

  chatMessage ChatMessage @relation(fields: [chatMessageId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chatMessageId, userId, emoji])
}

model ProjectChatRead {
  id         String   @id @default(cuid())
  projectId  String
  userId     String
  lastReadAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  content   String
  pinned    Boolean  @default(false)
  projectId String
  userId    String
  createdAt DateTime @default(now())

  project   Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User            @relation(fields: [userId], references: [id])
  attachments Attachment[]
  reactions   ChatReaction[]
}

model DirectMessage {
  id         String    @id @default(cuid())
  content    String    @default("")
  senderId   String
  receiverId String
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  sender      User         @relation("DirectSent", fields: [senderId], references: [id], onDelete: Cascade)
  receiver    User         @relation("DirectReceived", fields: [receiverId], references: [id], onDelete: Cascade)
  attachments Attachment[]
}

model Attachment {
  id              String   @id @default(cuid())
  filename        String
  originalName    String
  mimeType        String
  size            Int
  url             String
  uploadedById    String
  projectId       String?
  taskId          String?
  chatMessageId   String?
  directMessageId String?
  createdAt       DateTime @default(now())

  uploadedBy    User           @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  project       Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task          Task?          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  chatMessage   ChatMessage?   @relation(fields: [chatMessageId], references: [id], onDelete: Cascade)
  directMessage DirectMessage? @relation(fields: [directMessageId], references: [id], onDelete: Cascade)
}

model Label {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("#3B82F6")
  companyId String?
  createdAt DateTime @default(now())

  company Company?    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tasks   TaskLabel[]

  @@unique([name, companyId])
}

model TaskLabel {
  id      String @id @default(cuid())
  taskId  String
  labelId String

  task  Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@unique([taskId, labelId])
}

model ActivityLog {
  id         String   @id @default(cuid())
  action     String   @default("event")
  entityType String   @default("system")
  entityId   String   @default("")
  metadata   Json?
  userId     String?
  projectId  String?
  taskId     String?
  createdAt  DateTime @default(now())

  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  task    Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model TaskTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  priority    String   @default("NONE")
  companyId   String
  createdAt   DateTime @default(now())

  company    Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  checklists TemplateChecklist[]

  @@index([companyId])
}

model TemplateChecklist {
  id         String @id @default(cuid())
  content    String
  templateId String
  position   Int    @default(0)

  template TaskTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  content   String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
